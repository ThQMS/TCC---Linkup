# ─── OBRIGATÓRIAS ─────────────────────────────────────────────────────────────
# Todas as variáveis desta seção são exigidas na inicialização do servidor.
# O servidor recusa iniciar se alguma delas estiver ausente.

# Sessão — gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=gerar_valor_aleatorio_aqui

# E-mail (Gmail com App Password — veja docs/deployment.md para instruções)
GMAIL_USER=seu_email@gmail.com
GMAIL_PASS=sua_app_password_gmail

# API de IA (Groq — https://console.groq.com)
GROQ_API_KEY=sua_chave_groq

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linkup_db
DB_USER=postgres
DB_PASS=sua_senha_postgres

# ─── OBRIGATÓRIAS EM PRODUÇÃO ─────────────────────────────────────────────────
# Exigidas apenas quando NODE_ENV=production.

# Redis — habilita Socket.io adapter para multi-instância
# Em Docker este valor é sobrescrito automaticamente pelo docker-compose.yml
REDIS_URL=redis://localhost:6379

# ─── OPCIONAIS ────────────────────────────────────────────────────────────────
# Possuem valores padrão. Sobrescreva apenas se necessário.

# Ambiente de execução
NODE_ENV=development

# Porta do servidor HTTP (padrão: 3000)
PORT=3000

# URL base para links em e-mails transacionais
BASE_URL=http://localhost:3000

# Microserviço Python de busca semântica (padrão: http://localhost:5001)
# Em Docker este valor é sobrescrito automaticamente pelo docker-compose.yml
SEARCH_SERVICE_URL=http://localhost:5001

# Nível de log: error | warn | info | debug (padrão: info)
LOG_LEVEL=info

# Validação de CNPJ e domínio corporativo (padrão: false — habilitar em produção)
VALIDATE_COMPANY=false

# Connection string completa do PostgreSQL — substitui DB_HOST/PORT/NAME/USER/PASS quando definida.
# Provedores como Railway, Heroku e Render injetam esta variável automaticamente.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# SSL do PostgreSQL em produção — definir como "false" APENAS em provedores com
# certificado self-signed interno (ex: Railway). Padrão: true (recomendado)
# DB_SSL_REJECT_UNAUTHORIZED=false

# Senha padrão dos usuários criados pelo seed (apenas desenvolvimento)
SEED_PASSWORD=senha_para_o_seed
