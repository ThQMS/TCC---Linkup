# E-mail (Gmail com App Password)
GMAIL_USER=seu_email@gmail.com
GMAIL_PASS=sua_app_password_gmail

# Sessão (gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=gerar_valor_aleatorio_aqui

# API de IA
GROQ_API_KEY=sua_chave_groq

# Seed (senha padrão dos usuários de teste)
SEED_PASSWORD=senha_para_o_seed

# Ambiente
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linkup_db
DB_USER=postgres
DB_PASS=sua_senha_postgres

# Validação de CNPJ (false em dev, true em produção)
VALIDATE_COMPANY=false
