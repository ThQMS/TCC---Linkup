# ─── OBRIGATÓRIAS ─────────────────────────────────────────────────────────────
# Todas as variáveis desta seção são exigidas na inicialização do servidor.
# O servidor recusa iniciar se alguma delas estiver ausente.

# Sessão — gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=gerar_valor_aleatorio_aqui

# E-mail (Gmail com App Password — veja docs/deployment.md para instruções)
GMAIL_USER=seu_email@gmail.com
GMAIL_PASS=sua_app_password_gmail

# API de IA (Groq — https://console.groq.com)
GROQ_API_KEY=sua_chave_groq

# Modelo da Groq (centralizado). VERIFIQUE em https://console.groq.com/docs/models
# se o modelo ainda é suportado antes do deploy — modelos são descontinuados.
GROQ_MODEL=llama-3.3-70b-versatile

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=linkup_db
DB_USER=postgres
DB_PASS=sua_senha_postgres

# ─── OBRIGATÓRIAS EM PRODUÇÃO ─────────────────────────────────────────────────
# Exigidas apenas quando NODE_ENV=production.

# Redis — habilita Socket.io adapter para multi-instância
# Em Docker este valor é sobrescrito automaticamente pelo docker-compose.yml
REDIS_URL=redis://localhost:6379

# ─── OPCIONAIS ────────────────────────────────────────────────────────────────
# Possuem valores padrão. Sobrescreva apenas se necessário.

# Ambiente de execução
NODE_ENV=development

# Porta do servidor HTTP (padrão: 3000)
PORT=3000

# URL base para links em e-mails transacionais e no link de reset de senha.
BASE_URL=http://localhost:3000
# APP_URL: URL pública usada nos links de reset (cai no host da requisição se ausente).
# APP_URL=https://seudominio.com

# Segredo dedicado ao CSRF (recomendado). Se ausente, usa SESSION_SECRET.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CSRF_SECRET=gerar_valor_aleatorio_aqui

# Microserviço Python de busca semântica (padrão: http://localhost:5001)
# Em Docker este valor é sobrescrito automaticamente pelo docker-compose.yml
SEARCH_SERVICE_URL=http://localhost:5001

# Token compartilhado Node↔Python (opcional). Se definido, o serviço de busca
# exige o header x-search-token. Recomendado em produção.
# SEARCH_TOKEN=gerar_valor_aleatorio_aqui

# Limite GLOBAL diário de chamadas à IA (protege a conta Groq). Padrão: 1000
# GROQ_DAILY_LIMIT=1000

# Threshold do fit de redescoberta de talentos (0-100, padrão: 60)
# FIT_THRESHOLD=60

# Threshold de similaridade semântica do serviço Python (0-1, padrão: 0.25)
# EMBED_THRESHOLD=0.25

# Nível de log: error | warn | info | debug (padrão: info)
LOG_LEVEL=info

# Validação de CNPJ e domínio corporativo (padrão: false — habilitar em produção)
VALIDATE_COMPANY=false

# Connection string completa do PostgreSQL — substitui DB_HOST/PORT/NAME/USER/PASS quando definida.
# Provedores como Railway, Heroku e Render injetam esta variável automaticamente.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# SSL do PostgreSQL (migrations em produção). Padrão: desligado (Docker self-hosted).
# Ative em provedores gerenciados (Railway/Render/Heroku): DB_SSL=true
# DB_SSL=true
# Quando o provedor usa certificado self-signed interno: DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_REJECT_UNAUTHORIZED=false

# Senha padrão dos usuários criados pelo seed (apenas desenvolvimento)
SEED_PASSWORD=senha_para_o_seed
