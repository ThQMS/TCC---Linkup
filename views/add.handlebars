        { type: 'multipla',    question: 'Qual é o objetivo principal de um teste de usabilidade?', options: ['Validar preferências estéticas', 'Identificar problemas de uso', 'Aprovar o design final', 'Medir tempo de desenvolvimento'], correct: 1 },
        { type: 'aberta',      question: 'O que é design system e qual o benefício de adotá-lo?' }
