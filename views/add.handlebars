        { type: 'aberta',      question: 'O que você considera ao estruturar um programa de onboarding eficaz?' },
        { type: 'multipla',    question: 'O que é employer branding?', options: ['Marca do produto da empresa', 'Reputação da empresa como empregadora', 'Estratégia de vendas', 'Programa de benefícios'], correct: 1 },
        { type: 'situacional', question: 'Um gestor quer demitir um colaborador por baixa performance. Quais etapas você seguiria?' }
    ],
    marketing: [
