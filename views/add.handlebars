function selectContractType(type) {
    document.getElementById('contract-' + type).checked = true;
    document.querySelectorAll('#contract-grid .jf-mod-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('card-contract-' + type).classList.add('selected');
}

async function improveWithAI(fieldId, fieldLabel) {
    const textarea = document.getElementById(fieldId);
    const content  = textarea.value.trim();
    const title    = document.getElementById('title').value.trim();
    if (!content) { alert('Escreva algo no campo antes de melhorar com IA!'); return; }
    currentFieldId = fieldId;
    const modal  = document.getElementById('ia-modal');
    const result = document.getElementById('ia-result');
    modal.style.display = 'flex';
    result.innerHTML = '<span style="color:#555;">Gerando sugestão...</span>';
    try {
        const response = await fetch('/jobs/ai/improve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('input[name="_csrf"]').value },
            body: JSON.stringify({ fieldLabel, content, title })
        });
        const data = await response.json();
        result.textContent = data.improved || 'Erro ao gerar sugestão.';
    } catch (err) {
        result.innerHTML = '<span style="color:#e63946;">Erro ao conectar com a IA. Tente novamente.</span>';
    }
}

function applyIAResult() {
    const result = document.getElementById('ia-result').textContent;
    if (currentFieldId) document.getElementById(currentFieldId).value = result;
    closeIAModal();
}

function closeIAModal() {
    document.getElementById('ia-modal').style.display = 'none';
    currentFieldId = null;
}

// ─── BIAS AUDITOR ────────────────────────────────────────────────────────────
let _biasProblemas = [];

async function auditarBias() {
    const btn    = document.getElementById('bias-btn');
    const result = document.getElementById('bias-result');
    const title        = document.querySelector('input[name="title"]')?.value || '';
    const description  = document.querySelector('textarea[name="description"]')?.value || '';
    const requirements = document.querySelector('textarea[name="requirements"]')?.value || '';
    const benefits     = document.querySelector('textarea[name="benefits"]')?.value || '';
    if (!description && !requirements) { alert('Preencha pelo menos a descrição antes de analisar.'); return; }
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Analisando...';
    result.style.display = 'block';
    result.innerHTML = '<p style="color:#666;font-size:.84rem;">Analisando linguagem da vaga...</p>';
    try {
        const res  = await fetch('/bias/audit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('input[name="_csrf"]').value },
            body: JSON.stringify({ title, description, requirements, benefits })
        });
        const data = await res.json();
        const scoreColor = data.score_inclusividade >= 70 ? '#4caf50' : data.score_inclusividade >= 40 ? '#f59e0b' : '#e63946';
        const riskColor  = { baixo: '#4caf50', medio: '#f59e0b', alto: '#e63946' }[data.nivel_risco] || '#888';
        const problemasHtml = (data.problemas_encontrados || []).map(p => `
            <div style="background:#0d0d0d;border-left:2px solid #f59e0b;border-radius:4px;padding:10px 14px;margin-bottom:8px;">
                <p style="color:#f59e0b;font-size:.75rem;font-weight:700;margin:0 0 4px;text-transform:uppercase;">${p.tipo}</p>
                <p style="color:#ccc;font-size:.82rem;margin:0 0 6px;"><strong>Trecho:</strong> "${p.trecho}"</p>
                <p style="color:#4caf50;font-size:.82rem;margin:0;"><strong>Sugestão:</strong> ${p.sugestao}</p>
            </div>`).join('');
        result.innerHTML = `
            <div style="display:flex;gap:20px;margin-bottom:14px;flex-wrap:wrap;">
                <div style="text-align:center;"><div style="font-size:1.8rem;font-weight:700;color:${scoreColor};font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-variant-numeric:tabular-nums;">${data.score_inclusividade}</div><div style="color:#555;font-size:.72rem;">Score Inclusividade</div></div>
                <div style="text-align:center;"><div style="font-size:1rem;font-weight:700;color:${riskColor};text-transform:capitalize;">${data.nivel_risco}</div><div style="color:#555;font-size:.72rem;">Nível de Risco</div></div>
            </div>
            ${data.problemas_encontrados?.length ? `<p style="color:#888;font-size:.8rem;font-weight:600;margin-bottom:8px;">Problemas encontrados:</p>${problemasHtml}` : '<p style="color:#4caf50;font-size:.84rem;">Nenhum problema de bias encontrado!</p>'}
            <p style="color:#666;font-size:.78rem;margin-top:8px;">${data.resumo || ''}</p>
            ${data.problemas_encontrados?.length ? `<button type="button" onclick="aplicarSugestoesBias()" style="margin-top:12px;background:#4caf50;border:none;color:#fff;border-radius:8px;padding:8px 18px;cursor:pointer;font-weight:600;font-size:.84rem;font-family:inherit;">Aplicar Sugestões</button>` : ''}`;
        _biasProblemas = data.problemas_encontrados || [];
    } catch (e) {
        result.innerHTML = '<p style="color:#e63946;font-size:.84rem;">Erro ao analisar. Tente novamente.</p>';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-shield-check me-2"></i>Analisar Bias';
    }
}

function aplicarSugestoesBias() {
    const campos = ['description', 'requirements', 'benefits', 'differential'];
    let total = 0;
    _biasProblemas.forEach(p => {
        if (!p.trecho || !p.sugestao) return;
        campos.forEach(id => {
            const el = document.querySelector('textarea[name="' + id + '"]');
            if (el && el.value.includes(p.trecho)) { el.value = el.value.replace(p.trecho, p.sugestao); total++; }
        });
    });
    alert(total > 0 ? total + ' sugestão(ões) aplicada(s)!' : 'Nenhuma sugestão aplicável automaticamente.');
}

// ─── CITY AUTOCOMPLETE ───────────────────────────────────────────────────────
let citiesAdd = [], citiesAddLoaded = false;

async function loadCitiesAdd() {
    if (citiesAddLoaded) return;
    try {
        const res  = await fetch('https://servicodados.ibge.gov.br/api/v1/localidades/municipios?orderBy=nome');
        const data = await res.json();
        citiesAdd = data.map(m => ({ name: m.nome, state: m.microrregiao?.mesorregiao?.UF?.sigla || '' })).filter(m => m.name);
        citiesAddLoaded = true;
    } catch (e) {}
}

async function filterCitiesAdd(query) {
    const box = document.getElementById('city-drop-add');
    box.style.display = 'block';
    const q = query.trim().toLowerCase();
    if (q.length < 2) { box.innerHTML = '<div class="jf-city-item" style="color:#444;">Digite ao menos 2 letras...</div>'; return; }
    if (!citiesAddLoaded) { box.innerHTML = '<div class="jf-city-item" style="color:#444;">Carregando...</div>'; await loadCitiesAdd(); }
    const filtered = citiesAdd.filter(c => c.name.toLowerCase().includes(q)).slice(0, 10);
    box.innerHTML = filtered.length === 0
        ? '<div class="jf-city-item" style="color:#444;">Nenhuma cidade encontrada</div>'
        : filtered.map(c => `<div class="jf-city-item" onmousedown="selectCityAdd('${c.name.replace(/'/g,"\\'")}')"> ${c.name} <span style="color:#444;font-size:.75rem;">- ${c.state}</span></div>`).join('');
}

function selectCityAdd(val) {
    document.getElementById('city-input-add').value = val;
    document.getElementById('city-drop-add').style.display = 'none';
}

loadCitiesAdd();

// ─── PROGRESS BAR ────────────────────────────────────────────────────────────
function updateProgress() {
    const fields = ['title', 'description', 'requirements', 'benefits', 'salary'];
    const filled = fields.filter(id => { const el = document.getElementById(id); return el && el.value.trim(); }).length;
    const hasModality      = document.querySelector('input[name="modality"]:checked');
    const hasContractType  = document.querySelector('input[name="contractType"]:checked');
    const total = fields.length + 2;
    const done  = filled + (hasModality ? 1 : 0) + (hasContractType ? 1 : 0);
    const pct   = Math.round((done / total) * 100);
    document.getElementById('progress-fill').style.width  = pct + '%';
    document.getElementById('progress-label').textContent = pct + '% preenchido';
}

document.querySelectorAll('.jf-input, .jf-textarea').forEach(el => el.addEventListener('input', updateProgress));
document.querySelectorAll('#modality-grid .jf-mod-card, #contract-grid .jf-mod-card').forEach(el => el.addEventListener('click', updateProgress));
</script>
