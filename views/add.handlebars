        { type: 'aberta',      question: 'Quais métricas você analisa para avaliar o desempenho de uma campanha digital?' },
        { type: 'situacional', question: 'Uma campanha nas redes sociais está gerando muitos comentários negativos. Como você agiria?' },
        { type: 'multipla',    question: 'O que é taxa de conversão?', options: ['Número total de visitantes', '% de visitantes que realizam a ação desejada', 'Custo por clique', 'Alcance total da campanha'], correct: 1 },
        { type: 'aberta',      question: 'Como você estruturaria uma estratégia de SEO para um novo site?' }
    ],
    financeiro: [
        { type: 'aberta',      question: 'Explique a diferença entre fluxo de caixa e lucro líquido.' },
        { type: 'situacional', question: 'Você identificou uma inconsistência no balanço patrimonial. Qual seria sua abordagem?' },
        { type: 'multipla',    question: 'O que é EBITDA?', options: ['Lucro antes de impostos', 'Lucro antes de juros, impostos, depreciação e amortização', 'Receita bruta total', 'Fluxo de caixa operacional'], correct: 1 },
        { type: 'aberta',      question: 'Como você elabora e monitora um orçamento empresarial?' },
        { type: 'situacional', question: 'A empresa precisa reduzir custos em 15% sem demissões. Que análises você faria?' },
        { type: 'aberta',      question: 'Explique o conceito de capital de giro e sua importância para a saúde financeira.' }
    ],
    geral: [
        { type: 'situacional', question: 'Descreva uma situação em que você precisou aprender algo novo rapidamente sob pressão.' },
        { type: 'situacional', question: 'Conte sobre um projeto em que você trabalhou em equipe e houve um conflito. Como resolveu?' },
        { type: 'aberta',      question: 'Como você se organiza para gerenciar múltiplas tarefas com prazos simultâneos?' },
        { type: 'situacional', question: 'Você cometeu um erro que impactou o time. O que fez a seguir?' },
        { type: 'aberta',      question: 'Como você lida com feedbacks negativos sobre seu trabalho?' },
        { type: 'situacional', question: 'Descreva uma situação em que você precisou tomar uma decisão difícil com informações incompletas.' },
        { type: 'aberta',      question: 'Onde você se vê profissionalmente daqui a 2 anos e como esta vaga contribui para isso?' }
    ]
};

let questions = [];

(function() {
    const input = document.getElementById('questionsInput');
    if (input && input.value) {
        try { JSON.parse(input.value).forEach(q => addQuestion(q)); } catch(e) {}
    }
})();

function loadCategoryQuestions(category) {
    const bank = document.getElementById('question-bank');
    const list = document.getElementById('bank-list');
    if (!category) { bank.style.display = 'none'; return; }
    const items = QUESTION_BANK[category] || [];
    bank.style.display = 'block';
    list.innerHTML = items.map((q, i) => `
        <div style="display:flex;align-items:flex-start;gap:10px;padding:10px;border-radius:8px;margin-bottom:6px;background:#111;transition:background .15s;"
            onmouseover="this.style.background='#161616'" onmouseout="this.style.background='#111'">
            <input type="checkbox" id="bank-q-${i}" onchange="toggleBankQuestion(${i},'${category}')"
                style="accent-color:#e63946;margin-top:3px;flex-shrink:0;cursor:pointer;">
            <label for="bank-q-${i}" style="cursor:pointer;flex:1;">
                <span style="color:#ccc;font-size:.84rem;line-height:1.5;">${q.question}</span>
                <span style="display:inline-block;margin-left:8px;background:${q.type==='multipla'?'rgba(6,182,212,.1)':q.type==='situacional'?'rgba(168,85,247,.1)':'rgba(76,175,80,.1)'};color:${q.type==='multipla'?'#06b6d4':q.type==='situacional'?'#a855f7':'#4caf50'};border-radius:20px;padding:1px 8px;font-size:.66rem;">${q.type}</span>
            </label>
        </div>`).join('');
}

function toggleBankQuestion(index, category) {
    const q = QUESTION_BANK[category][index];
    const checkbox = document.getElementById('bank-q-' + index);
    if (checkbox.checked) {
        if (questions.length >= 5) { alert('Máximo de 5 perguntas por vaga.'); checkbox.checked = false; return; }
        addQuestion({ ...q, _bankIndex: index, _category: category });
    } else {
        questions = questions.filter(item => !(item._bankIndex === index && item._category === category));
        renderQuestions();
    }
}

function addCustomQuestion() {
    if (questions.length >= 5) { alert('Máximo de 5 perguntas por vaga.'); return; }
    addQuestion({ type: 'aberta', question: '', options: [], _custom: true });
}

function addQuestion(data = {}) {
    const id = Date.now() + Math.random();
    questions.push({ id, type: data.type || 'aberta', question: data.question || '', options: data.options || [], correct: data.correct, _bankIndex: data._bankIndex, _category: data._category, _custom: data._custom });
    renderQuestions();
}

function removeQuestion(id) {
    const q = questions.find(item => item.id === id);
    if (q && q._bankIndex !== undefined) {
        const cb = document.getElementById('bank-q-' + q._bankIndex);
        if (cb) cb.checked = false;
    }
    questions = questions.filter(item => item.id !== id);
    renderQuestions();
}

function updateQuestion(id, field, value) {
    const q = questions.find(item => item.id === id);
    if (q) q[field] = value;
}

function renderQuestions() {
    const list = document.getElementById('questions-list');
    document.getElementById('question-counter-label').textContent = `${questions.length}/5 perguntas`;
    if (questions.length === 0) { list.innerHTML = ''; return; }
    list.innerHTML = `
        <p style="color:#666;font-size:.78rem;font-weight:600;margin-bottom:10px;">Perguntas selecionadas:</p>
        ${questions.map((q, i) => `
        <div style="background:#111;border:1px solid ${q._custom ? 'rgba(230,57,70,.2)' : 'rgba(255,255,255,.06)'};border-radius:10px;padding:14px;margin-bottom:10px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <span style="color:#e63946;font-size:.78rem;font-weight:700;">Pergunta ${i+1}</span>
                    ${q._custom ? '<span style="background:rgba(230,57,70,.1);color:#e63946;font-size:.65rem;padding:1px 8px;border-radius:20px;">personalizada</span>' : '<span style="background:rgba(255,255,255,.05);color:#555;font-size:.65rem;padding:1px 8px;border-radius:20px;">banco</span>'}
                </div>
                <button type="button" onclick="removeQuestion(${q.id})" style="background:transparent;border:none;color:#444;cursor:pointer;font-size:.85rem;padding:0;transition:color .2s;" onmouseover="this.style.color='#e63946'" onmouseout="this.style.color='#444'">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            ${q._custom ? `
            <select onchange="updateQuestion(${q.id},'type',this.value)" style="background:#0d0d0d;border:1px solid rgba(255,255,255,.1);color:#ccc;border-radius:8px;padding:6px 12px;width:100%;margin-bottom:8px;font-size:.82rem;font-family:inherit;outline:none;">
                <option value="aberta" ${q.type==='aberta'?'selected':''}>Resposta aberta (avaliada por IA)</option>
                <option value="situacional" ${q.type==='situacional'?'selected':''}>Situacional (avaliada por IA)</option>
                <option value="multipla" ${q.type==='multipla'?'selected':''}>Múltipla escolha</option>
            </select>
            <textarea placeholder="Digite sua pergunta personalizada..." rows="2" oninput="updateQuestion(${q.id},'question',this.value)"
                style="width:100%;background:#0d0d0d;border:1px solid rgba(255,255,255,.1);color:#e0e0e0;border-radius:8px;padding:10px;resize:none;font-size:.84rem;font-family:inherit;outline:none;">${q.question}</textarea>
            ${q.type === 'multipla' ? `
            <div style="margin-top:8px;">
                <p style="color:#555;font-size:.74rem;margin:0 0 6px;">Opções (1 por linha). Marque a correta com *:</p>
                <textarea placeholder="Opção A&#10;Opção B&#10;*Opção C (correta)&#10;Opção D" rows="4" oninput="updateQuestion(${q.id},'options',this.value.split('\\n'))"
                    style="width:100%;background:#0d0d0d;border:1px solid rgba(255,255,255,.1);color:#e0e0e0;border-radius:8px;padding:10px;resize:none;font-size:.82rem;font-family:inherit;outline:none;">${(q.options||[]).join('\n')}</textarea>
            </div>` : ''}` : `
            <p style="color:#ccc;font-size:.84rem;margin:0;line-height:1.55;">${q.question}</p>
            ${q.type==='multipla' && q.options?.length ? `
            <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:6px;">
                ${q.options.map((opt,oi) => `<span style="background:${oi===q.correct?'rgba(76,175,80,.1)':'rgba(255,255,255,.04)'};border:1px solid ${oi===q.correct?'#4caf50':'rgba(255,255,255,.08)'};color:${oi===q.correct?'#4caf50':'#888'};border-radius:20px;padding:2px 10px;font-size:.74rem;">${oi===q.correct?'✓ ':''}${opt}</span>`).join('')}
            </div>` : ''}`}
        </div>`).join('')}`;
}

document.querySelector('form')?.addEventListener('submit', function() {
    document.getElementById('questionsInput').value = JSON.stringify(
        questions.map(({ id, _bankIndex, _category, _custom, ...rest }) => rest)
    );
    document.getElementById('stagesInput').value = JSON.stringify(stages.map(s => s.name));
});

// ─── ETAPAS DO PROCESSO ───────────────────────────────────────────────────────
const STAGE_TEMPLATES = {
    tech:        ['Triagem de Currículo', 'Entrevista RH', 'Teste Técnico', 'Entrevista Técnica', 'Entrevista com Gestor', 'Proposta'],
    design:      ['Triagem de Currículo', 'Entrevista RH', 'Desafio de Portfolio', 'Entrevista com Time de Design', 'Proposta'],
    vendas:      ['Triagem de Currículo', 'Entrevista RH', 'Role Play Comercial', 'Entrevista com Gestor', 'Proposta'],
    rh:          ['Triagem de Currículo', 'Entrevista RH', 'Entrevista com Liderança', 'Proposta'],
    executivo:   ['Triagem de Currículo', 'Entrevista RH', 'Assessment', 'Entrevista com Diretoria', 'Proposta'],
    operacional: ['Triagem de Currículo', 'Entrevista RH', 'Entrevista Operacional', 'Proposta'],
    marketing:   ['Triagem de Currículo', 'Entrevista RH', 'Desafio de Case', 'Entrevista com Time', 'Proposta'],
    financeiro:  ['Triagem de Currículo', 'Entrevista RH', 'Teste Técnico', 'Entrevista com Gestor', 'Proposta'],
    padrao:      ['Triagem de Currículo', 'Entrevista RH', 'Entrevista Final', 'Proposta'],
};

let stages = [];

function loadStageTemplate(category) {
    if (!category) return;
    stages = (STAGE_TEMPLATES[category] || []).map((name, i) => ({ id: i, name }));
    renderStages();
    document.getElementById('stages-template-select').value = '';
}

function addCustomStage(name) {
    stages.push({ id: Date.now(), name: name || '' });
    renderStages();
    const inputs = document.querySelectorAll('#stages-list input[type=text]');
    if (inputs.length) inputs[inputs.length - 1].focus();
}

function removeStage(id) {
    stages = stages.filter(s => s.id !== id);
    renderStages();
}

function updateStageName(id, value) {
    const s = stages.find(s => s.id === id);
    if (s) s.name = value;
}

function renderStages() {
    const list = document.getElementById('stages-list');
    if (!stages.length) {
        list.innerHTML = '<p style="color:#444;font-size:.8rem;text-align:center;padding:14px 0;">Nenhuma etapa definida. Use um modelo ou adicione manualmente.</p>';
        return;
    }
    list.innerHTML = stages.map((s, i) => `
        <div style="display:flex;align-items:center;gap:10px;background:#0d0d0d;border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:10px 14px;margin-bottom:8px;">
            <span style="width:24px;height:24px;border-radius:6px;background:#e63946;display:flex;align-items:center;justify-content:center;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-weight:800;font-size:.72rem;flex-shrink:0;color:#fff;font-variant-numeric:tabular-nums;">${i + 1}</span>
            <input type="text" value="${s.name.replace(/"/g, '&quot;')}" placeholder="Nome da etapa..."
                oninput="updateStageName(${s.id}, this.value)"
                style="flex:1;background:transparent;border:none;color:#e0e0e0;font-size:.88rem;outline:none;font-family:inherit;">
            <button type="button" onclick="removeStage(${s.id})"
                style="background:transparent;border:none;color:#444;cursor:pointer;padding:0;font-size:1rem;line-height:1;transition:color .15s;"
                onmouseover="this.style.color='#e63946'" onmouseout="this.style.color='#444'">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    `).join('');
}

async function suggestStagesWithAI() {
    const title = document.getElementById('title')?.value?.trim();
    const description = document.getElementById('description')?.value?.trim();
    if (!title) { alert('Preencha o título da vaga antes de sugerir etapas!'); return; }
    const btn = document.getElementById('stages-ai-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Gerando...';
    try {
        const response = await fetch('/jobs/ai/stages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('input[name="_csrf"]').value },
            body: JSON.stringify({ title, description })
        });
        const data = await response.json();
        if (data.stages && Array.isArray(data.stages)) {
            stages = data.stages.map((name, i) => ({ id: i, name }));
            renderStages();
        }
    } catch (err) {
        alert('Erro ao conectar com a IA. Tente novamente.');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-stars"></i> Sugerir com IA';
    }
}

renderStages();

