<style>
.jf-page{max-width:1120px;margin:0 auto;padding:32px 20px 100px}
.jf-header{display:flex;align-items:center;gap:20px;margin-bottom:36px;padding-bottom:24px;border-bottom:1px solid rgba(255,255,255,0.07)}
.jf-back{display:flex;align-items:center;justify-content:center;width:38px;height:38px;border:1px solid rgba(255,255,255,0.08);border-radius:10px;color:#777;text-decoration:none;transition:all .2s;flex-shrink:0;font-size:1rem}
.jf-back:hover{border-color:rgba(255,255,255,0.18);color:#fff}
.jf-header-info{flex:1}
.jf-page-title{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;letter-spacing:-.5px;margin:0 0 2px}
.jf-page-sub{font-size:.82rem;color:#555;margin:0}.jf-page-sub strong{color:#999}
.jf-progress-wrap{min-width:170px;text-align:right}
.jf-progress-label{font-size:.72rem;color:#555;margin-bottom:6px}
.jf-progress-bar{height:4px;background:rgba(255,255,255,0.07);border-radius:2px;overflow:hidden}
.jf-progress-fill{height:100%;background:#e63946;border-radius:2px;transition:width .4s ease;width:0%}
.jf-layout{display:grid;grid-template-columns:1fr 288px;gap:24px;align-items:start}
.jf-section{background:#111;border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:28px;margin-bottom:14px}
.jf-section-hdr{display:flex;align-items:flex-start;gap:14px;margin-bottom:24px;padding-bottom:18px;border-bottom:1px solid rgba(255,255,255,0.06)}
.jf-section-num{width:30px;height:30px;border-radius:8px;background:#e63946;display:flex;align-items:center;justify-content:center;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-weight:800;font-size:.8rem;flex-shrink:0;margin-top:1px;font-variant-numeric:tabular-nums}
.jf-section-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;margin:0 0 2px}
.jf-section-sub{font-size:.78rem;color:#555;margin:0}
.jf-optional{font-weight:400;font-size:.72rem;color:#555;margin-left:6px}
.jf-field{margin-bottom:16px}.jf-field:last-child{margin-bottom:0}
.jf-label{display:block;font-size:.82rem;font-weight:600;color:#bbb;margin-bottom:7px}
.jf-label-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:7px}
.jf-label-row .jf-label{margin-bottom:0}
.jf-req{color:#e63946}
.jf-input,.jf-textarea,.jf-select{width:100%;background:#0d0d0d;border:1px solid rgba(255,255,255,0.09);border-radius:10px;color:#e0e0e0;padding:11px 14px;font-size:.88rem;font-family:inherit;transition:border-color .2s,box-shadow .2s;outline:none;appearance:none}
.jf-input:focus,.jf-textarea:focus,.jf-select:focus{border-color:#e63946;box-shadow:0 0 0 3px rgba(230,57,70,.1)}
.jf-input::placeholder,.jf-textarea::placeholder{color:#333}
.jf-textarea{resize:vertical;min-height:96px;line-height:1.65}
.jf-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.jf-modality-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.jf-contract-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.jf-mod-card{background:#0d0d0d;border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:18px 10px;text-align:center;cursor:pointer;transition:all .25s}
.jf-mod-card:hover{border-color:rgba(255,255,255,0.15);background:rgba(255,255,255,0.02)}
.jf-mod-card.selected{border-color:#e63946;background:rgba(230,57,70,.06)}
.jf-mod-icon{font-size:1.3rem;color:#444;margin-bottom:8px;transition:color .25s}
.jf-mod-card.selected .jf-mod-icon{color:#e63946}
.jf-mod-name{font-size:.8rem;font-weight:600;color:#666;transition:color .25s}
.jf-mod-card.selected .jf-mod-name{color:#e0e0e0}
.jf-btn-ia{display:inline-flex;align-items:center;gap:4px;background:transparent;border:1px solid rgba(230,57,70,.35);color:#e63946;border-radius:6px;padding:4px 10px;font-size:.74rem;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap;font-family:inherit}
.jf-btn-ia:hover{background:#e63946;color:#fff;border-color:#e63946}
.jf-btn-ia:disabled{opacity:.4;cursor:not-allowed}
.jf-autocomplete{position:relative}
.jf-city-drop{display:none;position:absolute;top:100%;left:0;z-index:200;background:#181818;border:1px solid rgba(255,255,255,0.1);border-radius:10px;width:100%;max-height:220px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,.6);margin-top:4px}
.jf-city-item{padding:10px 14px;cursor:pointer;font-size:.84rem;color:#ccc;transition:background .15s;border-radius:6px}
.jf-city-item:hover{background:rgba(255,255,255,0.05)}
.jf-questions-wrap{background:#0d0d0d;border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:18px}
.jf-bias-wrap{background:rgba(168,85,247,.04);border:1px solid rgba(168,85,247,.2);border-radius:12px;padding:20px}
.jf-bias-hdr{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.jf-bias-hdr h6{color:#a855f7;font-weight:700;margin:0;font-size:.9rem}
.jf-bias-badge{background:#a855f7;color:#fff;font-size:.62rem;padding:2px 8px;border-radius:20px;font-weight:700}
.jf-bias-btn{background:transparent;border:1px solid #a855f7;color:#a855f7;border-radius:8px;padding:8px 18px;cursor:pointer;font-weight:600;font-size:.84rem;transition:all .2s;font-family:inherit}
.jf-bias-btn:hover{background:#a855f7;color:#fff}
.jf-submit{width:100%;background:#e63946;color:#fff;border:none;border-radius:12px;padding:15px;font-size:1rem;font-weight:700;font-family:inherit;cursor:pointer;transition:all .25s;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:4px}
.jf-submit:hover{background:#c62828;box-shadow:0 8px 28px rgba(230,57,70,.35);transform:translateY(-1px)}
.jf-sidebar{position:sticky;top:90px}
.jf-sb-card{background:#111;border:1px solid rgba(255,255,255,0.07);border-radius:14px;padding:20px;margin-bottom:12px}
.jf-sb-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#444;margin-bottom:14px}
.jf-company-name{font-weight:700;font-size:.9rem;color:#e0e0e0;margin-bottom:2px}
.jf-company-email{font-size:.76rem;color:#555}
.jf-ai-item{display:flex;align-items:center;gap:10px;padding:9px 12px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);border-radius:8px;margin-bottom:6px;font-size:.8rem;color:#aaa;cursor:pointer;transition:all .2s}
.jf-ai-item:hover{border-color:rgba(230,57,70,.25);color:#e0e0e0;background:rgba(230,57,70,.03)}
.jf-ai-item:last-child{margin-bottom:0}
.jf-ai-dot{width:24px;height:24px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0}
.jf-tip{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06);font-size:.78rem;color:#666;line-height:1.55}
.jf-tip:last-child{border-bottom:none;padding-bottom:0}
.jf-tip i{color:#e63946;flex-shrink:0;margin-top:1px}
.jf-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:9999;align-items:center;justify-content:center}
.jf-modal-box{background:#141414;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:32px;max-width:580px;width:90%;max-height:80vh;overflow-y:auto}
.jf-modal-title{font-family:'Syne',sans-serif;font-weight:700;color:#e63946;margin-bottom:4px;font-size:.95rem}
.jf-modal-sub{font-size:.82rem;color:#555;margin-bottom:14px}
.jf-modal-result{background:#0d0d0d;border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:16px;color:#e0e0e0;line-height:1.8;white-space:pre-wrap;min-height:80px;font-size:.87rem}
.jf-modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:16px}
.jf-modal-cancel{background:transparent;border:1px solid rgba(255,255,255,.1);color:#777;border-radius:8px;padding:8px 16px;cursor:pointer;font-size:.85rem;font-family:inherit;transition:all .2s}
.jf-modal-cancel:hover{border-color:rgba(255,255,255,.2);color:#ccc}
.jf-modal-apply{background:#e63946;border:none;color:#fff;border-radius:8px;padding:8px 20px;cursor:pointer;font-weight:600;font-size:.85rem;font-family:inherit;transition:all .2s}
.jf-modal-apply:hover{background:#c62828}
@media(max-width:900px){
  .jf-layout{grid-template-columns:1fr}
  .jf-sidebar{position:static}
  .jf-progress-wrap{display:none}
  .jf-row{grid-template-columns:1fr}
}
@media(max-width:480px){
  .jf-modality-grid{grid-template-columns:1fr}
  .jf-contract-grid{grid-template-columns:repeat(2,1fr)}
}
</style>

<div class="jf-page">

  <!-- HEADER -->
  <div class="jf-header">
    <a href="/" class="jf-back"><i class="bi bi-arrow-left"></i></a>
    <div class="jf-header-info">
      <h1 class="jf-page-title">Abrir nova vaga</h1>
      <p class="jf-page-sub">Publicando como <strong>{{user.name}}</strong></p>
    </div>
    <div class="jf-progress-wrap">
      <div class="jf-progress-label" id="progress-label">0% preenchido</div>
      <div class="jf-progress-bar"><div class="jf-progress-fill" id="progress-fill"></div></div>
    </div>
  </div>

  <div class="jf-layout">

    <!-- MAIN FORM -->
    <div>
      <form action="/jobs/add" method="POST" id="jobForm">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <input type="hidden" name="company" value="{{user.name}}">
        <input type="hidden" name="email" value="{{user.email}}">

        <!-- SEÇÃO 1: Informações Básicas -->
        <div class="jf-section">
          <div class="jf-section-hdr">
            <div class="jf-section-num">1</div>
            <div>
              <h3 class="jf-section-title">Informações Básicas</h3>
              <p class="jf-section-sub">Nome, formato de trabalho, localização e salário</p>
            </div>
          </div>

          <div class="jf-field">
            <label class="jf-label">Título da Vaga <span class="jf-req">*</span></label>
            <input type="text" class="jf-input" name="title" id="title"
              placeholder="Ex: Desenvolvedor Full Stack Pleno" required>
          </div>

          <div class="jf-field">
            <label class="jf-label">Modalidade <span class="jf-req">*</span></label>
            <div class="jf-modality-grid" id="modality-grid">
              <div class="jf-mod-card" onclick="selectModality('presencial')" id="card-presencial">
                <input type="radio" name="modality" value="presencial" id="presencial" style="display:none" required>
                <div class="jf-mod-icon"><i class="bi bi-buildings"></i></div>
                <div class="jf-mod-name">Presencial</div>
              </div>
              <div class="jf-mod-card" onclick="selectModality('hibrido')" id="card-hibrido">
                <input type="radio" name="modality" value="hibrido" id="hibrido" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-arrow-left-right"></i></div>
                <div class="jf-mod-name">Híbrido</div>
              </div>
              <div class="jf-mod-card" onclick="selectModality('homeoffice')" id="card-homeoffice">
                <input type="radio" name="modality" value="homeoffice" id="homeoffice" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-house-door"></i></div>
                <div class="jf-mod-name">Home Office</div>
              </div>
            </div>
          </div>

          <div class="jf-field">
            <label class="jf-label">Tipo de Contratação</label>
            <div class="jf-contract-grid" id="contract-grid">
              <div class="jf-mod-card" onclick="selectContractType('clt')" id="card-contract-clt">
                <input type="radio" name="contractType" value="clt" id="contract-clt" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-briefcase"></i></div>
                <div class="jf-mod-name">CLT</div>
              </div>
              <div class="jf-mod-card" onclick="selectContractType('pj')" id="card-contract-pj">
                <input type="radio" name="contractType" value="pj" id="contract-pj" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-building"></i></div>
                <div class="jf-mod-name">PJ</div>
              </div>
              <div class="jf-mod-card" onclick="selectContractType('estagio')" id="card-contract-estagio">
                <input type="radio" name="contractType" value="estagio" id="contract-estagio" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-mortarboard"></i></div>
                <div class="jf-mod-name">Estágio</div>
              </div>
              <div class="jf-mod-card" onclick="selectContractType('temporario')" id="card-contract-temporario">
                <input type="radio" name="contractType" value="temporario" id="contract-temporario" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-clock"></i></div>
                <div class="jf-mod-name">Temporário</div>
              </div>
              <div class="jf-mod-card" onclick="selectContractType('freelancer')" id="card-contract-freelancer">
                <input type="radio" name="contractType" value="freelancer" id="contract-freelancer" style="display:none">
                <div class="jf-mod-icon"><i class="bi bi-laptop"></i></div>
                <div class="jf-mod-name">Freelancer</div>
              </div>
            </div>
          </div>

          <div class="jf-field">
            <label class="jf-label">Vaga PCD <span class="jf-optional">opcional</span></label>
            <label id="pcd-label" style="display:flex;align-items:center;gap:12px;cursor:pointer;background:#0d0d0d;border:1px solid rgba(255,255,255,0.09);border-radius:10px;padding:14px;transition:border-color .2s,background .2s;">
              <input type="checkbox" name="isPcd" id="isPcd" style="display:none" onchange="updatePcdToggle()">
              <span id="pcd-toggle" style="width:38px;height:22px;background:#1a1a1a;border:1px solid rgba(255,255,255,.15);border-radius:11px;flex-shrink:0;position:relative;transition:background .2s,border-color .2s;">
                <span id="pcd-knob" style="position:absolute;top:3px;left:3px;width:14px;height:14px;background:#444;border-radius:50%;transition:all .2s;"></span>
              </span>
              <span style="font-size:.86rem;line-height:1.45;" id="pcd-text"><span style="font-weight:600;color:#777;">Vaga para PCD</span><br><span style="color:#444;font-size:.78rem;">Exclusiva ou prioritária para Pessoas com Deficiência</span></span>
            </label>
          </div>

          <div class="jf-row">
            <div class="jf-field">
              <label class="jf-label">Salário</label>
              <input type="text" class="jf-input" name="salary"
                placeholder="Ex: R$ 5.000 ou A combinar">
            </div>
            <div class="jf-field">
              <label class="jf-label">Cidade</label>
              <div class="jf-autocomplete">
                <input type="text" class="jf-input" id="city-input-add" name="city"
                  placeholder="Ex: São Paulo" autocomplete="off"
                  oninput="filterCitiesAdd(this.value)"
                  onfocus="filterCitiesAdd(this.value)"
                  onblur="setTimeout(()=>document.getElementById('city-drop-add').style.display='none',200)">
                <div id="city-drop-add" class="jf-city-drop"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- SEÇÃO 2: Conteúdo -->
        <div class="jf-section">
          <div class="jf-section-hdr">
            <div class="jf-section-num">2</div>
            <div>
              <h3 class="jf-section-title">Conteúdo da Vaga</h3>
              <p class="jf-section-sub">Descreva responsabilidades, requisitos e benefícios</p>
            </div>
          </div>

          <div class="jf-field">
            <div class="jf-label-row">
              <label class="jf-label">Descrição <span class="jf-req">*</span></label>
              <button type="button" class="jf-btn-ia" onclick="improveWithAI('description','descrição da vaga')">
                <i class="bi bi-stars"></i> Melhorar com IA
              </button>
            </div>
            <textarea class="jf-textarea" name="description" id="description" rows="4"
              placeholder="Descreva as responsabilidades e atividades do cargo..." required></textarea>
          </div>

          <div class="jf-field">
            <div class="jf-label-row">
              <label class="jf-label">Requisitos</label>
              <button type="button" class="jf-btn-ia" onclick="improveWithAI('requirements','requisitos da vaga')">
                <i class="bi bi-stars"></i> Melhorar com IA
              </button>
            </div>
            <textarea class="jf-textarea" name="requirements" id="requirements" rows="3"
              placeholder="Ex: 2 anos de experiência com Node.js, conhecimento em SQL..."></textarea>
          </div>

          <div class="jf-field">
            <div class="jf-label-row">
              <label class="jf-label">Benefícios</label>
              <button type="button" class="jf-btn-ia" onclick="improveWithAI('benefits','benefícios da vaga')">
                <i class="bi bi-stars"></i> Melhorar com IA
              </button>
            </div>
            <textarea class="jf-textarea" name="benefits" id="benefits" rows="3"
              placeholder="Ex: Vale refeição, plano de saúde, gympass..."></textarea>
          </div>

          <div class="jf-field">
            <div class="jf-label-row">
              <label class="jf-label">Diferencial <span style="color:#444;font-weight:400;font-size:.75rem;">(opcional)</span></label>
              <button type="button" class="jf-btn-ia" onclick="improveWithAI('differential','diferencial da vaga')">
                <i class="bi bi-stars"></i> Melhorar com IA
              </button>
            </div>
            <textarea class="jf-textarea" name="differential" id="differential" rows="2"
              placeholder="Ex: Experiência com AWS, certificações, inglês avançado..."></textarea>
          </div>
        </div>

        <!-- SEÇÃO 3: Teste Técnico -->
        <div class="jf-section">
          <div class="jf-section-hdr">
            <div class="jf-section-num">3</div>
            <div>
              <h3 class="jf-section-title">Teste Técnico <span class="jf-optional">opcional</span></h3>
              <p class="jf-section-sub">Adicione até 5 perguntas para filtrar candidatos</p>
            </div>
          </div>

          <div class="jf-questions-wrap">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
              <select id="category-select" onchange="loadCategoryQuestions(this.value)"
                style="background:#111;border:1px solid rgba(255,255,255,.1);color:#ccc;border-radius:8px;padding:8px 14px;font-size:.84rem;flex:1;max-width:320px;outline:none;font-family:inherit;">
                <option value="">Selecione uma área para ver perguntas...</option>
                <option value="frontend">Frontend</option>
                <option value="backend">Backend</option>
                <option value="mobile">Mobile</option>
                <option value="devops">DevOps</option>
                <option value="dados">Dados & BI</option>
                <option value="ux">UX/UI Design</option>
                <option value="vendas">Vendas & Comercial</option>
                <option value="rh">RH & Pessoas</option>
                <option value="marketing">Marketing</option>
                <option value="financeiro">Financeiro & Contábil</option>
                <option value="geral">Geral / Comportamental</option>
              </select>
              <span style="color:#555;font-size:.78rem;margin-left:12px;" id="question-counter-label">0/5 perguntas</span>
            </div>

            <div id="question-bank" style="display:none;background:#0a0a0a;border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:14px;margin-bottom:14px;">
              <p style="color:#777;font-size:.78rem;font-weight:600;margin-bottom:10px;">Selecione as perguntas que deseja usar:</p>
              <div id="bank-list"></div>
            </div>

            <div id="questions-list" style="margin-bottom:14px;"></div>

            <button type="button" onclick="addCustomQuestion()"
              style="background:transparent;border:1px solid rgba(255,255,255,.1);color:#666;border-radius:8px;padding:7px 14px;cursor:pointer;font-size:.8rem;font-family:inherit;transition:all .2s;"
              onmouseover="this.style.borderColor='#e63946';this.style.color='#e63946'"
              onmouseout="this.style.borderColor='rgba(255,255,255,.1)';this.style.color='#666'">
              <i class="bi bi-plus-lg me-1"></i> Pergunta personalizada
            </button>

            <input type="hidden" name="questions" id="questionsInput">
          </div>
        </div>

        <!-- SEÇÃO 4: Etapas do Processo Seletivo -->
        <div class="jf-section">
          <div class="jf-section-hdr">
            <div class="jf-section-num">4</div>
            <div>
              <h3 class="jf-section-title">Etapas do Processo <span class="jf-optional">opcional</span></h3>
              <p class="jf-section-sub">Defina as fases que os candidatos irão percorrer</p>
            </div>
          </div>

          <div class="jf-questions-wrap">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px;">
              <select id="stages-template-select" onchange="loadStageTemplate(this.value)"
                style="background:#111;border:1px solid rgba(255,255,255,.1);color:#ccc;border-radius:8px;padding:8px 14px;font-size:.84rem;flex:1;max-width:310px;outline:none;font-family:inherit;">
                <option value="">Carregar modelo por área...</option>
                <option value="tech">Tecnologia</option>
                <option value="design">Design / UX</option>
                <option value="vendas">Vendas & Comercial</option>
                <option value="rh">RH & Pessoas</option>
                <option value="executivo">Executivo / Liderança</option>
                <option value="operacional">Operacional</option>
                <option value="marketing">Marketing</option>
                <option value="financeiro">Financeiro</option>
                <option value="padrao">Processo Padrão</option>
              </select>
              <button type="button" class="jf-btn-ia" id="stages-ai-btn" onclick="suggestStagesWithAI()">
                <i class="bi bi-stars"></i> Sugerir com IA
              </button>
            </div>

            <div id="stages-list" style="margin-bottom:14px;"></div>

            <button type="button" onclick="addCustomStage()"
