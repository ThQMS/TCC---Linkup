<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LinkUp — Encontre sua próxima oportunidade</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --red: #e63946; --red-dark: #b71c1c; --red-glow: rgba(230,57,70,0.22);
      --bg: #0a0a0a; --bg2: #111111; --bg3: #181818;
      --border: rgba(255,255,255,0.07); --text: #f0f0f0; --muted: #777;
      --card-bg: rgba(255,255,255,0.03);
    }
    html { scroll-behavior: smooth; overflow-x: hidden; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }
    /* Garante que descenders de letras (g, j, p, q) não sejam cortados */
    h1, h2, h3, h4, h5, h6 { overflow: visible; text-rendering: geometricPrecision; -webkit-font-smoothing: antialiased; }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 0; opacity: 0.4;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 60px;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { text-decoration: none; display: flex; align-items: center; gap: 10px; font-family: 'Syne', sans-serif; font-size: 1.3rem; font-weight: 800; color: var(--text); letter-spacing: -0.5px; }
    .nav-logo-dot { width: 10px; height: 10px; background: var(--red); border-radius: 50%; display: inline-block; animation: pulse 2s infinite; }
    .nav-logo span { color: var(--red); }
    .nav-links { display: flex; gap: 10px; align-items: center; }
    .btn-outline { padding: 8px 20px; border: 1px solid var(--border); border-radius: 8px; color: #aaa; text-decoration: none; font-size: 0.88rem; font-family: 'DM Sans', sans-serif; transition: all 0.2s; background: transparent; }
    .btn-outline:hover { border-color: rgba(255,255,255,0.2); color: var(--text); }
    .btn-primary { padding: 8px 20px; background: var(--red); border: 1px solid var(--red); border-radius: 8px; color: white; text-decoration: none; font-size: 0.88rem; font-family: 'DM Sans', sans-serif; font-weight: 600; transition: all 0.2s; }
    .btn-primary:hover { background: var(--red-dark); box-shadow: 0 6px 20px var(--red-glow); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center; padding: 120px 20px 80px;
      position: relative;
    }

    /* Gradiente animado de fundo */
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% 40%, rgba(230,57,70,0.08) 0%, transparent 60%);
      animation: heroPulse 6s ease-in-out infinite;
      pointer-events: none;
    }
    @keyframes heroPulse {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50%       { opacity: 1;   transform: scale(1.15); }
    }

    /* Partículas decorativas */
    .hero-particles { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
    .hero-particles span {
      position: absolute; width: 2px; height: 2px; background: var(--red);
      border-radius: 50%; opacity: 0;
      animation: floatParticle var(--dur, 8s) var(--delay, 0s) infinite linear;
    }
    @keyframes floatParticle {
      0%   { opacity: 0;   transform: translateY(100vh) translateX(0); }
      10%  { opacity: 0.6; }
      90%  { opacity: 0.3; }
      100% { opacity: 0;   transform: translateY(-100px) translateX(var(--drift, 20px)); }
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 16px; border: 1px solid rgba(230,57,70,0.3); border-radius: 100px;
      background: rgba(230,57,70,0.07); font-size: 0.78rem; color: #ff8080;
      margin-bottom: 32px; position: relative; z-index: 1;
      animation: fadeDown 0.6s ease both;
    }
    .hero-badge-dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; animation: pulse 2s infinite; flex-shrink: 0; }

    /* Título com letras animadas */
    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2rem, 7vw, 5.5rem);
      font-weight: 800; line-height: 1.25; letter-spacing: -2.5px;
      margin-bottom: 24px; position: relative; z-index: 1;
    }
    .hero h1 .word { display: inline-block; overflow: hidden; padding-bottom: 0.8em; margin-bottom: -0.8em; vertical-align: top; }
    .hero h1 .word span {
      display: inline-block;
      opacity: 0; transform: translateY(30px);
      animation: wordReveal 0.6s forwards;
    }
    @keyframes wordReveal {
      to { opacity: 1; transform: translateY(0); }
    }
    .hero h1 em { font-style: normal; color: var(--red); position: relative; }
    .hero h1 em::after {
      content: ''; position: absolute; bottom: 2px; left: 0; right: 0;
      height: 3px; background: var(--red); border-radius: 2px; opacity: 0.35;
      transform: scaleX(0); transform-origin: left;
      animation: underlineReveal 0.6s 0.8s forwards;
    }
    @keyframes underlineReveal { to { transform: scaleX(1); } }

    .hero p { font-size: 1.1rem; color: var(--muted); max-width: 500px; line-height: 1.75; margin-bottom: 40px; animation: fadeDown 0.6s 0.5s ease both; opacity: 0; position: relative; z-index: 1; }

    .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; animation: fadeDown 0.6s 0.7s ease both; opacity: 0; position: relative; z-index: 1; }

    /* CTA com glow e ripple */
    .btn-hero {
      padding: 13px 30px; background: var(--red); color: white; border-radius: 10px;
      text-decoration: none; font-size: 0.95rem; font-weight: 600;
      font-family: 'DM Sans', sans-serif; transition: all 0.25s;
      border: none; display: inline-flex; align-items: center; gap: 8px;
      position: relative; overflow: hidden;
    }
    .btn-hero::after {
      content: ''; position: absolute; top: 50%; left: 50%;
      width: 0; height: 0; background: rgba(255,255,255,0.25);
      border-radius: 50%; transform: translate(-50%, -50%);
      transition: width 0.5s, height 0.5s, opacity 0.5s;
    }
    .btn-hero:active::after { width: 300px; height: 300px; opacity: 0; }
    .btn-hero:hover { background: var(--red-dark); transform: translateY(-2px) scale(1.02); box-shadow: 0 12px 30px var(--red-glow); }

    .btn-hero-outline {
      padding: 13px 30px; background: transparent; color: #aaa; border-radius: 10px;
      text-decoration: none; font-size: 0.95rem; font-weight: 500;
      font-family: 'DM Sans', sans-serif; transition: all 0.2s; border: 1px solid var(--border);
    }
    .btn-hero-outline:hover { border-color: rgba(255,255,255,0.18); color: var(--text); background: rgba(255,255,255,0.03); }

    /* ── COUNTERS ── */
    .counters {
      display: flex; justify-content: center; margin-top: 64px;
      border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
      background: var(--card-bg); backdrop-filter: blur(10px);
      animation: fadeDown 0.6s 0.9s ease both; opacity: 0;
      max-width: 640px; width: 100%; position: relative; z-index: 1;
    }
    .counter-item { flex: 1; padding: 26px 20px; text-align: center; border-right: 1px solid var(--border); }
    .counter-item:last-child { border-right: none; }
    .counter-num { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-size: 1.9rem; font-weight: 800; color: var(--red); display: block; font-variant-numeric: tabular-nums; }
    .counter-label { font-size: 0.78rem; color: var(--muted); margin-top: 4px; display: block; }

    section { position: relative; z-index: 1; }
    .section-tag { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2.5px; color: var(--red); margin-bottom: 12px; }
    .section-title { font-family: 'Syne', sans-serif; font-size: clamp(1.7rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -1.5px; line-height: 1.4; margin-bottom: 16px; padding-bottom: 0.1em; }
    .section-sub { color: var(--muted); font-size: 0.95rem; line-height: 1.75; max-width: 460px; }

    /* ── FEATURES ── */
    .features { padding: 100px 60px; max-width: 1200px; margin: 0 auto; }
    .features-header { margin-bottom: 56px; }
    .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

    .feature-card {
      background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px;
      padding: 28px; transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
      position: relative; overflow: hidden;
    }
    .feature-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0;
      height: 2px; background: linear-gradient(90deg, var(--red), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .feature-card:hover { border-color: rgba(230,57,70,0.3); transform: translateY(-8px); background: rgba(230,57,70,0.04); box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
    .feature-card:hover::before { opacity: 1; }
    .feature-card:hover .feature-icon { transform: scale(1.15) rotate(-5deg); background: rgba(230,57,70,0.2); }

    .feature-icon {
      width: 44px; height: 44px; background: rgba(230,57,70,0.1); border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem; margin-bottom: 18px; color: var(--red);
      transition: all 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }
    .feature-card h3 { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 8px; line-height: 1.4; }
    .feature-card p { font-size: 0.87rem; color: var(--muted); line-height: 1.65; }

    /* ── IA SHOWCASE ── */
    .ia-section { padding: 100px 60px; background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .ia-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .ia-tools { display: flex; flex-direction: column; gap: 12px; margin-top: 36px; }
    .ia-tool {
      display: flex; align-items: center; gap: 16px; padding: 18px 20px;
      background: var(--bg3); border: 1px solid var(--border); border-radius: 12px;
      transition: all 0.3s;
    }
    .ia-tool:hover { border-color: rgba(230,57,70,0.2); background: rgba(230,57,70,0.03); transform: translateX(4px); }
    .ia-tool-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1rem; }
    .ia-tool-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 2px; }
    .ia-tool-desc { font-size: 0.8rem; color: var(--muted); }

    /* ── HOW IT WORKS ── */
    .how { padding: 100px 60px; }
    .how-inner { max-width: 1200px; margin: 0 auto; }
    .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px; }
    .step-card { padding: 32px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; transition: all 0.3s; }
    .step-card:hover { border-color: rgba(230,57,70,0.2); transform: translateY(-3px); }
    .step-num { width: 36px; height: 36px; background: var(--red); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-weight: 800; font-size: 0.85rem; margin-bottom: 20px; font-variant-numeric: tabular-nums; }
    .step-card h4 { font-family: 'Syne', sans-serif; font-weight: 700; margin-bottom: 8px; font-size: 1rem; }
    .step-card p { font-size: 0.87rem; color: var(--muted); line-height: 1.65; }

    /* ── RESPONSIVIDADE ── */
    .responsive-section { padding: 100px 60px; background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .responsive-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 36px; }
    .metric-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 14px; padding: 20px; }
    .metric-card.full { grid-column: span 2; }
    .metric-label { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .metric-value { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-size: 1.4rem; font-weight: 800; font-variant-numeric: tabular-nums; }
    .metric-value.red { color: var(--red); }
    .metric-bar { height: 4px; background: var(--border); border-radius: 2px; margin-top: 10px; overflow: hidden; }
    .metric-fill { height: 100%; background: var(--red); border-radius: 2px; }
    .metric-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(76,175,80,0.1); border: 1px solid rgba(76,175,80,0.3); color: #4caf50; border-radius: 20px; padding: 4px 12px; font-size: 0.75rem; font-weight: 600; margin-top: 8px; }

    /* ── TESTIMONIALS ── */
    .testimonials { padding: 100px 60px; max-width: 1200px; margin: 0 auto; }
    .testimonials-header { margin-bottom: 56px; }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .testimonial-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 28px; transition: all 0.3s; }
    .testimonial-card:hover { border-color: rgba(230,57,70,0.2); transform: translateY(-3px); }
    .stars { color: var(--red); font-size: 0.85rem; margin-bottom: 14px; letter-spacing: 2px; }
    .testimonial-text { font-size: 0.9rem; line-height: 1.7; color: #bbb; margin-bottom: 22px; font-style: italic; }
    .testimonial-author { display: flex; align-items: center; gap: 10px; }
    .author-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--red), #ff8080); display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; }
    .author-name { font-weight: 600; font-size: 0.88rem; }
    .author-role { font-size: 0.78rem; color: var(--muted); }

    /* ── CTA ── */
    .cta-section { padding: 100px 60px; text-align: center; background: var(--bg2); border-top: 1px solid var(--border); position: relative; overflow: hidden; }
    .cta-section::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 800px; height: 400px; background: radial-gradient(ellipse, rgba(230,57,70,0.08) 0%, transparent 70%); pointer-events: none; }
    .cta-section h2 { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; letter-spacing: -1.5px; line-height: 1.35; margin-bottom: 16px; }
    .cta-section p { color: var(--muted); font-size: 0.95rem; margin-bottom: 40px; }

    /* ── FOOTER ── */
    footer { padding: 36px 60px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .footer-text { font-size: 0.78rem; color: var(--muted); }

    /* RECONEXÃO INTELIGENTE */
    .reconnect-section { padding: 100px 60px; background: var(--bg2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .reconnect-inner { max-width: 1200px; margin: 0 auto; }
    .reconnect-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 56px; }
    .reconnect-card {
      background: var(--bg3); border: 1px solid var(--border); border-radius: 20px;
      padding: 36px; position: relative; overflow: hidden; transition: all 0.35s;
    }
    .reconnect-card.company { border-color: rgba(168,85,247,0.15); }
    .reconnect-card.candidate { border-color: rgba(6,182,212,0.15); }
    .reconnect-card.similar { border-color: rgba(251,146,60,0.15); }
    .reconnect-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; }
    .reconnect-card.company::before  { background: linear-gradient(90deg, #a855f7, transparent); }
    .reconnect-card.candidate::before { background: linear-gradient(90deg, #06b6d4, transparent); }
    .reconnect-card.similar::before  { background: linear-gradient(90deg, #fb923c, transparent); }
    .reconnect-card.company:hover  { transform: translateY(-5px); box-shadow: 0 24px 48px rgba(168,85,247,0.12); border-color: rgba(168,85,247,0.35); }
    .reconnect-card.candidate:hover { transform: translateY(-5px); box-shadow: 0 24px 48px rgba(6,182,212,0.12); border-color: rgba(6,182,212,0.35); }
    .reconnect-card.similar:hover  { transform: translateY(-5px); box-shadow: 0 24px 48px rgba(251,146,60,0.12); border-color: rgba(251,146,60,0.35); }
    .reconnect-tag { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 100px; font-size: 0.75rem; font-weight: 600; margin-bottom: 16px; }
    .company-tag  { background: rgba(168,85,247,0.1); color: #a855f7; border: 1px solid rgba(168,85,247,0.25); }
    .candidate-tag { background: rgba(6,182,212,0.1);   color: #06b6d4; border: 1px solid rgba(6,182,212,0.25); }
    .similar-tag  { background: rgba(251,146,60,0.1);   color: #fb923c; border: 1px solid rgba(251,146,60,0.25); }
    .reconnect-title { font-family: 'Syne', sans-serif; font-size: 1.3rem; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 12px; line-height: 1.4; }
    .reconnect-desc  { font-size: 0.87rem; color: var(--muted); line-height: 1.7; margin-bottom: 24px; }
    .reconnect-mock  { background: rgba(0,0,0,0.35); border: 1px solid var(--border); border-radius: 12px; padding: 14px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
    .mock-candidate  { display: flex; align-items: center; gap: 12px; padding: 10px 12px; background: rgba(255,255,255,0.03); border-radius: 8px; }
    .mock-candidate.dim { opacity: 0.55; }
    .mock-avatar { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.75rem; flex-shrink: 0; color: #fff; }
    .mock-info  { flex: 1; }
    .mock-name  { font-size: 0.82rem; font-weight: 600; }
    .mock-role  { font-size: 0.74rem; color: var(--muted); }
    .mock-fit   { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; font-weight: 800; font-size: 0.88rem; color: #a855f7; font-variant-numeric: tabular-nums; }
    .mock-notif { display: flex; align-items: center; gap: 12px; padding: 14px; background: rgba(6,182,212,0.05); border: 1px solid rgba(6,182,212,0.15); border-radius: 10px; }
    .mock-notif-icon { width: 36px; height: 36px; border-radius: 10px; background: rgba(6,182,212,0.15); color: #06b6d4; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
    .mock-notif-body { flex: 1; }
    .mock-notif-title { font-size: 0.82rem; font-weight: 600; margin-bottom: 2px; }
    .mock-notif-sub   { font-size: 0.74rem; color: var(--muted); }
    .mock-notif-time  { font-size: 0.72rem; color: var(--muted); flex-shrink: 0; }
    .avail-pills { display: flex; gap: 8px; flex-wrap: wrap; padding: 14px; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 10px; }
    .avail-pills-label { font-size: 0.74rem; color: var(--muted); width: 100%; margin-bottom: 4px; }
    .avail-pill { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: 100px; font-size: 0.74rem; background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--muted); }
    .avail-pill.active { background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.3); color: #06b6d4; }
    .reconnect-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 0.78rem; font-weight: 600; }
    .reconnect-badge.purple { color: #a855f7; }
    .reconnect-badge.teal   { color: #06b6d4; }
    .reconnect-badge.orange { color: #fb923c; }
    .mock-fit.orange { color: #fb923c; }
    .mock-fit-new { font-size: 0.65rem; font-weight: 600; padding: 2px 7px; border-radius: 100px; background: rgba(251,146,60,0.1); color: #fb923c; border: 1px solid rgba(251,146,60,0.3); white-space: nowrap; }

    /* ANIMATIONS */
    @keyframes fadeDown { from { opacity: 0; transform: translateY(-16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.85); } }

    /* Scroll reveal */
    .reveal { opacity: 0; transform: translateY(32px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 900px) {
      nav { padding: 14px 20px; }
      .features, .how, .testimonials, .cta-section, .ia-section, .responsive-section, .reconnect-section { padding: 60px 20px; }
      .features-grid, .testimonials-grid, .steps-grid { grid-template-columns: 1fr; }
