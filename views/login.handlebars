<style>
.auth-split{display:flex;min-height:100vh;}
.auth-left{width:42%;background:#0d0d0d;border-right:1px solid #1e1e1e;display:flex;flex-direction:column;justify-content:space-between;padding:48px 52px;position:relative;overflow:hidden;}
.auth-left::before{content:'';position:absolute;bottom:-80px;right:-80px;width:400px;height:400px;background:radial-gradient(ellipse,rgba(230,57,70,0.1) 0%,transparent 65%);pointer-events:none;}
.auth-left-logo{text-decoration:none;display:flex;align-items:center;gap:10px;font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;color:#f0f0f0;letter-spacing:-0.5px;}
.auth-left-logo-dot{width:10px;height:10px;background:#e63946;border-radius:50%;flex-shrink:0;}
.auth-left-logo span{color:#e63946;}
.auth-left-content{position:relative;z-index:1;}
.auth-left h2{font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800;letter-spacing:-1px;line-height:1.4;margin-bottom:10px;}
.auth-left h2 em{font-style:normal;color:#e63946;}
.auth-left-sub{color:#444;font-size:0.85rem;line-height:1.6;margin-bottom:28px;}
.auth-left-footer{color:#2a2a2a;font-size:0.72rem;}
.auth-right{flex:1;display:flex;align-items:center;justify-content:center;padding:48px 40px;background:#0a0a0a;}
.auth-form-box{width:100%;max-width:420px;}
.auth-form-box .form-label{font-size:0.83rem;font-weight:600;color:#ccc;margin-bottom:5px;}
.auth-form-box .form-control,.auth-form-box .auth-input{background:#141414!important;border:1px solid #2a2a2a!important;color:#f0f0f0!important;border-radius:8px;padding:10px 14px;font-size:0.88rem;transition:border-color 0.2s;}
.auth-form-box .form-control:focus,.auth-form-box .auth-input:focus{border-color:#e63946!important;box-shadow:none!important;}
.auth-form-box .form-control::placeholder{color:#444;}
.auth-eye-btn{background:#141414!important;border:1px solid #2a2a2a!important;border-left:none!important;color:#555!important;}
.auth-eye-btn:hover{color:#e63946!important;}
.auth-submit{background:#e63946;border:none;color:white;width:100%;padding:11px;border-radius:8px;font-weight:700;font-size:0.92rem;cursor:pointer;transition:all 0.2s;margin-top:4px;}
.auth-submit:hover{background:#b71c1c;transform:translateY(-1px);box-shadow:0 8px 24px rgba(230,57,70,0.3);}
.auth-link{color:#e63946;text-decoration:none;}
.auth-link:hover{text-decoration:underline;}
.auth-divider{display:flex;align-items:center;gap:12px;margin:20px 0;}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:#1a1a1a;}
.auth-divider span{color:#333;font-size:0.75rem;}
@media(max-width:768px){.auth-left{display:none;}.auth-right{padding:40px 24px;}}
</style>

<div class="auth-split">

    <div class="auth-left">
        <a href="/landing" class="auth-left-logo">
            <span class="auth-left-logo-dot"></span>
            Link<span>Up</span>
        </a>

        <div class="auth-left-content">
            <h2>Bem-vindo<br>de <em>volta</em></h2>
            <p class="auth-left-sub">Vagas reais, empresas reais, IA que faz diferença.</p>

            <div style="display:flex;flex-direction:column;gap:12px;">
                <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:20px 22px;position:relative;overflow:hidden;">
                    <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#e63946,transparent);"></div>
                    <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:1.5px;color:#444;margin-bottom:8px;">Vagas na plataforma</div>
                    <div style="display:flex;align-items:baseline;gap:10px;">
                        <span id="stat-jobs" style="font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-size:2.6rem;font-weight:800;font-variant-numeric:tabular-nums;color:#e63946;line-height:1;">0</span>
                        <span style="font-size:0.75rem;color:#4caf50;font-weight:600;background:rgba(76,175,80,0.08);border:1px solid rgba(76,175,80,0.2);border-radius:20px;padding:2px 8px;">Ao vivo</span>
                    </div>
                    <div style="font-size:0.75rem;color:#333;margin-top:4px;">Oportunidades esperando por você</div>
                </div>
                <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:14px;padding:20px 22px;position:relative;overflow:hidden;">
                    <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,rgba(6,182,212,0.7),transparent);"></div>
                    <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:1.5px;color:#444;margin-bottom:8px;">Empresas cadastradas</div>
                    <div style="display:flex;align-items:baseline;gap:10px;">
                        <span id="stat-companies" style="font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-size:2.6rem;font-weight:800;font-variant-numeric:tabular-nums;color:#06b6d4;line-height:1;">0</span>
                        <span style="font-size:0.75rem;color:#06b6d4;font-weight:600;background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.2);border-radius:20px;padding:2px 8px;">Recrutando</span>
                    </div>
                    <div style="font-size:0.75rem;color:#333;margin-top:4px;">Empresas ativas na plataforma</div>
                </div>
            </div>
        </div>

        <div class="auth-left-footer">© 2025 LinkUp — Projeto TCC</div>
    </div>

    <div class="auth-right">
        <div class="auth-form-box">
            <div style="margin-bottom:32px;">
                <h3 style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.5rem;letter-spacing:-0.5px;margin-bottom:6px;">Entrar na conta</h3>
                <p style="color:#444;font-size:0.83rem;margin:0;">Não tem conta? <a href="/register" class="auth-link">Cadastre-se grátis</a></p>
            </div>

            <form action="/login" method="POST">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <input type="hidden" name="redirect" value="">

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control auth-input" name="email" placeholder="seu@email.com" required>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label" style="margin:0;">Senha</label>
                        <a href="/forgot-password" class="auth-link" style="font-size:0.78rem;">Esqueceu a senha?</a>
                    </div>
                    <div class="input-group">
                        <input type="password" class="form-control auth-input" id="password" name="password" placeholder="Sua senha" required>
                        <button class="btn auth-eye-btn" type="button" onclick="togglePass('password','eye-icon')"><i id="eye-icon" class="bi bi-eye"></i></button>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="remember" id="remember" value="1" style="accent-color:#e63946;">
                        <label class="form-check-label" for="remember" style="color:#444;font-size:0.8rem;cursor:pointer;">Lembrar de mim por 30 dias</label>
                    </div>
                </div>

                <button type="submit" class="auth-submit" id="login-submit-btn">Entrar</button>
            </form>

            <div class="auth-divider"><span>ou</span></div>

            <p style="text-align:center;color:#333;font-size:0.8rem;">
                Ainda não tem conta? <a href="/register" class="auth-link">Criar conta grátis</a>
            </p>
        </div>
    </div>
</div>

<script>
// Anima contadores do 0 até o valor real
function animateCounter(id, target) {
    const el = document.getElementById(id);
    if (!el || target === 0) { if(el) el.textContent = target; return; }
    let current = 0;
    const step = Math.max(1, Math.ceil(target / 40));
    const timer = setInterval(() => {
        current = Math.min(current + step, target);
        el.textContent = current;
        if (current >= target) clearInterval(timer);
    }, 30);
}

animateCounter('stat-jobs', {{totalJobs}});
animateCounter('stat-companies', {{totalCompanies}});

(function(){
    const params=new URLSearchParams(window.location.search),redirect=params.get('redirect');
    if(redirect){const i=document.querySelector('input[name="redirect"]');if(i)i.value=redirect;}
})();

function togglePass(fId,iId){const f=document.getElementById(fId),i=document.getElementById(iId);if(f.type==='password'){f.type='text';i.classList.replace('bi-eye','bi-eye-slash');}else{f.type='password';i.classList.replace('bi-eye-slash','bi-eye');}}

/* ── VALIDAÇÃO INLINE ── */
function setFieldError(input, msg) {
    input.style.borderColor = '#f03e3e';
    let err = input.parentElement.querySelector('.lk-field-err');
    if (!err) { err = document.createElement('p'); err.className = 'lk-field-err'; err.style.cssText = 'color:#f03e3e;font-size:0.75rem;margin:4px 0 0;'; input.parentElement.appendChild(err); }
    err.textContent = msg;
}
function clearFieldError(input) {
    input.style.borderColor = '';
    const err = input.parentElement.querySelector('.lk-field-err');
    if (err) err.remove();
}
document.querySelector('form[action="/login"]').addEventListener('submit', function(e) {
    let valid = true;
    const email = this.querySelector('input[name="email"]');
    const pass  = this.querySelector('input[name="password"]');
    clearFieldError(email); clearFieldError(pass);
    if (!email.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
        setFieldError(email, 'Informe um e-mail válido.'); valid = false;
    }
    if (!pass.value || pass.value.length < 6) {
        setFieldError(pass, 'A senha deve ter ao menos 6 caracteres.'); valid = false;
    }
    if (!valid) { e.preventDefault(); return; }
    const btn = document.getElementById('login-submit-btn');
    btn.textContent = 'Entrando...'; btn.disabled = true;
});

</script>
