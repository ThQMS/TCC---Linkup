<div style="padding-top: 100px; padding-bottom: 60px;">
  <div class="container" style="max-width: 860px;">

    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
      <div>
        <h2 style="color:#f03e3e;font-weight:700;margin:0;">Candidatos</h2>
        <p style="color:#aaa;margin:4px 0 0;font-size:0.9rem;">Vaga: <strong>{{job.title}}</strong>
          <span style="margin-left:8px;padding:2px 10px;border-radius:20px;font-size:0.75rem;font-weight:700;
            {{#if (eq job.status 'aberta')}}background:rgba(76,175,80,0.1);border:1px solid #4caf50;color:#4caf50;
            {{else if (eq job.status 'encerrada')}}background:rgba(240,62,62,0.1);border:1px solid #f03e3e;color:#f03e3e;
            {{else}}background:#2a2a2a;border:1px solid #555;color:#888;{{/if}}">
            {{job.status}}
          </span>
        </p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
        {{#unless (eq job.status 'encerrada')}}
        <form action="/jobs/close/{{job.id}}" method="POST" onsubmit="return confirm('Encerrar a vaga e enviar feedback para todos os candidatos não selecionados? Esta ação não pode ser desfeita.')">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <button type="submit" style="background:transparent;border:1px solid #f03e3e;color:#f03e3e;border-radius:8px;padding:7px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;transition:all 0.2s;" onmouseover="this.style.background='rgba(240,62,62,0.1)'" onmouseout="this.style.background='transparent'">
            <i class="bi bi-x-circle me-1"></i>Encerrar vaga
          </button>
        </form>
        {{/unless}}
        <a href="javascript:history.back()" style="color:#aaa;text-decoration:none;font-size:0.9rem;padding:7px 0;">
          <i class="bi bi-arrow-left me-1"></i>Voltar
        </a>
      </div>
    </div>

    {{#if jobStages.length}}
    <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:12px;padding:16px 20px;margin-bottom:20px;">
      <p style="font-size:0.78rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 12px;"><i class="bi bi-list-check me-1"></i>Etapas do processo</p>
      <div style="display:flex;align-items:center;flex-wrap:wrap;gap:0;">
        {{#each jobStages}}
        <div style="display:flex;align-items:center;gap:0;">
          <span style="background:#2a2a2a;border:1px solid #3a3a3a;color:#aaa;border-radius:20px;padding:4px 14px;font-size:0.78rem;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;" title="{{this}}">{{this}}</span>
          {{#unless @last}}<i class="bi bi-chevron-right" style="color:#444;font-size:0.7rem;margin:0 4px;"></i>{{/unless}}
        </div>
        {{/each}}
        <i class="bi bi-chevron-right" style="color:#444;font-size:0.7rem;margin:0 4px;"></i>
        <span style="background:rgba(76,175,80,0.1);border:1px solid #4caf50;color:#4caf50;border-radius:20px;padding:4px 14px;font-size:0.78rem;font-weight:700;">Contratado</span>
      </div>
    </div>
    {{/if}}

    <!-- CANDIDATOS SIMILARES SUGERIDOS (carregado via JS) -->
    <div id="suggested-alert" style="display:none;background:linear-gradient(135deg,rgba(230,57,70,0.06),rgba(6,182,212,0.05));border:1px solid rgba(6,182,212,0.4);border-radius:12px;padding:20px 24px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:16px;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:12px;">
          <i class="bi bi-person-plus" style="color:#06b6d4;font-size:1.4rem;"></i>
          <div>
            <div style="font-weight:700;color:#06b6d4;" id="suggested-title">Candidatos Similares</div>
            <div style="color:#888;font-size:0.82rem;">Perfis com alto fit que ainda não se candidataram a esta vaga.</div>
          </div>
        </div>
      </div>
      <div id="suggested-list" style="display:flex;flex-direction:column;gap:10px;"></div>
    </div>

    <!-- DICA: VALOR DE ATUALIZAR STATUS -->
    {{#if applicants.length}}
    {{#if (eq job.status 'aberta')}}
    <div id="status-tip" style="background:rgba(255,193,7,0.04);border:1px solid rgba(255,193,7,0.2);border-radius:12px;padding:14px 18px;margin-bottom:20px;display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap;">
      <i class="bi bi-lightbulb" style="color:#ffc107;font-size:1.2rem;margin-top:2px;flex-shrink:0;"></i>
      <div style="flex:1;min-width:0;">
        <p style="font-weight:700;color:#ffc107;font-size:0.85rem;margin:0 0 4px;">Por que manter os status atualizados?</p>
        <p style="color:#888;font-size:0.8rem;margin:0;line-height:1.7;">
          Seu <strong style="color:#ccc;">Dashboard</strong> calcula Taxa de Resposta, Tempo Médio e outros indicadores com base nos status —
          sem atualizar, os dados ficam imprecisos.
          Candidatos marcados como <strong style="color:#ccc;">Aceito</strong> ou <strong style="color:#ccc;">Recusado</strong> recebem feedback automático, o que melhora a reputação da empresa na plataforma.
          E atualizar rápido é o que garante o <strong style="color:#4caf50;">Selo Empresa Responsiva</strong> no seu perfil.
        </p>
      </div>
      <button onclick="dismissStatusTip()"
        style="background:none;border:none;color:#555;font-size:1rem;cursor:pointer;padding:0;flex-shrink:0;" title="Fechar e não mostrar novamente nesta sessão">×</button>
    </div>
    {{/if}}
    {{/if}}

    <!-- ALERTA REDESCOBERTA DE TALENTOS (carregado via JS) -->
    <div id="rediscovery-alert" style="display:none;background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(240,62,62,0.06));border:1px solid #a855f7;border-radius:12px;padding:20px 24px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
        <i class="bi bi-stars" style="color:#a855f7;font-size:1.4rem;"></i>
        <div>
          <div style="font-weight:700;color:#a855f7;" id="rediscovery-title">Redescoberta de Talentos</div>
          <div style="color:#888;font-size:0.82rem;">Candidatos com alto fit da sua base que estão disponíveis.</div>
        </div>
      </div>
      <div id="rediscovery-list" style="display:flex;flex-direction:column;gap:10px;"></div>
    </div>

    {{#if applicants.length}}

      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;">
        <div>
          <p style="color:#888;font-size:0.85rem;margin:0;">{{applicants.length}} candidato(s)</p>
          <p id="compare-hint" style="color:#555;font-size:0.75rem;margin:3px 0 0;"><i class="bi bi-check2-square me-1"></i>Marque 2 ou 3 candidatos para comparar com IA</p>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button id="compare-btn" onclick="compararSelecionados()" style="display:none;background:#06b6d4;border:none;color:white;border-radius:8px;padding:8px 18px;cursor:pointer;font-weight:600;font-size:0.85rem;transition:opacity 0.2s;">
            <i class="bi bi-scale me-1"></i>Comparar (<span id="selected-count">0</span>)
          </button>
          <button id="rank-btn" onclick="rankCandidates()"
            style="background:transparent;border:1px solid #a855f7;color:#a855f7;border-radius:8px;padding:8px 20px;cursor:pointer;font-weight:600;font-size:0.9rem;transition:all 0.2s;"
            onmouseover="this.style.background='#a855f7';this.style.color='white'"
            onmouseout="this.style.background='transparent';this.style.color='#a855f7'">
            <i class="bi bi-robot me-1"></i>Rankear com IA
          </button>
        </div>
      </div>

      <div id="applicants-list">
        {{#each applicants}}
          <div class="applicant-card" data-id="{{this.id}}"
            style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:20px;margin-bottom:16px;transition:border-color 0.2s;">

            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">

              <div class="d-flex align-items-center gap-3">
                <div class="rank-badge" style="display:none;width:32px;height:32px;border-radius:50%;background:#a855f7;color:white;font-weight:700;font-size:0.9rem;align-items:center;justify-content:center;flex-shrink:0;"></div>
                <label style="position:relative;width:18px;height:18px;flex-shrink:0;cursor:pointer;" title="Selecionar para comparar">
                  <input type="checkbox" class="candidate-check" data-id="{{this.id}}" onchange="updateCompareBtn()" style="position:absolute;opacity:0;width:0;height:0;">
                  <span class="custom-check" style="position:absolute;inset:0;border-radius:5px;border:2px solid #3a3a3a;background:#1a1a1a;transition:all 0.15s;display:flex;align-items:center;justify-content:center;"></span>
                </label>
                <div style="width:50px;height:50px;border-radius:50%;border:2px solid #f03e3e;background:#2a2a2a;display:flex;align-items:center;justify-content:center;color:#f03e3e;font-size:1.3rem;flex-shrink:0;">
                  <i class="bi bi-person-fill"></i>
                </div>
                <div>
                  <p style="font-weight:700;margin:0;">{{this.candidate.name}}</p>
                  <p style="color:#aaa;font-size:0.85rem;margin:2px 0;">{{this.candidate.email}}</p>
                  {{#if this.candidate.city}}
                    <p style="color:#888;font-size:0.8rem;margin:0;"><i class="bi bi-geo-alt me-1"></i>{{this.candidate.city}}</p>
                  {{/if}}
                </div>
              </div>

              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;">
                {{#if (eq this.status 'contratado')}}
                  <span style="background:rgba(76,175,80,0.15);border:1px solid #4caf50;color:#4caf50;border-radius:20px;padding:4px 12px;font-size:0.8rem;font-weight:700;"><i class="bi bi-award-fill me-1"></i>Contratado</span>
                {{else if (eq this.status 'aprovado')}}
                  <span style="background:#1a3a1a;border:1px solid #4caf50;color:#4caf50;border-radius:20px;padding:4px 12px;font-size:0.8rem;"><i class="bi bi-check-circle-fill me-1"></i>Aprovado</span>
                {{else if (eq this.status 'rejeitado')}}
                  <span style="background:#3a1a1a;border:1px solid #f03e3e;color:#f03e3e;border-radius:20px;padding:4px 12px;font-size:0.8rem;"><i class="bi bi-x-circle-fill me-1"></i>Recusado</span>
                {{else if (eq this.status 'expirado')}}
                  <span style="background:#2a2a2a;border:1px solid #444;color:#666;border-radius:20px;padding:4px 12px;font-size:0.8rem;"><i class="bi bi-dash-circle me-1"></i>Encerrado</span>
                {{else}}
                  <span style="background:#2a2a2a;border:1px solid #555;color:#aaa;border-radius:20px;padding:4px 12px;font-size:0.8rem;"><i class="bi bi-hourglass-split me-1"></i>Em análise</span>
                {{/if}}
                {{#if (or (eq this.status 'aprovado') (eq this.status 'contratado'))}}
                {{#if this.currentStage}}
                  <span class="current-stage-badge" style="background:rgba(6,182,212,0.08);border:1px solid rgba(6,182,212,0.3);color:#06b6d4;border-radius:20px;padding:4px 10px;font-size:0.75rem;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;" title="{{this.currentStage}}">
                    <i class="bi bi-layers me-1"></i>{{this.currentStage}}
                  </span>
                {{/if}}
                {{/if}}
                <div class="ia-score" style="display:none;text-align:right;">
                  <div class="score-value" style="font-size:1.4rem;font-weight:700;"></div>
                  <div style="color:#aaa;font-size:0.72rem;">compatibilidade</div>
                </div>
              </div>
            </div>

            {{#if this.skills.length}}
              <div style="margin-top:12px;display:flex;flex-wrap:wrap;gap:6px;">
                {{#each this.skills}}
                  <span style="background:#2a2a2a;border:1px solid #f03e3e;color:#f03e3e;border-radius:20px;padding:3px 10px;font-size:0.78rem;">{{this}}</span>
                {{/each}}
              </div>
            {{/if}}

            <div class="ia-analysis" style="display:none;margin-top:14px;background:#2a2a2a;border:1px solid #3a3a3a;border-radius:8px;padding:14px;">
              <p style="color:#a855f7;font-size:0.8rem;font-weight:700;margin:0 0 6px;"><i class="bi bi-robot me-1"></i>Análise da IA</p>
              <p class="analysis-text" style="color:#ccc;font-size:0.85rem;margin:0;line-height:1.6;white-space:pre-wrap;"></p>
            </div>

            <!-- Candidatos Similares -->
            <div style="margin-top:14px;padding-top:14px;border-top:1px solid #232323;">
              <button onclick="toggleSimilares({{this.id}}, this)"
                style="background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.25);color:#a855f7;font-size:0.8rem;font-weight:600;cursor:pointer;padding:7px 16px;border-radius:20px;display:inline-flex;align-items:center;gap:7px;transition:all 0.2s;"
                onmouseover="this.style.background='rgba(168,85,247,0.18)';this.style.borderColor='#a855f7';"
                onmouseout="this.style.background='rgba(168,85,247,0.08)';this.style.borderColor='rgba(168,85,247,0.25)';">
                <i class="bi bi-people-fill"></i>Candidatos Similares
              </button>
              <div id="similar-{{this.id}}" style="display:none;margin-top:12px;"></div>
            </div>

            {{#unless (eq this.status 'contratado')}}
            {{#unless (eq this.status 'expirado')}}
            {{#unless (eq this.status 'rejeitado')}}
            <div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap;align-items:center;">

              {{#if (eq this.status 'aprovado')}}
              {{#if ../jobStages.length}}
              <form action="/jobs/applications/stage" method="POST" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin:0;">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                <input type="hidden" name="applicationId" value="{{this.id}}">
                <input type="hidden" name="jobId" value="{{../job.id}}">
                <span style="font-size:0.78rem;color:#888;white-space:nowrap;">Mover para:</span>
                <div style="position:relative;display:inline-flex;align-items:center;">
                  <select name="stageName" onchange="this.form.submit()"
                    style="background:#2a2a2a;border:1px solid #3a3a3a;color:#ccc;border-radius:6px;padding:5px 28px 5px 10px;font-size:0.8rem;cursor:pointer;appearance:none;-webkit-appearance:none;outline:none;max-width:180px;">
                    <option value="" style="background:#2a2a2a;color:#888;">Selecionar etapa...</option>
                    {{#each ../jobStages}}
                    <option value="{{this}}" style="background:#2a2a2a;color:#ccc;" {{#if (eq this ../currentStage)}}selected{{/if}}>{{this}}</option>
                    {{/each}}
                  </select>
                  <i class="bi bi-chevron-down" style="position:absolute;right:8px;pointer-events:none;color:#888;font-size:0.7rem;"></i>
                </div>
              </form>
              {{/if}}
              {{/if}}

              {{#unless (eq this.status 'aprovado')}}
              <form action="/jobs/applications/status" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                <input type="hidden" name="applicationId" value="{{this.id}}">
                <input type="hidden" name="jobId" value="{{../job.id}}">
                <input type="hidden" name="status" value="aprovado">
                <button type="submit"
                  style="background:rgba(6,182,212,0.1);border:1px solid #06b6d4;color:#06b6d4;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;transition:all 0.2s;" onmouseover="this.style.background='#06b6d4';this.style.color='white'" onmouseout="this.style.background='rgba(6,182,212,0.1)';this.style.color='#06b6d4'">
                  <i class="bi bi-check-circle me-1"></i>Aceitar
                </button>
              </form>
              {{/unless}}

              {{#if (eq this.status 'aprovado')}}
              <form action="/jobs/applications/status" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                <input type="hidden" name="applicationId" value="{{this.id}}">
                <input type="hidden" name="jobId" value="{{../job.id}}">
                <input type="hidden" name="status" value="contratado">
                <button type="submit"
                  onclick="return confirm('Confirmar contratação de {{this.candidate.name}}? Os outros candidatos receberão um e-mail de feedback quando você encerrar a vaga.')"
                  style="background:rgba(76,175,80,0.1);border:1px solid #4caf50;color:#4caf50;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:0.82rem;font-weight:700;white-space:nowrap;transition:all 0.2s;" onmouseover="this.style.background='#4caf50';this.style.color='white'" onmouseout="this.style.background='rgba(76,175,80,0.1)';this.style.color='#4caf50'">
                  <i class="bi bi-award-fill me-1"></i>Contratar
                </button>
              </form>
              {{/if}}

              <form action="/jobs/applications/status" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                <input type="hidden" name="applicationId" value="{{this.id}}">
                <input type="hidden" name="jobId" value="{{../job.id}}">
                <input type="hidden" name="status" value="rejeitado">
                {{#if (eq this.status 'aprovado')}}
                <button type="submit"
                  onclick="return confirm('Desclassificar {{this.candidate.name}}? O candidato será removido do processo seletivo.')"
                  style="background:rgba(240,62,62,0.1);border:1px solid #f03e3e;color:#f03e3e;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;transition:all 0.2s;" onmouseover="this.style.background='#f03e3e';this.style.color='white'" onmouseout="this.style.background='rgba(240,62,62,0.1)';this.style.color='#f03e3e'">
                  <i class="bi bi-person-x me-1"></i>Desclassificar
                </button>
                {{else}}
                <button type="submit"
                  style="background:rgba(240,62,62,0.1);border:1px solid #f03e3e;color:#f03e3e;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;transition:all 0.2s;" onmouseover="this.style.background='#f03e3e';this.style.color='white'" onmouseout="this.style.background='rgba(240,62,62,0.1)';this.style.color='#f03e3e'">
                  <i class="bi bi-x-lg me-1"></i>Recusar
                </button>
                {{/if}}
              </form>

            </div>
            {{/unless}}
            {{/unless}}
            {{/unless}}

          </div>
        {{/each}}
      </div>

    {{else}}
      <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:50px;text-align:center;">
        <i class="bi bi-people" style="font-size:3rem;color:#444;"></i>
        <p class="mt-3" style="color:#888;">Nenhum candidato ainda.</p>
      </div>
    {{/if}}

  </div>
</div>

<!-- Modal de comparação -->
<div id="compare-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:10001;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto;">
  <div style="background:#141414;border:1px solid #2a2a2a;border-radius:20px;width:100%;max-width:900px;margin-top:60px;">
    <div style="padding:20px 24px;border-bottom:1px solid #2a2a2a;display:flex;justify-content:space-between;align-items:center;">
      <p style="font-weight:700;margin:0;color:#06b6d4;"><i class="bi bi-scale me-2"></i>Comparação de Candidatos</p>
      <button onclick="fecharComparacao()" style="background:transparent;border:none;color:#666;font-size:1.4rem;cursor:pointer;">×</button>
    </div>
    <div id="compare-loading" style="padding:60px;text-align:center;"><p style="color:#888;"><i class="bi bi-hourglass-split me-2"></i>Analisando candidatos...</p></div>
    <div id="compare-content" style="display:none;padding:24px;"></div>
  </div>
</div>

<style>
.candidate-check:checked + .custom-check {
  background: #06b6d4;
  border-color: #06b6d4;
}
.candidate-check:checked + .custom-check::after {
  content: '';
  display: block;
  width: 5px;
  height: 9px;
  border: 2px solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg) translateY(-1px);
}
label:hover .custom-check {
  border-color: #06b6d4;
}
</style>

<script>
const APPLICATIONS_CSRF = '{{csrfToken}}';
const APPLICATIONS_JOB_ID = '{{job.id}}';

function dismissStatusTip() {
    document.getElementById('status-tip').style.display = 'none';
    sessionStorage.setItem('status-tip-dismissed', '1');
}
if (sessionStorage.getItem('status-tip-dismissed')) {
    const tip = document.getElementById('status-tip');
    if (tip) tip.style.display = 'none';
}

const _similarCache = {};
async function toggleSimilares(applicationId, btn) {
    const container = document.getElementById('similar-' + applicationId);
    if (!container) return;
    if (container.style.display !== 'none') {
        container.style.display = 'none';
        btn.innerHTML = '<i class="bi bi-people-fill"></i>Candidatos Similares';
        return;
    }
    if (_similarCache[applicationId]) {
        container.innerHTML = _similarCache[applicationId];
        container.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-x-lg"></i>Ocultar';
        return;
    }
    btn.innerHTML = '<i class="bi bi-hourglass-split"></i>Carregando...';
    try {
        const res  = await fetch('/jobs/similar-candidates/' + applicationId);
        const data = await res.json();
        if (!data.similar || !data.similar.length) {
            _similarCache[applicationId] = '<p style="color:#666;font-size:0.8rem;margin:6px 0;">Nenhum candidato com perfil similar encontrado fora desta vaga no momento.</p>';
        } else {
            _similarCache[applicationId] = `
                <div style="background:#141414;border:1px solid rgba(168,85,247,0.25);border-radius:12px;overflow:hidden;">
                  <div style="padding:12px 16px;border-bottom:1px solid rgba(168,85,247,0.15);display:flex;align-items:center;gap:8px;">
                    <i class="bi bi-stars" style="color:#a855f7;font-size:0.9rem;"></i>
                    <span style="font-size:0.78rem;font-weight:700;color:#a855f7;text-transform:uppercase;letter-spacing:1px;">Perfis similares encontrados</span>
                    <span style="margin-left:auto;background:rgba(168,85,247,0.15);border:1px solid rgba(168,85,247,0.3);color:#a855f7;border-radius:20px;padding:1px 9px;font-size:0.72rem;font-weight:700;">${data.similar.length}</span>
                  </div>
                  <div style="padding:8px 0;">
                  ${data.similar.map((s, i) => {
                    const color = s.fitScore >= 70 ? '#4caf50' : s.fitScore >= 40 ? '#ffc107' : '#f03e3e';
                    const initial = s.candidate.name ? s.candidate.name.charAt(0).toUpperCase() : '?';
                    return `
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;${i < data.similar.length - 1 ? 'border-bottom:1px solid #1e1e1e;' : ''}flex-wrap:wrap;gap:10px;transition:background 0.15s;" onmouseover="this.style.background='#1a1a1a'" onmouseout="this.style.background='transparent'">
                      <div style="display:flex;align-items:center;gap:12px;">
                        <div style="width:42px;height:42px;border-radius:50%;background:rgba(168,85,247,0.15);border:2px solid rgba(168,85,247,0.4);color:#a855f7;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;">${initial}</div>
                        <div>
                          <div style="font-weight:700;font-size:0.9rem;margin-bottom:2px;">${s.candidate.name || '—'}</div>
                          ${s.candidate.city ? `<div style="color:#666;font-size:0.75rem;margin-bottom:5px;"><i class="bi bi-geo-alt" style="font-size:0.7rem;"></i> ${s.candidate.city}</div>` : ''}
                          <div style="display:flex;flex-wrap:wrap;gap:4px;">
                            ${s.commonSkills.map(sk => `<span style="background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.3);color:#a855f7;border-radius:20px;padding:2px 8px;font-size:0.7rem;">${sk}</span>`).join('')}
                          </div>
                        </div>
                      </div>
                      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        <div style="text-align:center;min-width:54px;">
                          <div style="font-size:1.4rem;font-weight:800;color:${color};line-height:1;">${s.fitScore}%</div>
                          <div style="color:#555;font-size:0.65rem;text-transform:uppercase;letter-spacing:.5px;">fit vaga</div>
                        </div>
                        <div style="text-align:center;min-width:54px;">
                          <div style="font-size:1.4rem;font-weight:800;color:${s.similarity >= 60 ? '#4caf50' : s.similarity >= 30 ? '#ffc107' : '#888'};line-height:1;">${s.similarity}%</div>
                          <div style="color:#555;font-size:0.65rem;text-transform:uppercase;letter-spacing:.5px;">similaridade</div>
                        </div>
                        <a href="/profile/c/${s.candidate.name ? s.candidate.name.replace(/\s+/g,'-') : ''}?fromJob=${APPLICATIONS_JOB_ID}" target="_blank"
                          style="background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.3);color:#a855f7;border-radius:8px;padding:7px 14px;font-size:0.8rem;font-weight:600;white-space:nowrap;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all 0.2s;"
                          onmouseover="this.style.background='rgba(168,85,247,0.22)';this.style.borderColor='#a855f7'" onmouseout="this.style.background='rgba(168,85,247,0.1)';this.style.borderColor='rgba(168,85,247,0.3)'">
                          <i class="bi bi-person-lines-fill"></i>Ver Perfil
                        </a>
                      </div>
                    </div>`;
                  }).join('')}
                  </div>
                </div>`;
        }
        container.innerHTML = _similarCache[applicationId];
        container.style.display = 'block';
        btn.innerHTML = '<i class="bi bi-x-lg"></i>Ocultar';
    } catch (e) {
        btn.innerHTML = '<i class="bi bi-people-fill"></i>Candidatos Similares';
    }
}


function updateCompareBtn() {
    const checked = document.querySelectorAll('.candidate-check:checked');
    const btn  = document.getElementById('compare-btn');
    const hint = document.getElementById('compare-hint');
    const n = checked.length;
    document.getElementById('selected-count').textContent = n;
    btn.style.display  = n >= 2 && n <= 3 ? 'inline-block' : 'none';
    if (hint) hint.style.display = n === 0 ? 'block' : 'none';
}

async function rankCandidates() {
    const btn = document.getElementById('rank-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Analisando...';
    btn.style.opacity = '0.6';

    try {
        const res = await fetch('/jobs/ai/rank/' + APPLICATIONS_JOB_ID, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': APPLICATIONS_CSRF }
        });
        const data = await res.json();
        if (data.error) { alert(data.error); return; }

        data.rankings.forEach(r => {
            const card = document.querySelector('.applicant-card[data-id="' + r.applicationId + '"]');
            if (!card) return;
            const color = r.score >= 70 ? '#4caf50' : r.score >= 40 ? '#ffc107' : '#f03e3e';
            const scoreEl = card.querySelector('.score-value');
            scoreEl.textContent = r.score + '%';
            scoreEl.style.color = color;
            card.querySelector('.ia-score').style.display = 'block';
            card.querySelector('.analysis-text').textContent = r.analysis;
            card.querySelector('.ia-analysis').style.display = 'block';
            card.style.borderColor = color;
        });

        const list = document.getElementById('applicants-list');
        const cards = Array.from(list.querySelectorAll('.applicant-card'));
        const rankMap = {};
        data.rankings.forEach((r, i) => { rankMap[r.applicationId] = { score: r.score, pos: i + 1 }; });
        cards.sort((a, b) => (rankMap[b.dataset.id]?.score ?? -1) - (rankMap[a.dataset.id]?.score ?? -1));
        cards.forEach((card, i) => {
            const badge = card.querySelector('.rank-badge');
            badge.textContent = '#' + (i + 1);
            badge.style.display = 'flex';
        });
        list.innerHTML = '';
        cards.forEach(c => list.appendChild(c));

        btn.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Ranking concluído';
        btn.style.borderColor = '#4caf50';
        btn.style.color = '#4caf50';
    } catch (err) {
        alert('Erro ao conectar com a IA.');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-robot me-1"></i>Rankear com IA';
        btn.style.opacity = '1';
    }
}

async function compararSelecionados() {
    const ids = [...document.querySelectorAll('.candidate-check:checked')].map(el => el.dataset.id);
    if (ids.length < 2) return;

    document.getElementById('compare-modal').style.display = 'flex';
    document.getElementById('compare-loading').style.display = 'block';
    document.getElementById('compare-content').style.display = 'none';

    try {
        const res = await fetch('/jobs/compare-candidates', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': APPLICATIONS_CSRF },
            body: JSON.stringify({ applicationIds: ids, jobId: APPLICATIONS_JOB_ID })
        });
        const data = await res.json();
        document.getElementById('compare-loading').style.display = 'none';
        document.getElementById('compare-content').style.display = 'block';
        document.getElementById('compare-content').innerHTML = renderComparacao(data);
    } catch(e) {
        document.getElementById('compare-loading').innerHTML = '<p style="color:#f03e3e;">Erro ao comparar. Tente novamente.</p>';
    }
}

function renderComparacao(data) {
    if (data.error) return `<p style="color:#f03e3e;padding:12px;">${data.error}</p>`;
    const candidates = data.candidates || [];

    const cols = candidates.map(c => {
        const scoreColor = c.score >= 70 ? '#4caf50' : c.score >= 40 ? '#f59e0b' : '#f03e3e';
        const borderColor = c.recomendado ? '#4caf50' : '#2a2a2a';
        const initial = c.nome ? c.nome.charAt(0).toUpperCase() : '?';
        const barWidth = Math.max(4, Math.min(100, c.score || 0));

        return `
        <div style="flex:1;min-width:220px;background:#1a1a1a;border:1px solid ${borderColor};border-radius:14px;overflow:hidden;display:flex;flex-direction:column;">

          <!-- Cabeçalho do candidato -->
          <div style="padding:18px 18px 14px;border-bottom:1px solid #242424;${c.recomendado ? 'background:rgba(76,175,80,0.04);' : ''}">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
              <div style="width:44px;height:44px;border-radius:50%;background:#242424;border:2px solid ${borderColor};display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:700;font-size:1.1rem;color:${c.recomendado ? '#4caf50' : '#aaa'};">${initial}</div>
              <div style="min-width:0;">
                <div style="font-weight:700;font-size:0.95rem;color:#eee;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.nome}</div>
                ${c.recomendado ? '<div style="font-size:0.72rem;color:#4caf50;margin-top:2px;"><i class="bi bi-star-fill" style="font-size:0.65rem;"></i> Mais recomendado</div>' : ''}
              </div>
            </div>

            <!-- Score + barra -->
            <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:6px;">
              <span style="font-size:2rem;font-weight:800;color:${scoreColor};line-height:1;">${c.score}</span>
              <span style="font-size:1rem;font-weight:600;color:${scoreColor};">%</span>
              <span style="font-size:0.72rem;color:#555;margin-left:2px;">compatibilidade</span>
            </div>
            <div style="height:5px;background:#2a2a2a;border-radius:99px;overflow:hidden;">
              <div style="height:100%;width:${barWidth}%;background:${scoreColor};border-radius:99px;transition:width 0.6s ease;"></div>
            </div>
          </div>

          <!-- Análise -->
          <div style="padding:14px 18px;border-bottom:1px solid #242424;">
            <div style="font-size:0.68rem;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;"><i class="bi bi-chat-square-text me-1"></i>Análise</div>
            <div style="font-size:0.82rem;color:#aaa;line-height:1.65;">${c.analise || '—'}</div>
          </div>

          <!-- Pontos fortes -->
          ${(c.pontos_fortes||[]).length ? `
          <div style="padding:12px 18px;border-bottom:1px solid #242424;">
            <div style="font-size:0.68rem;font-weight:700;color:#4caf50;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;"><i class="bi bi-check-circle me-1"></i>Pontos fortes</div>
            <div style="display:flex;flex-direction:column;gap:4px;">
              ${(c.pontos_fortes).map(p => `<span style="display:flex;align-items:center;gap:6px;font-size:0.8rem;color:#ccc;"><span style="color:#4caf50;font-size:0.75rem;">✓</span>${p}</span>`).join('')}
            </div>
          </div>` : ''}

          <!-- Lacunas -->
          ${(c.lacunas||[]).length ? `
          <div style="padding:12px 18px;">
            <div style="font-size:0.68rem;font-weight:700;color:#f03e3e;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:8px;"><i class="bi bi-exclamation-circle me-1"></i>Lacunas</div>
            <div style="display:flex;flex-direction:column;gap:4px;">
              ${(c.lacunas).map(l => `<span style="display:flex;align-items:center;gap:6px;font-size:0.8rem;color:#ccc;"><span style="color:#f03e3e;font-size:0.75rem;">✗</span>${l}</span>`).join('')}
            </div>
          </div>` : ''}

        </div>`;
    }).join('');

    const conclusaoHtml = data.conclusao ? `
        <div style="margin-top:20px;background:#141414;border:1px solid #1e3a4a;border-radius:12px;overflow:hidden;">
          <div style="padding:10px 18px;background:rgba(6,182,212,0.06);border-bottom:1px solid #1e3a4a;display:flex;align-items:center;gap:8px;">
            <i class="bi bi-robot" style="color:#06b6d4;font-size:0.9rem;"></i>
            <span style="font-size:0.72rem;font-weight:700;color:#06b6d4;text-transform:uppercase;letter-spacing:0.8px;">Recomendação Final da IA</span>
          </div>
          <div style="padding:14px 18px;font-size:0.85rem;color:#bbb;line-height:1.7;">${data.conclusao}</div>
        </div>` : '';

    return `
        <div style="display:flex;gap:14px;flex-wrap:wrap;align-items:flex-start;">${cols}</div>
        ${conclusaoHtml}
        <div style="display:flex;justify-content:flex-end;margin-top:18px;">
          <button onclick="fecharComparacao()" style="background:transparent;border:1px solid #333;color:#888;border-radius:8px;padding:8px 18px;cursor:pointer;font-size:0.85rem;transition:all 0.2s;" onmouseover="this.style.borderColor='#555';this.style.color='#ccc'" onmouseout="this.style.borderColor='#333';this.style.color='#888'">Fechar</button>
        </div>`;
}

function fecharComparacao() {
    document.getElementById('compare-modal').style.display = 'none';
}

// ── Candidatos Similares Sugeridos ────────────────────────────────────────────
(async function loadSuggested() {
    const jobId = {{job.id}};
    try {
        const res  = await fetch(`/jobs/suggested-candidates/${jobId}`);
        const data = await res.json();
        if (!data.suggested || !data.suggested.length) return;

        const alertEl = document.getElementById('suggested-alert');
        const listEl  = document.getElementById('suggested-list');
        const titleEl = document.getElementById('suggested-title');

        titleEl.textContent = `Candidatos Similares — ${data.suggested.length} perfil(is) compatível(is) encontrado(s)`;

        listEl.innerHTML = data.suggested.map(s => `
            <div id="suggested-card-${s.candidate.id}" style="background:#141414;border:1px solid #1e3a4a;border-radius:10px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    ${s.candidate.avatar
                        ? `<img src="${s.candidate.avatar}" style="width:38px;height:38px;border-radius:50%;object-fit:cover;border:2px solid #06b6d4;">`
                        : `<div style="width:38px;height:38px;border-radius:50%;background:#06b6d4;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;">${s.candidate.name ? s.candidate.name.charAt(0).toUpperCase() : '?'}</div>`
                    }
                    <div>
                        <div style="font-weight:700;font-size:0.9rem;">${s.candidate.name}</div>
                        ${s.candidate.city ? `<div style="color:#888;font-size:0.78rem;"><i class="bi bi-geo-alt me-1"></i>${s.candidate.city}</div>` : ''}
                        ${s.commonSkills.length ? `<div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px;">${s.commonSkills.map(sk => `<span style="background:#0e2a36;border:1px solid #06b6d433;color:#06b6d4;border-radius:20px;padding:1px 7px;font-size:0.68rem;">${sk}</span>`).join('')}</div>` : ''}
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <div style="text-align:right;">
                        <div style="font-size:1.1rem;font-weight:700;color:${s.combinedScore>=70?'#4caf50':s.combinedScore>=40?'#ffc107':'#06b6d4'};">${s.combinedScore}%</div>
                        <div style="color:#888;font-size:0.68rem;">fit combinado</div>
                    </div>
                    <a href="/profile/c/${s.candidate.name.replace(/\s+/g,'-')}?fromJob=${jobId}" target="_blank"
                        style="background:transparent;border:1px solid #2a2a2a;color:#aaa;border-radius:8px;padding:7px 12px;font-size:0.82rem;font-weight:600;white-space:nowrap;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                        <i class="bi bi-person-lines-fill"></i>Ver Perfil
                    </a>
                    <button onclick="convidarSugerido(${s.candidate.id}, ${jobId}, this)"
                        style="background:#06b6d4;border:none;color:white;border-radius:8px;padding:7px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;transition:opacity 0.2s;">
                        <i class="bi bi-envelope me-1"></i>Convidar
                    </button>
                </div>
            </div>
        `).join('');

        alertEl.style.display = 'block';
    } catch (e) {}
})();

async function convidarSugerido(candidateId, jobId, btn) {
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Enviando...';
    btn.style.opacity = '0.6';
    try {
        const res  = await fetch(`/jobs/contact-suggested/${jobId}/${candidateId}`, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': APPLICATIONS_CSRF }
        });
        const data = await res.json();
        if (data.ok) {
            btn.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Convite enviado';
            btn.style.background = '#4caf50';
            btn.style.opacity    = '1';
        } else {
            btn.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>' + (data.error || 'Erro');
            btn.style.background = '#f03e3e';
            btn.style.opacity    = '1';
            btn.disabled         = false;
        }
    } catch (e) {
        btn.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>Erro';
        btn.style.background = '#f03e3e';
        btn.style.opacity    = '1';
        btn.disabled         = false;
    }
}

// ── Redescoberta de Talentos ───────────────────────────────────────────────────
(async function loadRediscovery() {
    const jobId = {{job.id}};
    try {
        const res  = await fetch(`/jobs/talents/${jobId}`);
        const data = await res.json();
        if (!data.talents || data.talents.length === 0) return;

        const alert = document.getElementById('rediscovery-alert');
        const list  = document.getElementById('rediscovery-list');
        const title = document.getElementById('rediscovery-title');

        title.textContent = `Redescoberta de Talentos: ${data.talents.length} candidato(s) da sua base têm alto fit para esta vaga.`;

        list.innerHTML = data.talents.map(t => `
            <div style="background:#141414;border:1px solid #2a2a2a;border-radius:10px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    ${t.candidate.avatar
                        ? `<img src="${t.candidate.avatar}" style="width:38px;height:38px;border-radius:50%;object-fit:cover;border:2px solid #a855f7;">`
                        : `<div style="width:38px;height:38px;border-radius:50%;background:#a855f7;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;">${t.candidate.name.charAt(0).toUpperCase()}</div>`
                    }
                    <div>
                        <div style="font-weight:700;font-size:0.9rem;">${t.candidate.name}</div>
                        <div style="color:#888;font-size:0.78rem;">
                            Candidatou há ${_mesesAtras(t.lastApplicationDate)} mês(es)
                        </div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <span style="background:rgba(168,85,247,0.15);border:1px solid #a855f7;color:#a855f7;border-radius:20px;padding:4px 12px;font-size:0.78rem;font-weight:700;">
                        ${t.fitScore}% fit
                    </span>
                    <form method="POST" action="/jobs/reactivate-contact/${jobId}/${t.candidate.id}" style="margin:0;">
                        <input type="hidden" name="_csrf" value="{{csrfToken}}">
                        <button type="submit"
                            style="background:#a855f7;border:none;color:white;border-radius:8px;padding:7px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;">
                            <i class="bi bi-arrow-repeat me-1"></i> Reativar contato
                        </button>
                    </form>
                </div>
            </div>
        `).join('');

        alert.style.display = 'block';
    } catch (e) {}

    function _mesesAtras(dateStr) {
        const now  = new Date();
        const past = new Date(dateStr);
        return Math.max(1, (now.getFullYear() - past.getFullYear()) * 12 + now.getMonth() - past.getMonth());
    }
})();
</script>
