<div style="padding-top: 100px; padding-bottom: 60px;">
  <div class="container" style="max-width: 800px;">

    <!-- CABEÇALHO DA PÁGINA -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
      <h2 style="color:#f03e3e;font-weight:700;margin:0;">
        <i class="bi bi-file-earmark-text me-2"></i>Meu Currículo
      </h2>
      <div class="d-flex gap-2 align-items-center flex-wrap">
        <a href="/resume/create"
          style="background:transparent;border:1px solid #f03e3e;color:#f03e3e;border-radius:8px;padding:8px 16px;text-decoration:none;font-size:0.9rem;">
          <i class="bi bi-pencil me-1"></i> Editar
        </a>
        <button onclick="document.getElementById('templateModal').style.display='flex'"
          style="background:#2a2a2a;border:1px solid #3a3a3a;color:#e0e0e0;border-radius:8px;padding:8px 16px;cursor:pointer;font-size:0.9rem;">
          <i class="bi bi-palette me-1"></i> Template: <span id="selectedTemplateName">Refinado</span>
        </button>
        <button onclick="exportPDF()"
          style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:8px 16px;cursor:pointer;font-size:0.9rem;font-weight:600;">
          <i class="bi bi-file-pdf me-1"></i> Exportar PDF
        </button>
        <a href="/profile"
          style="color:#aaa;text-decoration:none;font-size:0.9rem;display:flex;align-items:center;">
          <i class="bi bi-arrow-left me-1"></i> Perfil
        </a>
      </div>
    </div>

    <!-- PREVIEW NA TELA -->
    <div id="resumeContent">
      <div class="resume-card">
        <div class="d-flex align-items-center gap-4">
          <div style="width:80px;height:80px;border-radius:50%;border:3px solid #f03e3e;background:#2a2a2a;display:flex;align-items:center;justify-content:center;font-size:2rem;color:#f03e3e;flex-shrink:0;">
            <i class="bi bi-person-fill"></i>
          </div>
          <div style="flex:1;">
            <h1 style="font-size:1.6rem;font-weight:700;margin-bottom:6px;">{{user.name}}</h1>
            <p style="color:#aaa;margin-bottom:6px;font-size:0.9rem;display:flex;flex-wrap:wrap;gap:16px;">
              {{#if user.city}}<span><i class="bi bi-geo-alt me-1"></i>{{user.city}}</span>{{/if}}
              {{#if user.birthDate}}<span><i class="bi bi-calendar3 me-1"></i>{{user.birthDate}}</span>{{/if}}
              {{#if user.address}}<span><i class="bi bi-house me-1"></i>{{user.address}}</span>{{/if}}
            </p>
            <p style="color:#aaa;font-size:0.85rem;margin:0;display:flex;flex-wrap:wrap;gap:12px;align-items:center;">
              <span><i class="bi bi-envelope me-1"></i>{{user.email}}</span>
              {{#if user.phone}}<span>•</span><span>{{user.phone}}</span>{{/if}}
              {{#if user.linkedin}}<span>•</span><a href="{{user.linkedin}}" style="color:#f03e3e;" target="_blank">LinkedIn</a>{{/if}}
              {{#if user.github}}<span>•</span><a href="{{user.github}}" style="color:#f03e3e;" target="_blank">GitHub</a>{{/if}}
            </p>
          </div>
        </div>
      </div>
      {{#if resume.summary}}
      <div class="resume-card">
        <h5><i class="bi bi-person-lines-fill me-2"></i>Resumo Profissional</h5>
        <p style="color:#ccc;line-height:1.7;margin:0;">{{resume.summary}}</p>
      </div>
      {{/if}}
      {{#if resume.experiences}}
      <div class="resume-card">
        <h5><i class="bi bi-briefcase me-2"></i>Experiências</h5>
        {{#each resume.experiences}}
          <div style="border-left:3px solid #f03e3e;padding-left:16px;margin-bottom:20px;">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
              <div>
                <p style="font-weight:700;font-size:1rem;margin-bottom:2px;">{{this.role}}</p>
                <p style="color:#f03e3e;font-size:0.9rem;margin-bottom:4px;">{{this.company}}</p>
              </div>
              {{#if this.period}}<span style="background:#2a2a2a;border:1px solid #333;color:#aaa;border-radius:20px;padding:3px 10px;font-size:0.8rem;">{{this.period}}</span>{{/if}}
            </div>
            {{#if this.description}}<p style="color:#ccc;font-size:0.9rem;margin:8px 0 0;line-height:1.6;">{{this.description}}</p>{{/if}}
          </div>
        {{/each}}
      </div>
      {{/if}}
      {{#if resume.education}}
      <div class="resume-card">
        <h5><i class="bi bi-mortarboard me-2"></i>Formação Acadêmica</h5>
        {{#each resume.education}}
          <div style="border-left:3px solid #f03e3e;padding-left:16px;margin-bottom:20px;">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
              <div>
                <p style="font-weight:700;font-size:1rem;margin-bottom:2px;">{{this.course}}</p>
                <p style="color:#f03e3e;font-size:0.9rem;margin-bottom:0;">{{this.institution}}</p>
              </div>
              {{#if this.period}}<span style="background:#2a2a2a;border:1px solid #333;color:#aaa;border-radius:20px;padding:3px 10px;font-size:0.8rem;">{{this.period}}</span>{{/if}}
            </div>
          </div>
        {{/each}}
      </div>
      {{/if}}
      {{#if resume.skills}}
      <div class="resume-card">
        <h5><i class="bi bi-lightning me-2"></i>Habilidades</h5>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          {{#each resume.skills}}
            <span style="background:#2a2a2a;border:1px solid #f03e3e;color:#f03e3e;border-radius:20px;padding:5px 14px;font-size:0.85rem;">{{this}}</span>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </div>
  </div>
</div>

