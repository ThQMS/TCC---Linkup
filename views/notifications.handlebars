<style>
.notif-card{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:14px;padding:18px 20px;margin-bottom:10px;display:flex;align-items:flex-start;justify-content:space-between;gap:14px;flex-wrap:wrap;transition:border-color 0.2s,box-shadow 0.2s;border-left-width:3px;border-left-style:solid;}
.notif-card:hover{box-shadow:0 4px 20px rgba(0,0,0,0.3);}
.notif-card.t-success{border-left-color:#4caf50;}
.notif-card.t-danger {border-left-color:#f03e3e;}
.notif-card.t-info   {border-left-color:#06b6d4;}
.notif-card.t-default{border-left-color:#ffc107;}
.notif-card.unread{background:#1e1e1e;}
.notif-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.notif-icon.t-success{background:rgba(76,175,80,0.1);border:1px solid rgba(76,175,80,0.2);color:#4caf50;}
.notif-icon.t-danger {background:rgba(240,62,62,0.1);border:1px solid rgba(240,62,62,0.2);color:#f03e3e;}
.notif-icon.t-info   {background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.2);color:#06b6d4;}
.notif-icon.t-default{background:rgba(255,193,7,0.08);border:1px solid rgba(255,193,7,0.2);color:#ffc107;}
.notif-link{display:inline-flex;align-items:center;gap:5px;background:#e63946;color:white;border-radius:8px;padding:5px 12px;text-decoration:none;font-size:0.78rem;font-weight:600;white-space:nowrap;transition:background 0.2s;}
.notif-link:hover{background:#c62828;color:white;}
.notif-del{background:transparent;border:1px solid #2a2a2a;color:#555;border-radius:8px;padding:5px 10px;cursor:pointer;font-size:0.82rem;transition:all 0.2s;}
.notif-del:hover{border-color:#f03e3e;color:#f03e3e;}
.notif-clear{display:inline-flex;align-items:center;gap:6px;background:transparent;border:1px solid #2a2a2a;color:#666;border-radius:8px;padding:7px 14px;cursor:pointer;font-size:0.82rem;font-weight:500;transition:all 0.2s;}
.notif-clear:hover{border-color:#f03e3e;color:#f03e3e;}
.notif-back{display:inline-flex;align-items:center;gap:6px;color:#888;text-decoration:none;font-size:0.87rem;border:1px solid #2a2a2a;border-radius:8px;padding:7px 14px;transition:all 0.2s;}
.notif-back:hover{border-color:#f03e3e;color:#f03e3e;}
@media(max-width:576px){
  .notif-card{padding:14px 16px;gap:10px;}
  .notif-card>div:last-child{width:100%;justify-content:flex-end;}
  .notif-icon{width:34px;height:34px;font-size:0.95rem;}
}
</style>

<div style="padding-top:90px;padding-bottom:72px;">
  <div class="container" style="max-width:760px;">

    <!-- HEADER -->
    <div class="d-flex align-items-start justify-content-between mb-5 flex-wrap gap-3">
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
          <h2 style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.75rem;letter-spacing:-0.5px;margin:0;">Notificações</h2>
          {{#if unreadCount}}
          <span style="background:rgba(230,57,70,0.1);border:1px solid rgba(230,57,70,0.25);color:#e63946;border-radius:20px;padding:2px 10px;font-size:0.8rem;font-weight:700;">{{unreadCount}} nova{{#if (gt unreadCount 1)}}s{{/if}}</span>
          {{/if}}
        </div>
        <p style="color:#666;margin:0;font-size:0.88rem;">Todas as notificações são marcadas como lidas ao abrir esta página.</p>
      </div>
      <div class="d-flex gap-2 align-items-center flex-wrap">
        {{#if notifications.length}}
        <form action="/notifications/clear-all" method="POST" style="margin:0;">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <button type="submit" class="notif-clear" onclick="return confirm('Limpar todas as notificações?')">
            <i class="bi bi-trash3"></i>Limpar tudo
          </button>
        </form>
        {{/if}}
        <a href="/" class="notif-back"><i class="bi bi-arrow-left"></i>Ver Vagas</a>
      </div>
    </div>

    {{#if notifications.length}}
      {{#each notifications}}
        <div class="notif-card
          {{#if (eq this.type 'success')}}t-success
          {{else if (eq this.type 'danger')}}t-danger
          {{else if (eq this.type 'info')}}t-info
          {{else}}t-default{{/if}}
          {{#unless this.read}} unread{{/unless}}">

          <div class="d-flex align-items-start gap-3" style="flex:1;min-width:0;">
            <div class="notif-icon
              {{#if (eq this.type 'success')}}t-success
              {{else if (eq this.type 'danger')}}t-danger
              {{else if (eq this.type 'info')}}t-info
              {{else}}t-default{{/if}}">
              {{#if (eq this.type 'success')}}<i class="bi bi-check-circle-fill"></i>
              {{else if (eq this.type 'danger')}}<i class="bi bi-x-circle-fill"></i>
              {{else if (eq this.type 'info')}}<i class="bi bi-info-circle-fill"></i>
              {{else}}<i class="bi bi-bell-fill"></i>{{/if}}
            </div>
            <div style="min-width:0;">
              <p style="margin:0 0 4px;font-size:0.92rem;color:#e0e0e0;line-height:1.5;{{#unless this.read}}font-weight:600;{{/unless}}">
                {{this.message}}
              </p>
              <span style="color:#555;font-size:0.75rem;">{{formatDate this.createdAt}}</span>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2 flex-shrink-0">
            {{#if this.link}}
              <a href="{{this.link}}" class="notif-link">Ver <i class="bi bi-arrow-right"></i></a>
            {{/if}}
            <form action="/notifications/delete/{{this.id}}" method="POST" style="margin:0;">
              <input type="hidden" name="_csrf" value="{{../csrfToken}}">
              <button type="submit" class="notif-del" title="Remover"><i class="bi bi-trash3"></i></button>
            </form>
          </div>

        </div>
      {{/each}}

    {{else}}
      <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:20px;padding:80px 40px;text-align:center;">
        <div style="width:72px;height:72px;border-radius:50%;background:rgba(230,57,70,0.06);border:1px solid rgba(230,57,70,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
          <i class="bi bi-bell-slash" style="font-size:1.8rem;color:#e63946;"></i>
        </div>
        <h5 style="font-weight:700;margin-bottom:8px;">Tudo em dia!</h5>
        <p style="color:#555;font-size:0.88rem;max-width:320px;margin:0 auto 24px;line-height:1.7;">
          Nenhuma notificação por enquanto. Candidate-se a vagas para receber atualizações aqui.
        </p>
        <a href="/" style="background:#e63946;color:white;border-radius:8px;padding:10px 28px;text-decoration:none;font-weight:600;font-size:0.9rem;display:inline-flex;align-items:center;gap:8px;">
          <i class="bi bi-search"></i>Explorar Vagas
        </a>
      </div>
    {{/if}}

  </div>
</div>
