<div id="job-data" data-job-id="{{job.id}}" data-csrf="{{csrfToken}}" style="display:none;"></div>
<div style="padding-top: 80px; padding-bottom: 60px;">
  <div class="container" style="max-width: 1060px;">

    <a href="/" style="color:#f03e3e;text-decoration:none;font-size:0.9rem;display:inline-flex;align-items:center;gap:6px;margin-bottom:24px;">
      <i class="bi bi-arrow-left"></i> Voltar para vagas
    </a>

    <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:16px;overflow:hidden;">

      <!-- HEADER -->
      <div style="background:linear-gradient(135deg,#1a1a1a,#2c2c2c);padding:32px 36px;border-bottom:1px solid #2a2a2a;">
        <div class="d-flex align-items-center gap-4 flex-wrap">
          <div style="width:72px;height:72px;border-radius:14px;border:2px solid #f03e3e;background:#2a2a2a;display:flex;align-items:center;justify-content:center;font-size:1.8rem;color:#f03e3e;flex-shrink:0;">
            <i class="bi bi-building"></i>
          </div>
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
              <h1 style="font-size:1.6rem;font-weight:700;margin:0;line-height:1.45;">{{job.title}}</h1>
              {{#if (isNew job.createdAt)}}<span style="background:#f03e3e;color:white;font-size:0.7rem;padding:3px 10px;border-radius:20px;font-weight:700;">NOVA</span>{{/if}}
              {{#if (eq job.status 'pausada')}}<span style="background:#3a2e00;color:#ffc107;border:1px solid #ffc107;font-size:0.7rem;padding:3px 10px;border-radius:20px;font-weight:700;">⏸️ PAUSADA</span>{{/if}}
              {{#if (eq job.status 'encerrada')}}<span style="background:#3a1a1a;color:#f03e3e;border:1px solid #f03e3e;font-size:0.7rem;padding:3px 10px;border-radius:20px;font-weight:700;">🔒 ENCERRADA</span>{{/if}}
            </div>
            <p style="color:#f03e3e;font-weight:600;font-size:0.95rem;margin-bottom:8px;">{{job.company}}</p>
            <div class="d-flex gap-2 flex-wrap">
              {{#if job.modality}}<span style="background:#2a2a2a;border:1px solid #3a3a3a;color:#aaa;border-radius:20px;padding:3px 12px;font-size:0.78rem;">{{formatModality job.modality}}</span>{{/if}}
              {{#if job.contractType}}<span style="background:#2a2a2a;border:1px solid #3a3a3a;color:#aaa;border-radius:20px;padding:3px 12px;font-size:0.78rem;">{{formatContractType job.contractType}}</span>{{/if}}
              {{#if job.isPcd}}<span style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.35);color:#4ade80;border-radius:20px;padding:3px 12px;font-size:0.78rem;font-weight:700;"><i class="bi bi-person-wheelchair me-1"></i>PCD</span>{{/if}}
              {{#if job.salary}}<span style="background:#2a2a2a;border:1px solid #3a3a3a;color:#aaa;border-radius:20px;padding:3px 12px;font-size:0.78rem;">💰 R$ {{job.salary}}</span>{{/if}}
              {{#if (isOwner user.id job.UserId)}}<span style="background:#2a2a2a;border:1px solid #3a3a3a;color:#666;border-radius:20px;padding:3px 12px;font-size:0.78rem;">👁 {{job.views}} views</span>{{/if}}
            </div>
          </div>
        </div>
      </div>

      <!-- CORPO -->
      <div style="padding:32px 36px;">
        <div class="row g-4">

          <!-- COLUNA PRINCIPAL -->
          <div class="col-md-7">
            <div style="margin-bottom:24px;">
              <h5 style="color:#f03e3e;font-weight:700;font-size:0.95rem;margin-bottom:10px;display:flex;align-items:center;gap:8px;"><i class="bi bi-file-text"></i> Descrição</h5>
              <p style="color:#ccc;line-height:1.8;white-space:pre-line;font-size:0.92rem;">{{job.description}}</p>
            </div>
            {{#if job.requirements}}
            <div style="margin-bottom:24px;">
              <h5 style="color:#f03e3e;font-weight:700;font-size:0.95rem;margin-bottom:10px;display:flex;align-items:center;gap:8px;"><i class="bi bi-check2-square"></i> Requisitos</h5>
              <p style="color:#ccc;line-height:1.8;white-space:pre-line;font-size:0.92rem;">{{job.requirements}}</p>
            </div>
            {{/if}}
            {{#if job.benefits}}
            <div style="margin-bottom:24px;">
              <h5 style="color:#f03e3e;font-weight:700;font-size:0.95rem;margin-bottom:10px;display:flex;align-items:center;gap:8px;"><i class="bi bi-gift"></i> Benefícios</h5>
              <p style="color:#ccc;line-height:1.8;white-space:pre-line;font-size:0.92rem;">{{job.benefits}}</p>
            </div>
            {{/if}}
            {{#if job.differential}}
            <div style="margin-bottom:24px;">
              <h5 style="color:#f03e3e;font-weight:700;font-size:0.95rem;margin-bottom:10px;display:flex;align-items:center;gap:8px;"><i class="bi bi-star"></i> Diferencial</h5>
              <p style="color:#ccc;line-height:1.8;white-space:pre-line;font-size:0.92rem;">{{job.differential}}</p>
            </div>
            {{/if}}
          </div>

          <!-- COLUNA LATERAL -->
          <div class="col-md-5">

            <!-- CARD: CANDIDATURA -->
            <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:14px;overflow:hidden;margin-bottom:12px;">
              <div style="padding:14px 18px;border-bottom:1px solid #2a2a2a;display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:0.8rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.05em;">Candidatura</span>
                <span style="background:#2a2a2a;color:#888;font-size:0.75rem;padding:3px 10px;border-radius:20px;"><i class="bi bi-people me-1"></i>{{#if applicantsCount}}{{applicantsCount}}{{else}}0{{/if}} candidato(s)</span>
              </div>
              <div style="padding:16px 18px;">
                {{#if isCandidate}}
                  {{#if (eq job.status 'encerrada')}}
                    <button disabled style="width:100%;background:#1e1e1e;border:1px solid #2a2a2a;color:#555;border-radius:10px;padding:11px;font-weight:600;cursor:not-allowed;font-size:0.88rem;">🔒 Vaga Encerrada</button>
                  {{else if (eq job.status 'pausada')}}
                    <button disabled style="width:100%;background:#1e1e1e;border:1px solid #2a2a2a;color:#555;border-radius:10px;padding:11px;font-weight:600;cursor:not-allowed;font-size:0.88rem;">⏸️ Candidaturas Pausadas</button>
                  {{else if alreadyApplied}}
                    <button disabled style="width:100%;background:#1a3a1a;border:1px solid #4caf50;color:#4caf50;border-radius:10px;padding:11px;font-weight:600;font-size:0.88rem;"><i class="bi bi-check-circle me-2"></i>Candidatura Enviada</button>
                  {{else if hasResume}}
                    <button onclick="abrirModalCarta()" style="width:100%;background:#f03e3e;border:none;color:white;border-radius:10px;padding:11px;font-weight:700;cursor:pointer;font-size:0.92rem;transition:background 0.2s;" onmouseover="this.style.background='#c0392b'" onmouseout="this.style.background='#f03e3e'">
                      <i class="bi bi-send me-2"></i>Me Candidatar
                    </button>
                    <p style="color:#666;font-size:0.75rem;text-align:center;margin:6px 0 0;">Carta de apresentação gerada por IA</p>
                  {{else}}
                    <button disabled style="width:100%;background:#1e1e1e;border:1px solid #2a2a2a;color:#555;border-radius:10px;padding:11px;font-weight:600;cursor:not-allowed;font-size:0.88rem;">
                      <i class="bi bi-send me-2"></i>Me Candidatar
                    </button>
                    <div style="margin-top:10px;background:rgba(230,57,70,0.07);border:1px solid rgba(230,57,70,0.2);border-radius:10px;padding:12px 14px;text-align:center;">
                      <p style="color:#e63946;font-size:0.82rem;margin:0 0 10px;font-weight:500;">
                        <i class="bi bi-exclamation-circle me-1"></i>Você ainda não tem currículo cadastrado.
                      </p>
                      <p style="color:#888;font-size:0.77rem;margin:0 0 12px;line-height:1.5;">
                        O currículo é obrigatório para se candidatar. Ele é enviado automaticamente a cada candidatura e usado pela IA para calcular sua compatibilidade.
                      </p>
                      <a href="/resume/create" style="display:inline-flex;align-items:center;gap:6px;background:#e63946;color:white;border-radius:8px;padding:8px 18px;text-decoration:none;font-size:0.85rem;font-weight:700;transition:background 0.2s;" onmouseover="this.style.background='#c62828'" onmouseout="this.style.background='#e63946'">
                        <i class="bi bi-file-earmark-person-fill"></i>Criar meu currículo
                      </a>
                    </div>
                  {{/if}}

                  {{#unless (eq job.status 'encerrada')}}
                  <div style="margin-top:10px;">
                    <form action="/jobs/favorite/{{job.id}}" method="POST">
                      <input type="hidden" name="_csrf" value="{{csrfToken}}">
                      <button type="submit" style="width:100%;background:transparent;border:1px solid {{#if isFavorited}}#f03e3e{{else}}#2a2a2a{{/if}};color:{{#if isFavorited}}#f03e3e{{else}}#666{{/if}};border-radius:10px;padding:8px;cursor:pointer;font-size:0.82rem;transition:all 0.2s;">
                        <i class="bi bi-{{#if isFavorited}}heart-fill{{else}}heart{{/if}} me-1"></i>{{#if isFavorited}}Salvo{{else}}Salvar Vaga{{/if}}
                      </button>
                    </form>
                  </div>
                  {{/unless}}

                {{else if user}}
                  {{#if (eq user.id job.UserId)}}
                    <p style="color:#666;font-size:0.82rem;text-align:center;margin:0;">Gerencie esta vaga pelos botões abaixo.</p>
                  {{/if}}
                {{else}}
                  <p style="color:#888;font-size:0.85rem;text-align:center;margin:0;"><a href="/login" style="color:#f03e3e;">Faça login</a> para se candidatar.</p>
                {{/if}}
              </div>
            </div>

            <!-- CARD: FERRAMENTAS DE IA — só para candidato em vaga aberta -->
            {{#if isCandidate}}
            {{#unless (eq job.status 'encerrada')}}
            <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:14px;overflow:hidden;margin-bottom:12px;">
              <div style="padding:14px 18px;border-bottom:1px solid #2a2a2a;">
                <span style="font-size:0.8rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.05em;"><i class="bi bi-robot me-1"></i>Ferramentas de IA</span>
              </div>
              <div style="padding:12px 14px;display:flex;flex-direction:column;gap:8px;">

               <!-- Compatibilidade -->
<button onclick="checkCompatibility()" style="width:100%;background:#1e1e1e;border:1px solid #a855f7;color:#a855f7;border-radius:10px;padding:10px 14px;cursor:pointer;font-weight:600;font-size:0.85rem;text-align:left;display:flex;align-items:center;gap:10px;transition:all 0.2s;" onmouseover="this.style.background='#a855f722'" onmouseout="this.style.background='#1e1e1e'">
  <span style="width:32px;height:32px;border-radius:8px;background:#a855f722;border:1px solid #a855f744;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
    <i class="bi bi-cpu" style="color:#a855f7;font-size:0.9rem;"></i>
  </span>
  <div>
    <div style="font-size:0.85rem;font-weight:600;">Ver compatibilidade</div>
    <div style="font-size:0.72rem;color:#888;font-weight:400;">IA analisa seu perfil vs vaga</div>
  </div>
</button>

                <!-- Chat -->
                <button onclick="abrirChat()" style="width:100%;background:#1e1e1e;border:1px solid #06b6d4;color:#06b6d4;border-radius:10px;padding:10px 14px;cursor:pointer;font-weight:600;font-size:0.85rem;text-align:left;display:flex;align-items:center;gap:10px;transition:all 0.2s;" onmouseover="this.style.background='#06b6d422'" onmouseout="this.style.background='#1e1e1e'">
                  <span style="width:32px;height:32px;border-radius:8px;background:#06b6d422;border:1px solid #06b6d444;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                   <i class="bi bi-chat-dots" style="color:#06b6d4;font-size:0.9rem;"></i>
                   </span>
                  <div><div style="font-size:0.85rem;font-weight:600;">Chat sobre a vaga</div><div style="font-size:0.72rem;color:#888;font-weight:400;">Tire dúvidas com a IA</div></div>
                </button>

                <!-- Entrevista -->
                <button onclick="iniciarEntrevista()" style="width:100%;background:#1e1e1e;border:1px solid #0bf574;color:#0bf574;border-radius:10px;padding:10px 14px;cursor:pointer;font-weight:600;font-size:0.85rem;text-align:left;display:flex;align-items:center;gap:10px;transition:all 0.2s;" onmouseover="this.style.background='#f59e0b22'" onmouseout="this.style.background='#1e1e1e'">
                  <span style="width:32px;height:32px;border-radius:8px;background:#f59e0b22;border:1px solid #f59e0b44;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="bi bi-mic" style="font-size:0.9rem;"></i></span>
                  <div><div style="font-size:0.85rem;font-weight:600;">Praticar entrevista</div><div style="font-size:0.72rem;color:#888;font-weight:400;">Simulação com feedback</div></div>
                </button>

                <!-- Tailoring -->
                <button onclick="abrirTailoring()" style="width:100%;background:#1e1e1e;border:1px solid #f59e0b;color:#f59e0b;border-radius:10px;padding:10px 14px;cursor:pointer;font-weight:600;font-size:0.85rem;text-align:left;display:flex;align-items:center;gap:10px;transition:all 0.2s;" onmouseover="this.style.background='#f59e0b22'" onmouseout="this.style.background='#1e1e1e'">
                  <span style="width:32px;height:32px;border-radius:8px;background:#f59e0b22;border:1px solid #f59e0b44;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="bi bi-scissors" style="font-size:0.9rem;"></i></span>
                  <div><div style="font-size:0.85rem;font-weight:600;">Adaptar currículo</div><div style="font-size:0.72rem;color:#888;font-weight:400;">IA reescreve para esta vaga</div></div>
                </button>

              </div>
            </div>
            {{/unless}}
            {{/if}}

            <!-- CARD: EMPRESA -->
            <div style="background:#1a1a1a;border:1px solid #2a2a2a;border-radius:14px;overflow:hidden;margin-bottom:12px;">
              <div style="padding:14px 18px;border-bottom:1px solid #2a2a2a;">
                <span style="font-size:0.8rem;font-weight:700;color:#888;text-transform:uppercase;letter-spacing:0.05em;">Sobre a Empresa</span>
              </div>
              <div style="padding:16px 18px;">
                <p style="font-weight:700;margin:0 0 2px;font-size:0.95rem;">{{job.company}}</p>
                <a href="/profile/empresa/{{job.UserId}}" style="color:#f03e3e;font-size:0.8rem;text-decoration:none;display:inline-flex;align-items:center;gap:4px;margin-bottom:10px;">
                  <i class="bi bi-box-arrow-up-right"></i> Ver página da empresa
                </a>
                {{#if job.modality}}
                <div style="display:flex;justify-content:space-between;padding:6px 0;border-top:1px solid #2a2a2a;">
                  <span style="color:#666;font-size:0.82rem;">Modalidade</span>
                  <span style="color:#ccc;font-size:0.82rem;">{{formatModality job.modality}}</span>
                </div>
                {{/if}}
                {{#if job.contractType}}
                <div style="display:flex;justify-content:space-between;padding:6px 0;border-top:1px solid #2a2a2a;">
                  <span style="color:#666;font-size:0.82rem;">Contratação</span>
                  <span style="color:#ccc;font-size:0.82rem;">{{formatContractType job.contractType}}</span>
                </div>
                {{/if}}
                {{#if job.salary}}
                <div style="display:flex;justify-content:space-between;padding:6px 0;border-top:1px solid #2a2a2a;">
                  <span style="color:#666;font-size:0.82rem;">Salário</span>
                  <span style="color:#ccc;font-size:0.82rem;">R$ {{job.salary}}</span>
                </div>
                {{/if}}
              </div>
            </div>

            <!-- AÇÕES SECUNDÁRIAS -->
            <div style="display:flex;gap:8px;">
              <button onclick="compartilharVaga()" id="share-btn" style="flex:1;background:transparent;border:1px solid #2a2a2a;color:#666;border-radius:10px;padding:8px;cursor:pointer;font-size:0.8rem;transition:all 0.2s;" onmouseover="this.style.borderColor='#f03e3e';this.style.color='#f03e3e'" onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#666'">
                <i class="bi bi-share me-1"></i> Compartilhar
              </button>
              {{#if isCandidate}}
              <form action="/jobs/block-company/{{job.UserId}}" method="POST" style="flex:1;">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <button type="submit" style="width:100%;background:transparent;border:1px solid #2a2a2a;color:#666;border-radius:10px;padding:8px;cursor:pointer;font-size:0.8rem;transition:all 0.2s;" onmouseover="this.style.borderColor='#f03e3e';this.style.color='#f03e3e'" onmouseout="this.style.borderColor='#2a2a2a';this.style.color='#666'" onclick="return confirm('Bloquear vagas desta empresa?')">
                  <i class="bi bi-slash-circle me-1"></i> Bloquear
                </button>
              </form>
              {{/if}}
            </div>

            <!-- BOTÕES DO DONO -->
            {{#if (isOwner user.id job.UserId)}}
            <div style="margin-top:12px;display:flex;flex-direction:column;gap:8px;">
              <a href="/jobs/edit/{{job.id}}" style="background:transparent;border:1px solid #f03e3e;color:#f03e3e;border-radius:10px;padding:9px 16px;text-decoration:none;text-align:center;font-weight:600;font-size:0.88rem;"><i class="bi bi-pencil me-1"></i> Editar Vaga</a>
              <a href="/jobs/applications/{{job.id}}" style="background:transparent;border:1px solid #2a2a2a;color:#aaa;border-radius:10px;padding:9px 16px;text-decoration:none;text-align:center;font-weight:600;font-size:0.88rem;"><i class="bi bi-people me-1"></i> Ver Candidatos</a>
              <form action="/jobs/delete/{{job.id}}" method="POST" onsubmit="return confirm('Excluir esta vaga?');">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <button type="submit" style="width:100%;background:transparent;border:1px solid #2a2a2a;color:#555;border-radius:10px;padding:9px;cursor:pointer;font-weight:600;font-size:0.88rem;"><i class="bi bi-trash me-1"></i> Excluir</button>
              </form>
            </div>
            {{/if}}

          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- VAGAS SIMILARES -->
{{#if similarJobs.length}}
<div class="container" style="max-width:1060px;margin:0 auto;padding-bottom:60px;">
  <h5 style="color:#f0f0f0;font-weight:700;margin-bottom:16px;font-size:0.95rem;"><i class="bi bi-grid me-2" style="color:#f03e3e;"></i>Vagas Similares</h5>
  <div class="row g-3">
    {{#each similarJobs}}
    <div class="col-md-4">
      <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:18px;transition:border-color 0.2s;height:100%;display:flex;flex-direction:column;justify-content:space-between;" onmouseover="this.style.borderColor='#f03e3e'" onmouseout="this.style.borderColor='#2a2a2a'">
        <div>
          <p style="font-weight:700;margin:0 0 4px;font-size:0.9rem;">{{title}}</p>
          <p style="color:#f03e3e;font-size:0.8rem;margin:0 0 10px;">{{company}}</p>
          <div style="display:flex;flex-wrap:wrap;gap:6px;">
            {{#if modality}}<span style="background:#2a2a2a;border:1px solid #333;color:#aaa;border-radius:20px;padding:2px 10px;font-size:0.72rem;">{{modality}}</span>{{/if}}
            {{#if salary}}<span style="background:#2a2a2a;border:1px solid #333;color:#aaa;border-radius:20px;padding:2px 10px;font-size:0.72rem;">R$ {{salary}}</span>{{/if}}
          </div>
        </div>
        <a href="/jobs/view/{{id}}" style="display:block;background:#f03e3e;color:white;border-radius:8px;padding:7px 16px;text-decoration:none;font-weight:600;font-size:0.82rem;text-align:center;margin-top:14px;">Ver Vaga</a>
      </div>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- MODAL CARTA -->
<div id="carta-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:9998;align-items:center;justify-content:center;padding:20px;">
  <div style="background:#1e1e1e;border:1px solid #3a3a3a;border-radius:16px;padding:32px;max-width:680px;width:100%;max-height:90vh;overflow-y:auto;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;gap:12px;">
      <div><h5 style="color:#f03e3e;font-weight:700;margin:0 0 4px;">✉️ Carta de Apresentação</h5><p style="color:#888;font-size:0.82rem;margin:0;">Gerada pela IA. Edite à vontade antes de enviar.</p></div>
      <button onclick="fecharModalCarta()" style="background:transparent;border:none;color:#666;font-size:1.5rem;cursor:pointer;line-height:1;flex-shrink:0;">×</button>
    </div>
    <div id="carta-loading" style="text-align:center;padding:48px 0;"><div style="font-size:2rem;margin-bottom:12px;">🤖</div><p style="color:#888;margin:0;">Gerando sua carta...</p></div>
    <div id="carta-content" style="display:none;">
      <textarea id="carta-texto" style="width:100%;background:#2a2a2a;border:1px solid #3a3a3a;border-radius:8px;color:#e0e0e0;padding:16px;font-size:0.88rem;line-height:1.75;resize:vertical;min-height:300px;outline:none;font-family:inherit;" onfocus="this.style.borderColor='#f03e3e'" onblur="this.style.borderColor='#3a3a3a'"></textarea>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;flex-wrap:wrap;gap:8px;">
        <button onclick="regenerarCarta()" style="background:transparent;border:1px solid #a855f7;color:#a855f7;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:0.82rem;" onmouseover="this.style.background='#a855f7';this.style.color='white'" onmouseout="this.style.background='transparent';this.style.color='#a855f7'">🔄 Regenerar</button>
        <div style="display:flex;gap:8px;">
          <button onclick="fecharModalCarta()" style="background:transparent;border:1px solid #444;color:#888;border-radius:8px;padding:6px 16px;cursor:pointer;font-size:0.88rem;">Cancelar</button>
          <form id="apply-form" action="/jobs/apply/{{job.id}}" method="POST" style="display:inline;">
            <input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="coverLetter" id="cover-letter-input">
            <button type="button" onclick="confirmarCandidatura()" style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:6px 20px;cursor:pointer;font-weight:700;font-size:0.88rem;" onmouseover="this.style.background='#c0392b'" onmouseout="this.style.background='#f03e3e'"><i class="bi bi-send me-1"></i> Enviar</button>
          </form>
        </div>
      </div>
    </div>
    <div id="carta-erro" style="display:none;">
      <div style="background:#2a1a1a;border:1px solid #3a1a1a;border-radius:8px;padding:12px 16px;margin-bottom:16px;"><p style="color:#f03e3e;font-size:0.85rem;margin:0;">⚠️ Não foi possível gerar a carta automaticamente.</p></div>
      <textarea id="carta-manual" style="width:100%;background:#2a2a2a;border:1px solid #3a3a3a;border-radius:8px;color:#e0e0e0;padding:16px;font-size:0.88rem;line-height:1.75;resize:vertical;min-height:200px;outline:none;font-family:inherit;" placeholder="Escreva sua carta (opcional)..."></textarea>
      <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:12px;flex-wrap:wrap;">
        <button onclick="fecharModalCarta()" style="background:transparent;border:1px solid #444;color:#888;border-radius:8px;padding:6px 16px;cursor:pointer;">Cancelar</button>
        <form action="/jobs/apply/{{job.id}}" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="coverLetter" value=""><button type="submit" style="background:transparent;border:1px solid #555;color:#aaa;border-radius:8px;padding:6px 16px;cursor:pointer;">Enviar sem carta</button></form>
        <form id="apply-form-manual" action="/jobs/apply/{{job.id}}" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="{{csrfToken}}"><input type="hidden" name="coverLetter" id="cover-letter-manual"><button type="button" onclick="confirmarCandidaturaManual()" style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:6px 20px;cursor:pointer;font-weight:700;"><i class="bi bi-send me-1"></i> Enviar</button></form>
      </div>
    </div>
  </div>
</div>

<!-- MODAL COMPATIBILIDADE -->
<div id="compat-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:#1e1e1e;border:1px solid #3a3a3a;border-radius:16px;padding:32px;max-width:600px;width:90%;max-height:80vh;overflow-y:auto;">
    <h5 style="color:#a855f7;font-weight:700;margin-bottom:16px;">🤖 Compatibilidade com a Vaga</h5>
    <div id="compat-result" style="color:#e0e0e0;line-height:1.8;min-height:80px;"></div>
    <div class="d-flex justify-content-end mt-3"><button onclick="document.getElementById('compat-modal').style.display='none'" style="background:transparent;border:1px solid #555;color:#aaa;border-radius:8px;padding:8px 16px;cursor:pointer;">Fechar</button></div>
  </div>
</div>

<!-- MODAL ENTREVISTA -->
<div id="interview-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:10001;align-items:center;justify-content:center;padding:20px;">
  <div style="background:#141414;border:1px solid #2a2a2a;border-radius:20px;width:100%;max-width:680px;max-height:90vh;display:flex;flex-direction:column;">
    <div style="padding:18px 22px;border-bottom:1px solid #2a2a2a;display:flex;align-items:center;justify-content:space-between;">
      <div><p style="font-weight:700;margin:0;color:#f59e0b;"><i class="bi bi-mic me-2"></i>Entrevista com IA</p><p style="color:#888;font-size:0.75rem;margin:2px 0 0;">{{job.title}} · {{job.company}}</p></div>
      <div style="display:flex;align-items:center;gap:12px;"><span id="question-counter" style="color:#888;font-size:0.8rem;">Pergunta 1/5</span><button onclick="fecharEntrevista()" style="background:transparent;border:none;color:#666;font-size:1.4rem;cursor:pointer;">×</button></div>
    </div>
    <div id="interview-messages" style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:12px;min-height:300px;">
      <div style="text-align:center;padding:40px 0;"><p style="color:#888;">Clique em iniciar para começar a simulação.</p><button onclick="startInterview()" style="background:#f59e0b;border:none;color:white;border-radius:8px;padding:10px 24px;cursor:pointer;font-weight:700;margin-top:12px;">Iniciar Entrevista</button></div>
    </div>
    <div id="interview-score" style="display:none;padding:20px;border-top:1px solid #2a2a2a;"></div>
    <div id="interview-input" style="display:none;padding:14px 16px;border-top:1px solid #2a2a2a;">
      <div style="display:flex;gap:8px;align-items:flex-end;">
        <textarea id="interview-answer" rows="2" placeholder="Sua resposta..." style="flex:1;background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:10px;padding:10px 14px;font-size:0.875rem;resize:none;outline:none;font-family:inherit;" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();enviarResposta()}" onfocus="this.style.borderColor='#f59e0b'" onblur="this.style.borderColor='#2a2a2a'"></textarea>
        <button onclick="enviarResposta()" id="interview-send" style="background:#f59e0b;border:none;color:white;border-radius:10px;padding:10px 14px;cursor:pointer;height:42px;"><i class="bi bi-send-fill"></i></button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL TAILORING -->
<div id="tailoring-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:10001;align-items:center;justify-content:center;padding:20px;">
  <div style="background:#141414;border:1px solid #2a2a2a;border-radius:20px;width:100%;max-width:720px;max-height:90vh;overflow-y:auto;">
    <div style="padding:18px 22px;border-bottom:1px solid #2a2a2a;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:#141414;z-index:1;">
      <div><p style="font-weight:700;margin:0;color:#f59e0b;"><i class="bi bi-scissors me-2"></i>Currículo Adaptado pela IA</p><p style="color:#888;font-size:0.75rem;margin:2px 0 0;">{{job.title}}</p></div>
      <button onclick="fecharTailoring()" style="background:transparent;border:none;color:#666;font-size:1.4rem;cursor:pointer;">×</button>
    </div>
    <div id="tailoring-loading" style="padding:60px;text-align:center;"><p style="color:#888;">⏳ Adaptando seu currículo...</p></div>
    <div id="tailoring-content" style="display:none;padding:24px;">
      <div style="display:flex;gap:16px;margin-bottom:24px;background:#1e1e1e;border-radius:12px;padding:16px;">
        <div style="flex:1;text-align:center;"><div style="color:#888;font-size:0.75rem;margin-bottom:4px;">Antes</div><div id="score-antes" style="font-size:1.8rem;font-weight:800;color:#f03e3e;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-variant-numeric:tabular-nums;">—</div><div style="color:#666;font-size:0.7rem;">compatibilidade</div></div>
        <div style="display:flex;align-items:center;color:#555;font-size:1.2rem;">→</div>
        <div style="flex:1;text-align:center;"><div style="color:#888;font-size:0.75rem;margin-bottom:4px;">Depois</div><div id="score-depois" style="font-size:1.8rem;font-weight:800;color:#4caf50;font-family:system-ui,-apple-system,'Segoe UI',sans-serif;font-variant-numeric:tabular-nums;">—</div><div style="color:#666;font-size:0.7rem;">compatibilidade</div></div>
      </div>
      <div style="margin-bottom:20px;"><h6 style="color:#f59e0b;font-weight:700;margin-bottom:8px;">📝 Resumo</h6><div id="tailoring-summary" style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:10px;padding:14px;color:#e0e0e0;font-size:0.875rem;line-height:1.7;"></div></div>
      <div style="margin-bottom:20px;"><h6 style="color:#f59e0b;font-weight:700;margin-bottom:8px;">⚡ Skills Destacadas</h6><div id="tailoring-skills" style="display:flex;flex-wrap:wrap;gap:8px;"></div></div>
      <div style="margin-bottom:20px;"><h6 style="color:#f59e0b;font-weight:700;margin-bottom:8px;">💼 Experiências</h6><div id="tailoring-experiences"></div></div>
      <div style="margin-bottom:20px;"><h6 style="color:#f59e0b;font-weight:700;margin-bottom:8px;">💡 Dicas</h6><div id="tailoring-dicas"></div></div>
      <div style="display:flex;gap:8px;justify-content:flex-end;">
        <button onclick="fecharTailoring()" style="background:transparent;border:1px solid #444;color:#aaa;border-radius:8px;padding:8px 16px;cursor:pointer;">Fechar</button>
        <button onclick="aplicarTailoring()" style="background:#f59e0b;border:none;color:#1a1a1a;border-radius:8px;padding:8px 20px;cursor:pointer;font-weight:700;">✅ Aplicar no Currículo</button>
      </div>
    </div>
  </div>
</div>

<!-- CHAT LATERAL -->
<div id="chat-panel" style="position:fixed;top:0;right:-440px;width:420px;height:100vh;background:#141414;border-left:1px solid #2a2a2a;z-index:10000;display:flex;flex-direction:column;transition:right 0.3s ease;box-shadow:-4px 0 24px rgba(0,0,0,0.6);">
  <div style="padding:16px 20px;border-bottom:1px solid #2a2a2a;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
    <div><p style="font-weight:700;margin:0;font-size:0.95rem;color:#06b6d4;">💬 Chat com IA</p><p style="color:#888;font-size:0.75rem;margin:2px 0 0;">{{job.title}} · {{job.company}}</p></div>
    <button onclick="fecharChat()" style="background:transparent;border:none;color:#666;font-size:1.4rem;cursor:pointer;padding:4px;">×</button>
  </div>
  <div id="chat-messages" style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px;">
    <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px 12px 12px 4px;padding:12px 14px;max-width:90%;font-size:0.875rem;line-height:1.6;color:#e0e0e0;">Olá! Estou aqui para te ajudar a entender essa vaga e preparar sua candidatura.</div>
  </div>
  <div id="chat-suggestions" style="padding:0 16px 8px;display:flex;flex-wrap:wrap;gap:6px;flex-shrink:0;">
    <button onclick="enviarSugestao(this)" style="background:#1e1e1e;border:1px solid #2a2a2a;color:#aaa;border-radius:20px;padding:5px 12px;font-size:0.75rem;cursor:pointer;">Quais requisitos são obrigatórios?</button>
    <button onclick="enviarSugestao(this)" style="background:#1e1e1e;border:1px solid #2a2a2a;color:#aaa;border-radius:20px;padding:5px 12px;font-size:0.75rem;cursor:pointer;">Como adaptar meu currículo?</button>
    <button onclick="enviarSugestao(this)" style="background:#1e1e1e;border:1px solid #2a2a2a;color:#aaa;border-radius:20px;padding:5px 12px;font-size:0.75rem;cursor:pointer;">Tenho chances nessa vaga?</button>
    <button onclick="enviarSugestao(this)" style="background:#1e1e1e;border:1px solid #2a2a2a;color:#aaa;border-radius:20px;padding:5px 12px;font-size:0.75rem;cursor:pointer;">O que estudar para essa vaga?</button>
  </div>
  <div style="padding:12px 16px;border-top:1px solid #2a2a2a;flex-shrink:0;">
    <div style="display:flex;gap:8px;align-items:flex-end;">
      <textarea id="chat-input" placeholder="Pergunte sobre a vaga..." rows="1" style="flex:1;background:#1e1e1e;border:1px solid #2a2a2a;border-radius:10px;color:#e0e0e0;padding:10px 14px;font-size:0.875rem;resize:none;outline:none;font-family:inherit;max-height:120px;line-height:1.5;" onfocus="this.style.borderColor='#06b6d4'" onblur="this.style.borderColor='#2a2a2a'" onkeydown="handleChatKey(event)" oninput="autoResizeTextarea(this)"></textarea>
      <button id="chat-send-btn" onclick="enviarMensagem()" style="background:#06b6d4;border:none;color:white;border-radius:10px;padding:10px 14px;cursor:pointer;font-size:1rem;flex-shrink:0;height:42px;"><i class="bi bi-send-fill"></i></button>
    </div>
    <p style="color:#555;font-size:0.7rem;margin:6px 0 0;text-align:center;">IA pode cometer erros · Powered by Groq</p>
  </div>
</div>
<div id="chat-overlay" onclick="fecharChat()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:9999;"></div>

<script>
// ── CARTA ────────────────────────────────
function abrirModalCarta(){document.getElementById('carta-modal').style.display='flex';mostrarEstado('loading');gerarCarta();}
function fecharModalCarta(){document.getElementById('carta-modal').style.display='none';}
function mostrarEstado(e){document.getElementById('carta-loading').style.display=e==='loading'?'block':'none';document.getElementById('carta-content').style.display=e==='ok'?'block':'none';document.getElementById('carta-erro').style.display=e==='erro'?'block':'none';}
async function gerarCarta(){try{const r=await fetch('/jobs/ai/cover-letter/{{job.id}}',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':document.getElementById('job-data').dataset.csrf}});const d=await r.json();if(d.error||!d.letter){mostrarEstado('erro');return;}document.getElementById('carta-texto').value=d.letter;mostrarEstado('ok');}catch(e){mostrarEstado('erro');}}
function regenerarCarta(){mostrarEstado('loading');gerarCarta();}
function confirmarCandidatura(){document.getElementById('cover-letter-input').value=document.getElementById('carta-texto').value.trim();document.getElementById('apply-form').submit();}
function confirmarCandidaturaManual(){document.getElementById('cover-letter-manual').value=document.getElementById('carta-manual').value.trim();document.getElementById('apply-form-manual').submit();}
document.getElementById('carta-modal').addEventListener('click',function(e){if(e.target===this)fecharModalCarta();});

// ── COMPATIBILIDADE ──────────────────────
async function checkCompatibility(){
  const modal=document.getElementById('compat-modal'),result=document.getElementById('compat-result');
  modal.style.display='flex';result.innerHTML='<span style="color:#888;">⏳ Analisando...</span>';
  try{const r=await fetch('/jobs/ai/compatibility/{{job.id}}',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':document.getElementById('job-data').dataset.csrf}});const d=await r.json();
  if(d.error){result.innerHTML='<span style="color:#f03e3e;">'+d.error+'</span>';return;}
  result.innerHTML='<div style="text-align:center;margin-bottom:20px;"><div style="font-size:3rem;font-weight:700;color:'+(d.score>=70?'#4caf50':d.score>=40?'#ffc107':'#f03e3e')+';">'+d.score+'%</div><div style="color:#aaa;font-size:0.9rem;">de compatibilidade</div></div><div style="background:#2a2a2a;border-radius:8px;padding:16px;white-space:pre-wrap;font-size:0.9rem;">'+d.analysis+'</div>';}
  catch(e){result.innerHTML='<span style="color:#f03e3e;">Erro ao conectar com a IA.</span>';}}

// ── COMPARTILHAR ─────────────────────────
function compartilharVaga(){const btn=document.getElementById('share-btn');navigator.clipboard.writeText(window.location.href).then(()=>{btn.innerHTML='<i class="bi bi-check-lg me-1"></i> Copiado!';btn.style.borderColor='#4caf50';btn.style.color='#4caf50';setTimeout(()=>{btn.innerHTML='<i class="bi bi-share me-1"></i> Compartilhar';btn.style.borderColor='#2a2a2a';btn.style.color='#666';},2000);});}

// ── ENTREVISTA ───────────────────────────
const INTERVIEW_JOB_ID=document.getElementById('job-data').dataset.jobId,INTERVIEW_CSRF=document.getElementById('job-data').dataset.csrf;
let interviewHistory=[],currentQuestion=0,interviewEnded=false;
function iniciarEntrevista(){document.getElementById('interview-modal').style.display='flex';}
function fecharEntrevista(){document.getElementById('interview-modal').style.display='none';interviewHistory=[];currentQuestion=0;interviewEnded=false;document.getElementById('interview-messages').innerHTML='<div style="text-align:center;padding:40px 0;"><p style="color:#888;">Clique em iniciar para começar.</p><button onclick="startInterview()" style="background:#f59e0b;border:none;color:white;border-radius:8px;padding:10px 24px;cursor:pointer;font-weight:700;margin-top:12px;">Iniciar Entrevista</button></div>';document.getElementById('interview-input').style.display='none';document.getElementById('interview-score').style.display='none';}
function addInterviewMsg(role,text){const c=document.getElementById('interview-messages'),d=document.createElement('div');d.style.cssText=role==='user'?'background:#f59e0b;color:white;border-radius:12px 12px 4px 12px;padding:10px 14px;max-width:85%;align-self:flex-end;font-size:0.875rem;line-height:1.6;margin-left:auto;':'background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px 12px 12px 4px;padding:12px 14px;max-width:90%;font-size:0.875rem;line-height:1.6;color:#e0e0e0;';d.textContent=text;c.appendChild(d);c.scrollTop=c.scrollHeight;}
async function startInterview(){document.getElementById('interview-messages').innerHTML='';const l=document.createElement('div');l.style.cssText='text-align:center;padding:20px;color:#888;';l.textContent='Preparando entrevista...';document.getElementById('interview-messages').appendChild(l);try{const r=await fetch('/interview/'+INTERVIEW_JOB_ID+'/start',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':INTERVIEW_CSRF}});const d=await r.json();l.remove();currentQuestion=1;interviewHistory.push({role:'assistant',content:d.question});addInterviewMsg('assistant',d.question);document.getElementById('interview-input').style.display='block';document.getElementById('question-counter').textContent='Pergunta '+currentQuestion+'/5';document.getElementById('interview-answer').focus();}catch(e){l.textContent='Erro ao iniciar.';}}
async function enviarResposta(){const input=document.getElementById('interview-answer'),answer=input.value.trim();if(!answer||interviewEnded)return;input.value='';addInterviewMsg('user',answer);interviewHistory.push({role:'user',content:answer});const l=document.createElement('div');l.style.cssText='color:#888;font-size:0.82rem;padding:8px;';l.textContent='...';document.getElementById('interview-messages').appendChild(l);try{const r=await fetch('/interview/'+INTERVIEW_JOB_ID+'/answer',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':INTERVIEW_CSRF},body:JSON.stringify({history:interviewHistory,answer,questionNumber:currentQuestion})});const d=await r.json();l.remove();interviewHistory.push({role:'assistant',content:d.response});addInterviewMsg('assistant',d.response);currentQuestion++;document.getElementById('question-counter').textContent='Pergunta '+Math.min(currentQuestion,5)+'/5';if(d.isEnd){interviewEnded=true;document.getElementById('interview-input').style.display='none';await gerarScore();}}catch(e){l.textContent='Erro. Tente novamente.';}}
async function gerarScore(){const s=document.getElementById('interview-score');s.style.display='block';s.innerHTML='<p style="color:#888;">Gerando avaliação...</p>';try{const r=await fetch('/interview/'+INTERVIEW_JOB_ID+'/score',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':INTERVIEW_CSRF},body:JSON.stringify({history:interviewHistory})});const d=await r.json();const rc={aprovado:'#4caf50',em_analise:'#f59e0b',reprovado:'#f03e3e'}[d.recomendacao]||'#888',rl={aprovado:'Aprovado',em_analise:'Em Análise',reprovado:'Reprovado'}[d.recomendacao]||'';s.innerHTML='<div style="display:flex;gap:16px;margin-bottom:14px;align-items:center;"><div style="text-align:center;"><div style="font-size:2rem;font-weight:800;color:'+rc+';">'+d.score+'</div><div style="color:#888;font-size:0.72rem;">Score Final</div></div><span style="background:'+rc+'22;border:1px solid '+rc+';color:'+rc+';border-radius:20px;padding:4px 14px;font-weight:700;font-size:0.82rem;">'+rl+'</span></div><div style="display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;"><div style="background:#1e1e1e;border-radius:8px;padding:8px 12px;text-align:center;min-width:80px;"><div style="font-weight:700;color:#06b6d4;">'+d.comunicacao+'/10</div><div style="color:#888;font-size:0.7rem;">Comunicação</div></div><div style="background:#1e1e1e;border-radius:8px;padding:8px 12px;text-align:center;min-width:80px;"><div style="font-weight:700;color:#a855f7;">'+d.conhecimento_tecnico+'/10</div><div style="color:#888;font-size:0.7rem;">Técnico</div></div><div style="background:#1e1e1e;border-radius:8px;padding:8px 12px;text-align:center;min-width:80px;"><div style="font-weight:700;color:#f59e0b;">'+d.fit_cultural+'/10</div><div style="color:#888;font-size:0.7rem;">Fit Cultural</div></div></div><p style="color:#aaa;font-size:0.82rem;line-height:1.6;">'+(d.feedback_geral||'')+'</p><button onclick="fecharEntrevista()" style="background:transparent;border:1px solid #555;color:#aaa;border-radius:8px;padding:6px 16px;cursor:pointer;font-size:0.82rem;margin-top:8px;">Fechar</button>';}catch(e){s.innerHTML='<p style="color:#f03e3e;">Erro ao gerar avaliação.</p>';}}

// ── TAILORING ────────────────────────────
const TAILORING_JOB_ID=document.getElementById('job-data').dataset.jobId,TAILORING_CSRF=document.getElementById('job-data').dataset.csrf;
let tailoringData=null;
function abrirTailoring(){document.getElementById('tailoring-modal').style.display='flex';document.getElementById('tailoring-loading').style.display='block';document.getElementById('tailoring-content').style.display='none';fetchTailoring();}
function fecharTailoring(){document.getElementById('tailoring-modal').style.display='none';}
async function fetchTailoring(){try{const r=await fetch('/tailoring/'+TAILORING_JOB_ID,{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':TAILORING_CSRF}});const d=await r.json();if(d.error){alert(d.error);fecharTailoring();return;}tailoringData=d;document.getElementById('score-antes').textContent=(d.score_antes||0)+'%';document.getElementById('score-depois').textContent=(d.score_depois||0)+'%';document.getElementById('tailoring-summary').textContent=d.summary||'';document.getElementById('tailoring-skills').innerHTML=(d.skills_destacadas||[]).map(s=>'<span style="background:#2a2a2a;border:1px solid #f59e0b;color:#f59e0b;border-radius:20px;padding:4px 14px;font-size:0.8rem;">'+s+'</span>').join('');document.getElementById('tailoring-experiences').innerHTML=(d.experiences_reescritas||[]).map(e=>'<div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:10px;padding:14px;margin-bottom:10px;"><p style="font-weight:700;margin:0 0 2px;">'+e.role+'</p><p style="color:#f03e3e;font-size:0.82rem;margin:0 0 8px;">'+e.company+' · '+(e.period||'')+'</p><p style="color:#aaa;font-size:0.85rem;line-height:1.6;margin:0;">'+e.description+'</p></div>').join('');document.getElementById('tailoring-dicas').innerHTML=(d.dicas||[]).map(d=>'<div style="display:flex;gap:8px;margin-bottom:8px;color:#aaa;font-size:0.85rem;"><span style="color:#f59e0b;flex-shrink:0;">→</span>'+d+'</div>').join('');document.getElementById('tailoring-loading').style.display='none';document.getElementById('tailoring-content').style.display='block';}catch(e){alert('Erro ao adaptar currículo.');fecharTailoring();}}
async function aplicarTailoring(){if(!tailoringData)return;try{const r=await fetch('/resume/tailoring/apply',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':TAILORING_CSRF},body:JSON.stringify(tailoringData)});const d=await r.json();if(d.ok){alert('Currículo atualizado!');fecharTailoring();}}catch(e){alert('Erro ao aplicar.');}}

// ── CHAT ─────────────────────────────────
const JOB_ID=document.getElementById('job-data').dataset.jobId,CSRF=document.getElementById('job-data').dataset.csrf;
let chatHistory=[],isStreaming=false;
function abrirChat(){document.getElementById('chat-panel').style.right='0';document.getElementById('chat-overlay').style.display='block';document.body.style.overflow='hidden';setTimeout(()=>document.getElementById('chat-input').focus(),300);}
function fecharChat(){document.getElementById('chat-panel').style.right='-440px';document.getElementById('chat-overlay').style.display='none';document.body.style.overflow='';}
function handleChatKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();enviarMensagem();}}
function autoResizeTextarea(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}
function enviarSugestao(btn){document.getElementById('chat-input').value=btn.textContent.trim();document.getElementById('chat-suggestions').style.display='none';enviarMensagem();}
function adicionarMensagem(role,content,streaming=false){const c=document.getElementById('chat-messages'),d=document.createElement('div');d.style.cssText=role==='user'?'background:#06b6d4;color:white;border-radius:12px 12px 4px 12px;padding:10px 14px;max-width:85%;align-self:flex-end;font-size:0.875rem;line-height:1.6;margin-left:auto;':'background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px 12px 12px 4px;padding:12px 14px;max-width:90%;font-size:0.875rem;line-height:1.6;color:#e0e0e0;';d.textContent=content;if(streaming)d.id='streaming-msg';c.appendChild(d);c.scrollTop=c.scrollHeight;return d;}
async function enviarMensagem(){if(isStreaming)return;const input=document.getElementById('chat-input'),message=input.value.trim();if(!message)return;input.value='';input.style.height='auto';adicionarMensagem('user',message);chatHistory.push({role:'user',content:message});const aiDiv=adicionarMensagem('assistant','',true);aiDiv.innerHTML='<span style="color:#06b6d4;animation:blink 1s infinite;">&#9607;</span>';isStreaming=true;document.getElementById('chat-send-btn').disabled=true;document.getElementById('chat-send-btn').style.opacity='0.5';let fullResponse='';try{const response=await fetch('/jobs/'+JOB_ID+'/chat',{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':CSRF},body:JSON.stringify({messages:chatHistory})});if(!response.ok)throw new Error('Erro');const reader=response.body.getReader(),decoder=new TextDecoder();let buffer='';while(true){const{done,value}=await reader.read();if(done)break;buffer+=decoder.decode(value,{stream:true});const lines=buffer.split('\n');buffer=lines.pop();for(const line of lines){if(!line.startsWith('data: '))continue;try{const data=JSON.parse(line.slice(6));if(data.error){aiDiv.textContent='Erro: '+data.error;break;}if(data.done)break;if(data.token){fullResponse+=data.token;aiDiv.textContent=fullResponse;document.getElementById('chat-messages').scrollTop=document.getElementById('chat-messages').scrollHeight;}}catch(e){}}}aiDiv.removeAttribute('id');if(fullResponse)chatHistory.push({role:'assistant',content:fullResponse});}catch(err){aiDiv.textContent='Erro ao conectar com a IA.';aiDiv.removeAttribute('id');chatHistory.pop();}finally{isStreaming=false;document.getElementById('chat-send-btn').disabled=false;document.getElementById('chat-send-btn').style.opacity='1';document.getElementById('chat-input').focus();}}
const chatStyle=document.createElement('style');chatStyle.textContent='@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}#chat-messages::-webkit-scrollbar{width:4px}#chat-messages::-webkit-scrollbar-thumb{background:#2a2a2a;border-radius:4px}';document.head.appendChild(chatStyle);
</script>
