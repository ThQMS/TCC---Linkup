<style>
.help-tab{background:transparent;border:none;border-bottom:2px solid transparent;color:#666;padding:10px 20px;cursor:pointer;font-weight:600;font-size:0.88rem;white-space:nowrap;margin-bottom:-2px;transition:all 0.2s;}
.help-tab:hover{color:#ccc;}
.help-tab.active{border-bottom-color:#e63946;color:#f0f0f0;}
.help-contact-input{width:100%;background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;padding:10px 14px;outline:none;font-size:0.88rem;transition:border-color 0.2s;}
.help-contact-input:focus{border-color:#e63946;}
.help-contact-input::placeholder{color:#444;}
.help-submit{background:#e63946;border:none;color:white;border-radius:8px;padding:10px 28px;font-weight:700;cursor:pointer;font-size:0.9rem;transition:background 0.2s;}
.help-submit:hover{background:#c62828;}
.help-submit:active{background:#b71c1c;}
@media(max-width:576px){
  .help-tab{padding:9px 14px;font-size:0.82rem;}
  [id^="faq-"] [style*="grid-template-columns"]{grid-template-columns:1fr !important;}
}
.guia-cols { display:flex; gap:0; align-items:stretch; background:#1a1a1a; border:1px solid #2a2a2a; border-radius:14px; overflow:hidden; }
.guia-col  { flex:1; min-width:0; padding:22px 18px; }
.guia-col + .guia-col { border-left:1px solid #242424; }
.guia-feat { background:#111; border:1px solid #222; border-radius:10px; padding:16px; margin-bottom:10px; transition:border-color 0.2s, transform 0.2s; }
.guia-feat:last-child { margin-bottom:0; }
.guia-feat:hover { transform:translateY(-1px); }
.col-geral   .guia-feat:hover { border-color:rgba(230,57,70,0.45); }
.col-cand    .guia-feat:hover { border-color:rgba(6,182,212,0.45); }
.col-emp     .guia-feat:hover { border-color:rgba(168,85,247,0.45); }
@media(max-width:700px){
  .guia-cols { flex-direction:column; }
  .guia-col + .guia-col { border-left:none; border-top:1px solid #242424; }
}
