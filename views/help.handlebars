      <form action="/help/contact" method="POST">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="row g-3">
          <div class="col-md-6">
            <label style="display:block;color:#3a3a3a;font-size:0.74rem;font-weight:700;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.7px;">Nome</label>
            <input type="text" name="name" placeholder="Seu nome completo" required class="help-contact-input">
          </div>
          <div class="col-md-6">
            <label style="display:block;color:#3a3a3a;font-size:0.74rem;font-weight:700;margin-bottom:6px;text-transform:uppercase;letter-spacing:0.7px;">Email</label>
