            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
              <div style="width:30px;height:30px;border-radius:7px;background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-magic" style="color:#a855f7;font-size:0.85rem;"></i>
              </div>
              <span style="font-weight:700;font-size:0.85rem;">Melhorar Vaga com IA</span>
            </div>
            <p style="color:#666;font-size:0.8rem;line-height:1.6;margin:0;">Refina automaticamente descrição, requisitos e benefícios da vaga ao criar ou editar.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- CONTATO -->
    <div style="background:#1a1a1a;border:1px solid #252525;border-radius:16px;padding:36px;margin-top:48px;">
      <div class="d-flex align-items-center gap-3 mb-3">
        <div style="width:40px;height:40px;border-radius:10px;background:rgba(240,62,62,0.08);border:1px solid rgba(240,62,62,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="bi bi-chat-dots-fill" style="color:#f03e3e;"></i>
        </div>
        <div>
          <h4 style="font-weight:700;margin:0;font-size:1.05rem;">Não encontrou sua resposta?</h4>
          <p style="color:#666;margin:2px 0 0;font-size:0.85rem;">Envie sua dúvida e responderemos em até 24 horas.</p>
        </div>
      </div>
      <form action="/help/contact" method="POST">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="row g-3 mt-1">
          <div class="col-md-6">
            <input type="text" name="name" placeholder="Seu nome" required class="help-contact-input">
          </div>
          <div class="col-md-6">
            <input type="email" name="email" placeholder="Seu email" required class="help-contact-input">
          </div>
          <div class="col-12">
            <textarea name="message" rows="4" placeholder="Descreva sua dúvida..." required
              class="help-contact-input" style="resize:none;"></textarea>
          </div>
          <div class="col-12">
            <button type="submit" class="help-submit">
              <i class="bi bi-send me-2"></i>Enviar Mensagem
            </button>
          </div>
        </div>
      </form>
    </div>

  </div>
</div>

<script>
function showTab(tab) {
  ['candidato','empresa','conta','guia'].forEach(function(t) {
    document.getElementById('faq-' + t).style.display = t === tab ? 'block' : 'none';
    var btn = document.getElementById('tab-' + t);
    btn.classList.toggle('active', t === tab);
  });
}
if (window.location.hash === '#guia') showTab('guia');
</script>
