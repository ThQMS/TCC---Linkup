              <i class="bi bi-lock-fill"></i>Formulário protegido
            </span>
            <button type="submit" class="help-submit">
              <i class="bi bi-send me-2"></i>Enviar Mensagem
            </button>
          </div>
        </div>
      </form>
    </div>

  </div>
</div>

<script>
var _currentTab = 'candidato';

function toggleFaq(btn) {
  var item    = btn.parentElement;
  var content = btn.nextElementSibling;
  var icon    = btn.querySelector('i');
  var open    = content.style.display === 'none';
  content.style.display = open ? 'block' : 'none';
  icon.style.transform  = open ? 'rotate(180deg)' : 'rotate(0deg)';
  if (item) item.classList.toggle('faq-open', open);
}

function showTab(tab) {
  clearSearch();
  _currentTab = tab;
  ['candidato','empresa','conta','guia','passos'].forEach(function(t) {
    var section = document.getElementById('faq-' + t);
    var btn     = document.getElementById('tab-' + t);
    if (section) {
      if (t === tab) {
        section.style.display = 'block';
        section.classList.add('tab-fade');
        setTimeout(function() { section.classList.remove('tab-fade'); }, 250);
      } else {
        section.style.display = 'none';
      }
    }
    if (btn) btn.classList.toggle('active', t === tab);
  });
  var isFaqTab = ['candidato','empresa','conta'].indexOf(tab) !== -1;
  var searchEl = document.getElementById('faq-search');
  if (searchEl) {
    searchEl.disabled    = !isFaqTab;
    searchEl.style.opacity     = isFaqTab ? '1' : '0.3';
    searchEl.style.cursor      = isFaqTab ? '' : 'not-allowed';
    searchEl.placeholder = isFaqTab
      ? 'Pesquisar nas perguntas frequentes...'
      : 'Pesquisa disponível nas abas de FAQ';
  }
}

function filterFaq(term) {
  var q        = term.toLowerCase().trim();
  var clearBtn = document.getElementById('faq-search-clear');
  if (clearBtn) clearBtn.style.display = q ? 'inline-block' : 'none';

  var isFaqTab = ['candidato','empresa','conta'].indexOf(_currentTab) !== -1;
  if (!isFaqTab) return;

  var container = document.getElementById('faq-' + _currentTab);
  if (!container) return;
  var items   = container.querySelectorAll('[data-faq-item]');
  var visible = 0;

  items.forEach(function(item) {
    var questionBtn  = item.querySelector('button');
    var questionText = questionBtn ? questionBtn.textContent.toLowerCase() : '';
    var answerDiv    = item.querySelector('button + div');
    var answerText   = answerDiv ? answerDiv.textContent.toLowerCase() : '';
    var show = !q || questionText.indexOf(q) !== -1 || answerText.indexOf(q) !== -1;
    item.style.display = show ? '' : 'none';
    if (show) visible++;
  });

  var noResults = container.querySelector('.faq-no-results');
  if (!noResults) {
    noResults = document.createElement('div');
    noResults.className = 'faq-no-results';
    noResults.style.cssText = 'text-align:center;color:#3a3a3a;padding:48px 0;font-size:0.88rem;';
    container.appendChild(noResults);
  }
  noResults.innerHTML = '<i class="bi bi-search" style="font-size:1.6rem;display:block;margin-bottom:10px;color:#2a2a2a;"></i>Nenhuma pergunta encontrada para <strong style="color:#555;">"' + term + '"</strong>.';
  noResults.style.display = (visible === 0 && q) ? 'block' : 'none';
}

function clearSearch() {
  var input    = document.getElementById('faq-search');
  var clearBtn = document.getElementById('faq-search-clear');
  if (input)    { input.value = ''; filterFaq(''); }
  if (clearBtn) clearBtn.style.display = 'none';
}

if (window.location.hash === '#guia')   showTab('guia');
else if (window.location.hash === '#passos') showTab('passos');
</script>
