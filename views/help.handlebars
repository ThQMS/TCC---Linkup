<style>
/* ── TABS ── */
.help-tab{background:transparent;border:none;border-bottom:2px solid transparent;color:#555;padding:10px 20px;cursor:pointer;font-weight:600;font-size:0.88rem;white-space:nowrap;margin-bottom:-2px;transition:color 0.2s,border-color 0.2s;}
.help-tab:hover{color:#ccc;}
.help-tab.active{border-bottom-color:#e63946;color:#f0f0f0;}

/* ── CONTACT FORM ── */
.help-contact-input{width:100%;background:#161616;border:1px solid #252525;color:#e0e0e0;border-radius:8px;padding:10px 14px;outline:none;font-size:0.88rem;transition:border-color 0.2s,box-shadow 0.2s;}
.help-contact-input:focus{border-color:#e63946;box-shadow:0 0 0 3px rgba(230,57,70,0.08);}
.help-contact-input::placeholder{color:#3a3a3a;}
.help-submit{background:#e63946;border:none;color:white;border-radius:8px;padding:10px 28px;font-weight:700;cursor:pointer;font-size:0.9rem;transition:background 0.2s,transform 0.15s,box-shadow 0.2s;}
.help-submit:hover{background:#c62828;transform:translateY(-1px);box-shadow:0 4px 14px rgba(230,57,70,0.3);}
.help-submit:active{transform:translateY(0);}

/* ── SEARCH ── */
.help-search{width:100%;background:#161616;border:1px solid #252525;color:#e0e0e0;border-radius:10px;padding:12px 40px 12px 40px;outline:none;font-size:0.88rem;transition:border-color 0.2s,box-shadow 0.2s;}
.help-search:focus{border-color:#e63946;box-shadow:0 0 0 3px rgba(230,57,70,0.07);}
.help-search::placeholder{color:#3a3a3a;}

/* ── QUICK LINKS ── */
.quick-link{background:#111;border:1px solid #1e1e1e;border-radius:12px;padding:16px 10px;cursor:pointer;text-align:center;transition:border-color 0.2s,transform 0.2s,background 0.2s;display:flex;flex-direction:column;align-items:center;gap:7px;}
.quick-link:hover{transform:translateY(-3px);}
.quick-link-cand:hover{border-color:rgba(6,182,212,0.4);background:rgba(6,182,212,0.03);}
.quick-link-emp:hover{border-color:rgba(168,85,247,0.4);background:rgba(168,85,247,0.03);}
.quick-link-conta:hover{border-color:rgba(230,57,70,0.4);background:rgba(230,57,70,0.03);}
.quick-link-passos:hover{border-color:rgba(34,197,94,0.4);background:rgba(34,197,94,0.03);}
.quick-link-guia:hover{border-color:rgba(251,191,36,0.4);background:rgba(251,191,36,0.03);}

/* ── FAQ OPEN STATE — colored left accent ── */
[data-faq-item]{transition:border-color 0.2s;}
#faq-candidato [data-faq-item].faq-open{border-left:3px solid rgba(6,182,212,0.5);}
#faq-empresa   [data-faq-item].faq-open{border-left:3px solid rgba(168,85,247,0.5);}
#faq-conta     [data-faq-item].faq-open{border-left:3px solid rgba(230,57,70,0.5);}
[data-faq-item].faq-open>button{color:#fff;}
[data-faq-item].faq-open>div{color:#999;}

/* ── GUIDE ── */
.guia-cols{display:flex;gap:0;align-items:stretch;background:#111;border:1px solid #1e1e1e;border-radius:14px;overflow:hidden;}
.guia-col{flex:1;min-width:0;padding:22px 18px;}
.guia-col+.guia-col{border-left:1px solid #1e1e1e;}
.guia-feat{background:#0d0d0d;border:1px solid #1a1a1a;border-radius:10px;padding:16px;margin-bottom:10px;transition:border-color 0.2s,transform 0.15s;}
.guia-feat:last-child{margin-bottom:0;}
.guia-feat:hover{transform:translateY(-1px);}
.col-geral .guia-feat:hover{border-color:rgba(230,57,70,0.4);}
.col-cand  .guia-feat:hover{border-color:rgba(6,182,212,0.4);}
.col-emp   .guia-feat:hover{border-color:rgba(168,85,247,0.4);}

/* ── STEPS TIMELINE ── */
.steps-list{display:flex;flex-direction:column;gap:0;position:relative;}
.steps-list::before{content:'';position:absolute;left:13px;top:36px;bottom:36px;width:1px;background:linear-gradient(to bottom,#2a2a2a 0%,transparent 100%);pointer-events:none;}
.step-card{background:#0d0d0d;border:1px solid #1a1a1a;border-radius:12px;padding:16px 16px 16px 14px;display:flex;gap:14px;align-items:flex-start;transition:border-color 0.2s,transform 0.15s;margin-bottom:8px;position:relative;}
.step-card:last-child{margin-bottom:0;}
.step-card:hover{transform:translateX(3px);}
.step-num{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:800;flex-shrink:0;margin-top:1px;}

/* ── TAB FADE ANIMATION ── */
@keyframes tabFadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.tab-fade{animation:tabFadeIn 0.2s ease forwards;}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .help-tab{padding:9px 12px;font-size:0.8rem;}
  .quick-links-grid{grid-template-columns:repeat(3,1fr) !important;}
  .passos-grid{grid-template-columns:1fr !important;}
  .guia-cols{flex-direction:column;}
  .guia-col+.guia-col{border-left:none;border-top:1px solid #1e1e1e;}
  .steps-list::before{display:none;}
}
@media(max-width:400px){
  .quick-links-grid{grid-template-columns:repeat(2,1fr) !important;}
}
</style>

