<style>
/* ── PROFILE CANDIDATO ── */
.pf-wrap { padding-top: 64px; }

.pf-header {
  background: #111;
  border-bottom: 1px solid #222;
  padding: 24px 0;
}
.pf-header-inner {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 24px;
}
.pf-identity {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}
.pf-avatar-outer {
  position: relative;
  flex-shrink: 0;
}
.pf-avatar {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  border: 4px solid #111;
  background: #2a2a2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.8rem;
  color: #f03e3e;
  overflow: hidden;
  box-shadow: 0 0 0 2px #f03e3e;
}
.pf-avatar img { width: 100%; height: 100%; object-fit: cover; }
.pf-avatar-btn {
  position: absolute;
  bottom: 4px; right: 4px;
  width: 28px; height: 28px;
  background: #f03e3e;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  border: 2px solid #111;
  transition: opacity 0.2s;
}
.pf-avatar-btn:hover { opacity: 0.85; }

.pf-info { flex: 1; min-width: 200px; }
.pf-name { font-size: 1.6rem; font-weight: 800; margin: 0 0 4px; }
.pf-bio  { color: #888; font-size: 0.9rem; margin: 0 0 10px; }
.pf-badges { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
.pf-badge-role {
  background: rgba(240,62,62,0.12);
  border: 1px solid rgba(240,62,62,0.3);
  color: #f03e3e;
  font-size: 0.75rem;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 600;
  display: inline-flex; align-items: center; gap: 4px;
}
.pf-badge-city {
  color: #888; font-size: 0.85rem;
  display: inline-flex; align-items: center; gap: 4px;
}
.pf-badge-otw {
  background: rgba(76,175,80,0.12);
  border: 1px solid rgba(76,175,80,0.35);
  color: #4caf50;
  font-size: 0.75rem;
  padding: 3px 10px;
  border-radius: 20px;
  font-weight: 600;
  display: none;
}
.pf-badge-otw.visible { display: inline-flex; align-items: center; gap: 4px; }

.pf-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-left: auto; }
.pf-btn-edit {
  background: transparent;
  border: 1px solid #f03e3e;
  color: #f03e3e;
  border-radius: 8px;
  padding: 8px 18px;
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
}
.pf-btn-edit:hover { background: #f03e3e; color: white; }
.pf-btn-dash {
  background: #1e1e1e;
  border: 1px solid #2a2a2a;
  color: #aaa;
  border-radius: 8px;
  padding: 8px 18px;
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
  text-decoration: none;
}
.pf-btn-dash:hover { border-color: #f03e3e; color: #f03e3e; }

/* STATS */
.pf-stats {
  display: flex;
  gap: 1px;
  background: #222;
  border-top: 1px solid #222;
  margin-top: 20px;
}
.pf-stat {
  flex: 1;
  background: #111;
  padding: 14px 20px;
  text-align: center;
  position: relative;
}
.pf-stat-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  transition: background 0.35s ease;
}
.pf-stat-num {
  font-size: 1.6rem;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 2px;
}
.pf-stat-applications .pf-stat-bar { background: #f03e3e; }
.pf-stat-applications .pf-stat-num { color: #f03e3e; }
.pf-stat-days .pf-stat-bar         { background: #06b6d4; }
.pf-stat-days .pf-stat-num         { color: #06b6d4; }
.pf-stat-label { font-size: 0.75rem; color: #666; }

/* BODY */
.pf-body {
  max-width: 960px;
  margin: 32px auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 24px;
}
@media (max-width: 768px) {
  .pf-body { grid-template-columns: 1fr; }
  .pf-identity { margin-top: -40px; }
  .pf-info, .pf-actions { padding-top: 0; }
  .pf-actions { margin-left: 0; width: 100%; }
  .pf-name { font-size: 1.3rem; }
}

/* SIDEBAR CARDS */
.pf-card {
  background: #141414;
  border: 1px solid #222;
  border-radius: 14px;
  padding: 20px;
  margin-bottom: 16px;
}
.pf-card-title {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #555;
  margin-bottom: 14px;
}
.pf-link-item {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #1e1e1e;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  padding: 10px 14px;
  color: #e0e0e0;
  text-decoration: none;
  margin-bottom: 8px;
  font-size: 0.88rem;
  transition: border-color 0.2s;
}
.pf-link-item:hover { border-color: #f03e3e; color: #f03e3e; }
.pf-link-item .ms-auto { color: #555; font-size: 0.75rem; }
.pf-link-item:hover .ms-auto { color: #f03e3e; }
.pf-empty-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0;
  color: #444;
  font-size: 0.82rem;
  border-bottom: 1px dashed #222;
  margin-bottom: 8px;
  cursor: pointer;
  transition: color 0.2s;
}
.pf-empty-link:hover { color: #f03e3e; }
.pf-info-row { margin-bottom: 14px; }
.pf-info-label { font-size: 0.72rem; color: #555; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px; }
.pf-info-value { font-size: 0.9rem; color: #e0e0e0; }

/* DISPONIBILIDADE — seletor de 4 status */
.avail-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 11px;
  border-radius: 10px;
  border: 1.5px solid #222;
  margin-bottom: 7px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
  user-select: none;
}
.avail-option:last-child { margin-bottom: 0; }
.avail-option:hover:not(.avail-selected) { border-color: #383838; }
.avail-option.avail-selected.avail-s1 { border-color: #4caf50; background: rgba(76,175,80,0.06); }
.avail-option.avail-selected.avail-s2 { border-color: #ffc107; background: rgba(255,193,7,0.06); }
.avail-option.avail-selected.avail-s3 { border-color: #fd7e14; background: rgba(253,126,20,0.06); }
.avail-option.avail-selected.avail-s4 { border-color: #f03e3e; background: rgba(240,62,62,0.06); }
.avail-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.95rem;
  flex-shrink: 0;
}
.avail-s1 .avail-icon { background: rgba(76,175,80,0.12); }
.avail-s2 .avail-icon { background: rgba(255,193,7,0.12); }
.avail-s3 .avail-icon { background: rgba(253,126,20,0.12); }
.avail-s4 .avail-icon { background: rgba(240,62,62,0.12); }
.avail-title { font-size: 0.79rem; font-weight: 700; color: #e0e0e0; line-height: 1.2; }
.avail-desc  { font-size: 0.68rem; color: #555; margin-top: 1px; }
.avail-dot {
  margin-left: auto;
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 1.5px solid #333;
  flex-shrink: 0;
  transition: background 0.2s, border-color 0.2s;
}
.avail-selected.avail-s1 .avail-dot { background: #4caf50; border-color: #4caf50; }
.avail-selected.avail-s2 .avail-dot { background: #ffc107; border-color: #ffc107; }
.avail-selected.avail-s3 .avail-dot { background: #fd7e14; border-color: #fd7e14; }
.avail-selected.avail-s4 .avail-dot { background: #f03e3e; border-color: #f03e3e; }

/* TABS */
.pf-tabs { display: flex; gap: 0; border-bottom: 1px solid #222; margin-bottom: 20px; }
.pf-tab {
  padding: 10px 20px;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: #666;
  font-size: 0.88rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
}
.pf-tab.active { color: #f03e3e; border-bottom-color: #f03e3e; }
.pf-tab:hover:not(.active) { color: #aaa; }
.pf-tab-pane { display: none; }
.pf-tab-pane.active { display: block; }

/* SOBRE/BIO */
.pf-section-head {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #555;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
}
</style>

<div class="pf-wrap">

  <!-- COVER -->

  <!-- HEADER -->
  <div class="pf-header">
    <div class="pf-header-inner">

      <div class="pf-identity">
        <!-- AVATAR -->
        <div class="pf-avatar-outer">
          <div class="pf-avatar">
            {{#if user.avatar}}
              <img src="{{user.avatar}}" alt="Avatar">
            {{else}}
              <i class="bi bi-person-fill"></i>
            {{/if}}
          </div>
          <label for="avatarInput" title="Alterar foto" class="pf-avatar-btn">
            <i class="bi bi-camera-fill" style="font-size:0.7rem;color:white;"></i>
          </label>
          <form id="avatarForm" action="/profile/avatar" method="POST" enctype="multipart/form-data" style="display:none;">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <input type="file" id="avatarInput" name="avatar" accept="image/jpeg,image/png,image/webp"
              onchange="document.getElementById('avatarForm').submit();">
          </form>
        </div>

        <!-- INFO -->
        <div class="pf-info">
          <h1 class="pf-name">{{user.name}}</h1>
          <p class="pf-bio">{{#if user.bio}}{{user.bio}}{{else}}Sem bio ainda — clique em Editar Perfil para adicionar.{{/if}}</p>
          <div class="pf-badges">
            <span class="pf-badge-role"><i class="bi bi-person-badge"></i>Candidato</span>
            {{#if user.city}}<span class="pf-badge-city"><i class="bi bi-geo-alt"></i>{{user.city}}</span>{{/if}}
            {{#if (eq user.availabilityStatus 'actively_searching')}}
            <span class="pf-badge-otw visible" id="avail-badge" style="background:rgba(76,175,80,0.12);border-color:rgba(76,175,80,0.35);color:#4caf50;">
              <i class="bi bi-circle-fill" style="font-size:0.5rem;"></i>Buscando Ativamente
            </span>
            {{else if (eq user.availabilityStatus 'open_to_opportunities')}}
            <span class="pf-badge-otw visible" id="avail-badge" style="background:rgba(255,193,7,0.12);border-color:rgba(255,193,7,0.35);color:#ffc107;">
              <i class="bi bi-circle-fill" style="font-size:0.5rem;"></i>Aberto a Oportunidades
            </span>
            {{else if (eq user.availabilityStatus 'in_selection_process')}}
            <span class="pf-badge-otw visible" id="avail-badge" style="background:rgba(253,126,20,0.12);border-color:rgba(253,126,20,0.35);color:#fd7e14;">
              <i class="bi bi-circle-fill" style="font-size:0.5rem;"></i>Em Processo Seletivo
            </span>
            {{else}}
            <span class="pf-badge-otw visible" id="avail-badge" style="background:rgba(240,62,62,0.08);border-color:rgba(240,62,62,0.3);color:#f03e3e;">
              <i class="bi bi-circle-fill" style="font-size:0.5rem;"></i>Não Disponível
            </span>
            {{/if}}
          </div>
        </div>

        <!-- AÇÕES -->
        <div class="pf-actions">
          <button class="pf-btn-edit" onclick="document.getElementById('editModal').style.display='flex'">
            <i class="bi bi-pencil"></i>Editar Perfil
          </button>
        </div>
      </div>

      <!-- STATS -->
      <div class="pf-stats">
        <div class="pf-stat pf-stat-applications">
          <div class="pf-stat-num">{{applicationsCount}}</div>
          <div class="pf-stat-label">Candidaturas</div>
        </div>
        <div class="pf-stat pf-stat-days">
          <div class="pf-stat-num">{{memberDays}}</div>
          <div class="pf-stat-label">Dias na plataforma</div>
        </div>
        <div class="pf-stat pf-stat-otw">
          <div class="pf-stat-bar" id="avail-stat-bar" style="
            {{#if (eq user.availabilityStatus 'actively_searching')}}background:#4caf50;
            {{else if (eq user.availabilityStatus 'open_to_opportunities')}}background:#ffc107;
            {{else if (eq user.availabilityStatus 'in_selection_process')}}background:#fd7e14;
            {{else}}background:#f03e3e;{{/if}}"></div>
          <div class="pf-stat-num" id="avail-stat-text" style="font-size:0.85rem;line-height:1.2;padding-top:4px;transition:color 0.35s ease;
            {{#if (eq user.availabilityStatus 'actively_searching')}}color:#4caf50;
            {{else if (eq user.availabilityStatus 'open_to_opportunities')}}color:#ffc107;
            {{else if (eq user.availabilityStatus 'in_selection_process')}}color:#fd7e14;
            {{else}}color:#f03e3e;{{/if}}">
            {{#if (eq user.availabilityStatus 'actively_searching')}}Ativo
            {{else if (eq user.availabilityStatus 'open_to_opportunities')}}Aberto
            {{else if (eq user.availabilityStatus 'in_selection_process')}}Processo
            {{else}}Inativo{{/if}}
          </div>
          <div class="pf-stat-label">Disponibilidade</div>
        </div>
      </div>

    </div>
  </div>

  <!-- CHECKLIST DE ONBOARDING -->
  <div style="max-width:960px;margin:16px auto 0;padding:0 24px;">
    {{> onboarding-checklist}}
  </div>

  <!-- BODY -->
  <div class="pf-body">

    <!-- SIDEBAR -->
    <aside>

      <!-- DISPONIBILIDADE -->
      <div class="pf-card" id="avail-card">
        <p class="pf-card-title"><i class="bi bi-person-check me-1"></i>Disponibilidade</p>
        <p style="color:#555;font-size:0.72rem;margin:-6px 0 12px;line-height:1.5;">
          Controla sua visibilidade para recrutadores.
        </p>

        <div class="avail-option avail-s1 {{#if (eq user.availabilityStatus 'actively_searching')}}avail-selected{{/if}}"
          onclick="setAvailabilityStatus('actively_searching')"
          title="Desempregado e buscando emprego ativamente. Maior prioridade nas buscas.">
          <div class="avail-icon"><i class="bi bi-search" style="color:#4caf50;font-size:0.9rem;"></i></div>
          <div>
            <div class="avail-title">Buscando Ativamente</div>
            <div class="avail-desc">Desempregado, prioridade máxima</div>
          </div>
          <div class="avail-dot"></div>
        </div>

        <div class="avail-option avail-s2 {{#if (eq user.availabilityStatus 'open_to_opportunities')}}avail-selected{{/if}}"
          onclick="setAvailabilityStatus('open_to_opportunities')"
          title="Empregado, mas aberto a propostas melhores (salário, remoto, crescimento).">
          <div class="avail-icon"><i class="bi bi-briefcase" style="color:#ffc107;font-size:0.9rem;"></i></div>
          <div>
            <div class="avail-title">Aberto a Oportunidades</div>
            <div class="avail-desc">Empregado, aberto a propostas</div>
          </div>
          <div class="avail-dot"></div>
        </div>

        <div class="avail-option avail-s3 {{#if (eq user.availabilityStatus 'in_selection_process')}}avail-selected{{/if}}"
          onclick="setAvailabilityStatus('in_selection_process')"
          title="Participando de processos seletivos, mas ainda pode ser contactado.">
          <div class="avail-icon"><i class="bi bi-hourglass-split" style="color:#fd7e14;font-size:0.9rem;"></i></div>
          <div>
            <div class="avail-title">Em Processo Seletivo</div>
            <div class="avail-desc">Em processos, ainda contactável</div>
          </div>
          <div class="avail-dot"></div>
        </div>

        <div class="avail-option avail-s4 {{#if (eq user.availabilityStatus 'not_available')}}avail-selected{{/if}}"
          onclick="setAvailabilityStatus('not_available')"
          title="Não deseja receber contatos. Não aparece em buscas de recrutadores.">
          <div class="avail-icon"><i class="bi bi-lock-fill" style="color:#f03e3e;font-size:0.9rem;"></i></div>
          <div>
            <div class="avail-title">Não Disponível</div>
            <div class="avail-desc">Não desejo contato agora</div>
          </div>
          <div class="avail-dot"></div>
        </div>
      </div>

      <!-- LINKS -->
      <div class="pf-card">
        <p class="pf-card-title"><i class="bi bi-link-45deg me-1"></i>Links & Contato</p>
        {{#if user.github}}
          <a href="{{user.github}}" target="_blank" class="pf-link-item">
            <i class="bi bi-github"></i> GitHub <i class="bi bi-arrow-up-right ms-auto"></i>
          </a>
        {{else}}
          <div class="pf-empty-link" onclick="document.getElementById('editModal').style.display='flex'">
            <i class="bi bi-github"></i> Adicionar GitHub <i class="bi bi-plus ms-auto"></i>
          </div>
        {{/if}}
        {{#if user.linkedin}}
          <a href="{{user.linkedin}}" target="_blank" class="pf-link-item">
            <i class="bi bi-linkedin" style="color:#0a66c2;"></i> LinkedIn <i class="bi bi-arrow-up-right ms-auto"></i>
          </a>
        {{else}}
          <div class="pf-empty-link" onclick="document.getElementById('editModal').style.display='flex'">
            <i class="bi bi-linkedin"></i> Adicionar LinkedIn <i class="bi bi-plus ms-auto"></i>
          </div>
        {{/if}}
        {{#if user.phone}}
          <a href="https://wa.me/55{{user.phone}}" target="_blank" class="pf-link-item">
            <i class="bi bi-whatsapp" style="color:#25d366;"></i> WhatsApp <i class="bi bi-arrow-up-right ms-auto"></i>
          </a>
        {{else}}
          <div class="pf-empty-link" onclick="document.getElementById('editModal').style.display='flex'">
            <i class="bi bi-telephone"></i> Adicionar telefone <i class="bi bi-plus ms-auto"></i>
          </div>
        {{/if}}
      </div>

      <!-- CONTA -->
      <div class="pf-card">
        <p class="pf-card-title"><i class="bi bi-person-badge me-1"></i>Conta</p>
        <div class="pf-info-row">
          <div class="pf-info-label">E-mail</div>
          <div class="pf-info-value" style="font-size:0.85rem;">{{user.email}}</div>
        </div>
        <div class="pf-info-row" style="margin-bottom:0;">
          <div class="pf-info-label">Membro desde</div>
          <div class="pf-info-value" style="font-size:0.85rem;">{{formatDate user.createdAt}}</div>
        </div>
      </div>

    </aside>

    <!-- CONTEÚDO PRINCIPAL -->
    <main>
      <!-- TABS -->
      <div class="pf-tabs">
        <button class="pf-tab active" onclick="switchTab('sobre', this)">
          <i class="bi bi-person"></i>Sobre
        </button>
        <button class="pf-tab" onclick="switchTab('curriculo', this)">
          <i class="bi bi-file-earmark-text"></i>Currículo
        </button>
      </div>

      <!-- ABA SOBRE -->
      <div class="pf-tab-pane active" id="tab-sobre">
        <div class="pf-card">
          <p class="pf-section-head"><i class="bi bi-file-person"></i>Sobre mim</p>
          {{#if user.bio}}
            <p style="color:#ccc;line-height:1.7;margin:0;">{{user.bio}}</p>
          {{else}}
            <div style="text-align:center;padding:32px 0;">
              <i class="bi bi-pencil-square" style="font-size:2rem;color:#333;"></i>
              <p style="color:#555;margin-top:10px;font-size:0.88rem;">Nenhuma bio ainda.</p>
              <button class="pf-btn-edit" onclick="document.getElementById('editModal').style.display='flex'" style="margin:0 auto;">
                <i class="bi bi-pencil"></i>Adicionar bio
              </button>
            </div>
          {{/if}}
        </div>
      </div>

      <!-- ABA CURRÍCULO -->
      <div class="pf-tab-pane" id="tab-curriculo">
        <div class="pf-card" style="text-align:center;padding:48px 24px;">
          <i class="bi bi-file-earmark-person" style="font-size:3rem;color:#f03e3e;"></i>
          <h5 style="margin:16px 0 8px;font-weight:700;">
            {{#if hasCurriculo}}Seu currículo está pronto!{{else}}Ainda sem currículo{{/if}}
          </h5>
          <p style="color:#666;font-size:0.88rem;margin-bottom:20px;">
            {{#if hasCurriculo}}Visualize, edite ou exporte em PDF.{{else}}Crie seu currículo e apareça para os recrutadores.{{/if}}
          </p>
          <div class="d-flex gap-2 justify-content-center flex-wrap">
            {{#if hasCurriculo}}
              <a href="/resume/view" style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:8px 20px;text-decoration:none;font-weight:600;font-size:0.88rem;">
                <i class="bi bi-eye me-1"></i>Ver Currículo
              </a>
              <a href="/resume/create" style="background:transparent;border:1px solid #f03e3e;color:#f03e3e;border-radius:8px;padding:8px 20px;text-decoration:none;font-weight:600;font-size:0.88rem;">
                <i class="bi bi-pencil me-1"></i>Editar
              </a>
            {{else}}
              <a href="/resume/create" style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:8px 20px;text-decoration:none;font-weight:600;font-size:0.88rem;">
                <i class="bi bi-plus-lg me-1"></i>Criar Currículo
              </a>
            {{/if}}
          </div>
        </div>
      </div>
    </main>

  </div>
</div>

<!-- MODAL EDITAR CANDIDATO -->
<div id="editModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.75);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:#141414;border:1px solid #222;border-radius:16px;padding:32px;width:100%;max-width:600px;max-height:90vh;overflow-y:auto;">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h5 style="color:#e0e0e0;font-weight:700;margin:0;"><i class="bi bi-pencil-square me-2"></i>Editar Perfil</h5>
      <button onclick="document.getElementById('editModal').style.display='none'"
        style="background:transparent;border:none;color:#555;font-size:1.5rem;cursor:pointer;line-height:1;">&times;</button>
    </div>
    <form action="/profile/update" method="POST">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <div class="row g-3">
        <div class="col-md-6">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Nome completo</label>
          <input type="text" class="form-control" name="name" value="{{user.name}}" required
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
        <div class="col-md-6">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Cidade</label>
          <input type="text" class="form-control" name="city" value="{{user.city}}" placeholder="Ex: São Paulo, SP"
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
        <div class="col-md-6">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-calendar3 me-1"></i>Data de nascimento</label>
          <input type="text" class="form-control" name="birthDate" value="{{user.birthDate}}"
            placeholder="DD/MM/AAAA" maxlength="10"
            oninput="this.value=this.value.replace(/\D/g,'').replace(/(\d{2})(\d)/,'$1/$2').replace(/(\d{2})(\d)/,'$1/$2').replace(/(\d{4})\d+?$/,'$1')"
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
        <div class="col-md-6">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-whatsapp me-1"></i>Telefone/WhatsApp</label>
          <input type="text" class="form-control" name="phone" value="{{user.phone}}" placeholder="(11) 99999-9999"
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
        <div class="col-12">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-geo-alt me-1"></i>Endereço</label>
          <input type="text" class="form-control" name="address" value="{{user.address}}" placeholder="Rua das Flores, 123 - Bairro, Cidade/UF"
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
        <div class="col-12">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;">Bio</label>
          <textarea class="form-control" name="bio" rows="3" placeholder="Fale um pouco sobre você..."
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;resize:none;">{{user.bio}}</textarea>
        </div>
        <div class="col-md-6">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-github me-1"></i>GitHub</label>
          <input type="url" class="form-control" name="github" value="{{user.github}}" placeholder="https://github.com/usuario"
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
        <div class="col-md-6">
          <label style="color:#666;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.5px;"><i class="bi bi-linkedin me-1"></i>LinkedIn</label>
          <input type="url" class="form-control" name="linkedin" value="{{user.linkedin}}" placeholder="https://linkedin.com/in/usuario"
            style="background:#1e1e1e;border:1px solid #2a2a2a;color:#e0e0e0;border-radius:8px;" />
        </div>
      </div>
      <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" onclick="document.getElementById('editModal').style.display='none'"
          style="background:transparent;border:1px solid #333;color:#888;border-radius:8px;padding:8px 18px;cursor:pointer;">Cancelar</button>
        <button type="submit"
          style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:8px 20px;font-weight:600;">
          <i class="bi bi-check-lg me-1"></i>Salvar
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function switchTab(id, btn) {
    document.querySelectorAll('.pf-tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.pf-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    btn.classList.add('active');
}

// ── Disponibilidade: configuração dos 4 status ────────────────────────────────
const _AVAIL_CFG = {
    actively_searching:    {
        slot: 'avail-s1',
        statLabel: 'Ativo',
        statColor: '#4caf50',
        badgeLabel: 'Buscando Ativamente',
        badgeStyle: 'background:rgba(76,175,80,0.12);border-color:rgba(76,175,80,0.35);color:#4caf50;',
        showBadge: true
    },
    open_to_opportunities: {
        slot: 'avail-s2',
        statLabel: 'Aberto',
        statColor: '#ffc107',
        badgeLabel: 'Aberto a Oportunidades',
        badgeStyle: 'background:rgba(255,193,7,0.12);border-color:rgba(255,193,7,0.35);color:#ffc107;',
        showBadge: true
    },
    in_selection_process:  {
        slot: 'avail-s3',
        statLabel: 'Processo',
        statColor: '#fd7e14',
        badgeLabel: 'Em Processo Seletivo',
        badgeStyle: 'background:rgba(253,126,20,0.12);border-color:rgba(253,126,20,0.35);color:#fd7e14;',
        showBadge: true
    },
    not_available:         {
        slot: 'avail-s4',
        statLabel: 'Inativo',
        statColor: '#f03e3e',
        badgeLabel: 'Não Disponível',
        badgeStyle: 'background:rgba(240,62,62,0.08);border-color:rgba(240,62,62,0.3);color:#f03e3e;',
        showBadge: true
    }
};

// Status atual vindo do servidor (usado para rollback em caso de erro)
let _currentAvailStatus = '{{user.availabilityStatus}}';

async function setAvailabilityStatus(status) {
    if (status === _currentAvailStatus) return;

    // Atualização otimista da UI
    _applyAvailabilityUI(status);

    try {
        const res  = await fetch('/profile/availability-status', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '{{csrfToken}}' },
            body:    JSON.stringify({ status })
        });
        const data = await res.json();
        if (data.ok) {
            _currentAvailStatus = status;   // confirma o novo estado
        } else {
            _applyAvailabilityUI(_currentAvailStatus); // rollback
        }
    } catch {
        _applyAvailabilityUI(_currentAvailStatus);     // rollback em erro de rede
    }
}

function _applyAvailabilityUI(status) {
    const cfg = _AVAIL_CFG[status];
    if (!cfg) return;

    // Atualiza cards do seletor
    document.querySelectorAll('.avail-option').forEach(el => el.classList.remove('avail-selected'));
    const selected = document.querySelector(`.avail-option.${cfg.slot}`);
    if (selected) selected.classList.add('avail-selected');

    // Atualiza badge do header
    const badge = document.getElementById('avail-badge');
    if (badge) {
        if (cfg.showBadge) {
            badge.style.cssText = cfg.badgeStyle;
            badge.innerHTML     = `<i class="bi bi-circle-fill" style="font-size:0.5rem;"></i>${cfg.badgeLabel}`;
            badge.classList.add('visible');
        } else {
            badge.classList.remove('visible');
        }
    }

    // Atualiza stat box (texto, cor do número e barra)
    const stat = document.getElementById('avail-stat-text');
    if (stat) {
        stat.textContent  = cfg.statLabel;
        stat.style.color  = cfg.statColor;
    }
    const bar = document.getElementById('avail-stat-bar');
    if (bar) bar.style.background = cfg.statColor;
}
</script>
