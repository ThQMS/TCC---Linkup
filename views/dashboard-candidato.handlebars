<div style="padding-top:80px;padding-bottom:60px;">
  <div class="container" style="max-width:1000px;">

    <!-- HEADER -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <div>
        <h2 style="font-weight:700;margin-bottom:4px;">
          <i class="bi bi-speedometer2 me-2" style="color:#f03e3e;"></i>Meu Dashboard
        </h2>
        <p style="color:#888;margin:0;">Acompanhe sua jornada de candidaturas.</p>
      </div>
      <div class="d-flex gap-2 align-items-center flex-wrap">
        <a href="/profile" style="color:#aaa;text-decoration:none;font-size:0.9rem;display:flex;align-items:center;">
          <i class="bi bi-arrow-left me-1"></i> Perfil
        </a>
      </div>
    </div>

    <!-- CARDS DE RESUMO -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:20px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:#f03e3e;">{{totalCandidaturas}}</div>
          <div style="font-size:0.85rem;color:#888;">Total</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:20px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:#ffc107;">{{totalPendentes}}</div>
          <div style="font-size:0.85rem;color:#888;">Pendentes</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:20px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:#4caf50;">{{totalAceitos}}</div>
          <div style="font-size:0.85rem;color:#888;">Aceitos</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:20px;text-align:center;">
          <div style="font-size:2rem;font-weight:700;color:#ef5350;">{{totalRecusados}}</div>
          <div style="font-size:0.85rem;color:#888;">Recusados</div>
        </div>
      </div>
    </div>

    <!-- CARD OPORTUNIDADES REVISITADAS -->
    {{#if oportunidadesRevisitadas}}
    <div style="background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(240,62,62,0.06));border:1px solid #a855f7;border-radius:12px;padding:20px 24px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(168,85,247,0.15);border:1px solid rgba(168,85,247,0.3);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="bi bi-arrow-repeat" style="color:#a855f7;font-size:1.4rem;"></i>
        </div>
        <div>
          <div style="font-weight:700;font-size:1rem;color:#a855f7;">
            {{oportunidadesRevisitadas}} Oportunidade(s) Revisitada(s)
          </div>
          <div style="color:#888;font-size:0.82rem;margin-top:2px;">
            Empresas que você se candidatou reabriram vagas com alto fit para você.
          </div>
        </div>
      </div>
      <a href="/notifications"
        style="background:#a855f7;color:white;border-radius:8px;padding:8px 18px;text-decoration:none;font-size:0.85rem;font-weight:600;white-space:nowrap;">
        Ver notificações <i class="bi bi-arrow-right ms-1"></i>
      </a>
    </div>
    {{/if}}

    <div class="row g-4 mb-4">

      <!-- GRÁFICO DE PIZZA -->
      {{#if applications.length}}
      <div class="col-md-5">
        <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:24px;height:100%;">
          <h5 style="color:#f03e3e;font-weight:700;margin-bottom:20px;">
            <i class="bi bi-pie-chart me-2"></i>Distribuição
          </h5>
          <canvas id="statusChart"></canvas>
        </div>
      </div>

      <!-- PAINEL DE RESULTADOS -->
      <div class="col-md-7">
        <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:24px;height:100%;display:flex;flex-direction:column;justify-content:space-between;">
          <div>
            <h5 style="color:#f03e3e;font-weight:700;margin-bottom:24px;">
              <i class="bi bi-bar-chart-line me-2"></i>Resultado das Candidaturas
            </h5>
            <div style="display:flex;flex-direction:column;gap:20px;">

              <!-- Pendentes -->
              <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;">
                  <span style="font-size:0.85rem;color:#aaa;display:flex;align-items:center;gap:8px;">
                    <span style="width:9px;height:9px;border-radius:50%;background:#ffc107;flex-shrink:0;display:inline-block;"></span>
                    Pendentes
                  </span>
                  <span style="font-size:0.9rem;font-weight:700;color:#ffc107;">{{totalPendentes}}</span>
                </div>
                <div style="height:7px;background:#2a2a2a;border-radius:4px;overflow:hidden;">
                  <div class="dash-bar" data-val="{{totalPendentes}}" data-total="{{totalCandidaturas}}" data-color="#ffc107"
                    style="height:100%;background:#ffc107;border-radius:4px;width:0;transition:width 0.7s ease;"></div>
                </div>
              </div>

              <!-- Aceitos -->
              <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;">
                  <span style="font-size:0.85rem;color:#aaa;display:flex;align-items:center;gap:8px;">
                    <span style="width:9px;height:9px;border-radius:50%;background:#4caf50;flex-shrink:0;display:inline-block;"></span>
                    Aceitos / Aprovados
                  </span>
                  <span style="font-size:0.9rem;font-weight:700;color:#4caf50;">{{totalAceitos}}</span>
                </div>
                <div style="height:7px;background:#2a2a2a;border-radius:4px;overflow:hidden;">
                  <div class="dash-bar" data-val="{{totalAceitos}}" data-total="{{totalCandidaturas}}" data-color="#4caf50"
                    style="height:100%;background:#4caf50;border-radius:4px;width:0;transition:width 0.7s ease;"></div>
                </div>
              </div>

              <!-- Recusados -->
              <div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;">
                  <span style="font-size:0.85rem;color:#aaa;display:flex;align-items:center;gap:8px;">
                    <span style="width:9px;height:9px;border-radius:50%;background:#ef5350;flex-shrink:0;display:inline-block;"></span>
                    Não selecionado
                  </span>
                  <span style="font-size:0.9rem;font-weight:700;color:#ef5350;">{{totalRecusados}}</span>
                </div>
                <div style="height:7px;background:#2a2a2a;border-radius:4px;overflow:hidden;">
                  <div class="dash-bar" data-val="{{totalRecusados}}" data-total="{{totalCandidaturas}}" data-color="#ef5350"
                    style="height:100%;background:#ef5350;border-radius:4px;width:0;transition:width 0.7s ease;"></div>
                </div>
              </div>

            </div>
          </div>

          <!-- Taxa de aprovação -->
          <div style="margin-top:28px;padding-top:20px;border-top:1px solid #2a2a2a;display:flex;justify-content:space-between;align-items:center;">
            <div>
              <div style="font-size:0.8rem;color:#666;margin-bottom:2px;">Taxa de aprovação</div>
              <div id="taxa-aprovacao" style="font-size:1.6rem;font-weight:700;color:#4caf50;">—</div>
            </div>
            <div style="text-align:right;">
              <div style="font-size:0.8rem;color:#666;margin-bottom:2px;">Total enviadas</div>
              <div style="font-size:1.6rem;font-weight:700;color:#f03e3e;">{{totalCandidaturas}}</div>
            </div>
          </div>
        </div>
      </div>
      {{/if}}

    </div>

    <!-- TIMELINE DE CANDIDATURAS -->
    <div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:24px;">
      <h5 style="color:#f03e3e;font-weight:700;margin-bottom:24px;">
        <i class="bi bi-clock-history me-2"></i>Timeline de Candidaturas
      </h5>

      {{#if applications.length}}
        <div style="position:relative;">
          <!-- Linha vertical da timeline -->
          <div style="position:absolute;left:19px;top:0;bottom:0;width:2px;background:#2a2a2a;"></div>

          {{#each applications}}
          {{#if this.job}}
          <div style="position:relative;padding-left:52px;margin-bottom:28px;">

            <!-- Ícone do ponto na timeline -->
            <div style="position:absolute;left:0;top:4px;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;z-index:1;
              {{#if (eq this.status 'aprovado')}}background:#1a3a1a;border:2px solid #4caf50;
              {{else if (eq this.status 'contratado')}}background:#1a3a1a;border:2px solid #4caf50;
              {{else if (eq this.status 'rejeitado')}}background:#3a1a1a;border:2px solid #f03e3e;
              {{else if (eq this.status 'expirado')}}background:#2a2a2a;border:2px solid #555;
              {{else}}background:#2a2a1a;border:2px solid #ffc107;{{/if}}">
              <i class="bi {{#if (eq this.status 'aprovado')}}bi-check-lg" style="color:#4caf50;
                {{else if (eq this.status 'contratado')}}bi-award-fill" style="color:#4caf50;
                {{else if (eq this.status 'rejeitado')}}bi-x-lg" style="color:#f03e3e;
                {{else if (eq this.status 'expirado')}}bi-dash-circle" style="color:#555;
                {{else}}bi-hourglass-split" style="color:#ffc107;{{/if}}
                font-size:1rem;"></i>
            </div>

            <!-- Card da candidatura -->
            <div style="background:#141414;border:1px solid #2a2a2a;border-radius:10px;padding:16px 20px;
              {{#if (eq this.status 'aprovado')}}border-left:3px solid #4caf50;
              {{else if (eq this.status 'contratado')}}border-left:3px solid #4caf50;
              {{else if (eq this.status 'rejeitado')}}border-left:3px solid #f03e3e;
              {{else if (eq this.status 'expirado')}}border-left:3px solid #555;
              {{else}}border-left:3px solid #ffc107;{{/if}}">

              <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                <div>
                  <p style="font-weight:700;font-size:0.95rem;margin:0 0 2px;">{{this.job.title}}</p>
                  <p style="color:#f03e3e;font-size:0.82rem;margin:0;">{{this.job.company}}</p>
                </div>
                <span style="padding:4px 12px;border-radius:20px;font-size:0.75rem;font-weight:700;white-space:nowrap;
                  {{#if (eq this.status 'aprovado')}}background:#1a3a1a;color:#4caf50;border:1px solid #4caf50;
                  {{else if (eq this.status 'contratado')}}background:#1a3a1a;color:#4caf50;border:1px solid #4caf50;
                  {{else if (eq this.status 'rejeitado')}}background:#3a1a1a;color:#f03e3e;border:1px solid #f03e3e;
                  {{else if (eq this.status 'expirado')}}background:#2a2a2a;color:#666;border:1px solid #444;
                  {{else if (eq this.status 'em análise')}}background:rgba(6,182,212,0.08);color:#06b6d4;border:1px solid rgba(6,182,212,0.3);
                  {{else}}background:#2a2a1a;color:#ffc107;border:1px solid #ffc107;{{/if}}">
                  {{#if (eq this.status 'aprovado')}}<i class="bi bi-check-circle-fill me-1"></i>Aprovado
                  {{else if (eq this.status 'contratado')}}<i class="bi bi-award-fill me-1"></i>Contratado
                  {{else if (eq this.status 'rejeitado')}}<i class="bi bi-x-circle-fill me-1"></i>Não selecionado
                  {{else if (eq this.status 'expirado')}}<i class="bi bi-dash-circle me-1"></i>Vaga encerrada
                  {{else if (eq this.status 'em análise')}}<i class="bi bi-search me-1"></i>Em análise
                  {{else}}<i class="bi bi-hourglass-split me-1"></i>Pendente{{/if}}
                </span>
              </div>

              <!-- Badges da vaga -->
              <div class="d-flex gap-2 flex-wrap mb-3">
                {{#if this.job.modality}}
                  <span style="background:#2a2a2a;border:1px solid #333;color:#aaa;border-radius:20px;padding:2px 10px;font-size:0.72rem;">
                    {{this.job.modality}}
                  </span>
                {{/if}}
                {{#if this.job.salary}}
                  <span style="background:#2a2a2a;border:1px solid #333;color:#aaa;border-radius:20px;padding:2px 10px;font-size:0.72rem;">
                    <i class="bi bi-cash-coin me-1"></i>R$ {{this.job.salary}}
                  </span>
                {{/if}}
              </div>

              <!-- Passos da timeline interna -->
              <div class="d-flex align-items-center gap-0 mb-3" style="overflow-x:auto;">

                <!-- Passo 1: Candidatura enviada (sempre completo) -->
                <div style="display:flex;flex-direction:column;align-items:center;min-width:80px;">
                  <div style="width:28px;height:28px;border-radius:50%;background:#1a3a1a;border:2px solid #4caf50;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-check" style="color:#4caf50;font-size:0.75rem;"></i>
                  </div>
                  <p style="font-size:0.65rem;color:#4caf50;margin:4px 0 0;text-align:center;line-height:1.2;">Enviada</p>
                </div>

                <div style="flex:1;height:2px;background:#2a2a2a;min-width:20px;
                  {{#if (eq this.status 'aprovado')}}background:#4caf50;
                  {{else if (eq this.status 'contratado')}}background:#4caf50;
                  {{else if (eq this.status 'rejeitado')}}background:#f03e3e;
                  {{else if (eq this.status 'expirado')}}background:#555;
                  {{else}}background:#2a2a2a;{{/if}}"></div>

                <!-- Passo 2: Em análise -->
                <div style="display:flex;flex-direction:column;align-items:center;min-width:80px;">
                  <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;
                    {{#if (eq this.status 'aprovado')}}background:#1a3a1a;border:2px solid #4caf50;
                    {{else if (eq this.status 'contratado')}}background:#1a3a1a;border:2px solid #4caf50;
                    {{else if (eq this.status 'rejeitado')}}background:#3a1a1a;border:2px solid #f03e3e;
                    {{else if (eq this.status 'expirado')}}background:#2a2a2a;border:2px solid #555;
                    {{else}}background:#2a2a1a;border:2px solid #ffc107;{{/if}}">
                    <i class="bi {{#if (eq this.status 'aprovado')}}bi-check{{else if (eq this.status 'contratado')}}bi-check{{else if (eq this.status 'rejeitado')}}bi-check{{else if (eq this.status 'expirado')}}bi-check{{else}}bi-hourglass-split{{/if}}"
                      style="font-size:0.75rem;
                      {{#if (eq this.status 'aprovado')}}color:#4caf50;
                      {{else if (eq this.status 'contratado')}}color:#4caf50;
                      {{else if (eq this.status 'rejeitado')}}color:#f03e3e;
                      {{else if (eq this.status 'expirado')}}color:#555;
                      {{else}}color:#ffc107;{{/if}}"></i>
                  </div>
                  <p style="font-size:0.65rem;margin:4px 0 0;text-align:center;line-height:1.2;
                    {{#if (eq this.status 'aprovado')}}color:#4caf50;
                    {{else if (eq this.status 'contratado')}}color:#4caf50;
                    {{else if (eq this.status 'rejeitado')}}color:#f03e3e;
                    {{else if (eq this.status 'expirado')}}color:#555;
                    {{else}}color:#ffc107;{{/if}}">Em análise</p>
                </div>

                <div style="flex:1;height:2px;min-width:20px;
                  {{#if (eq this.status 'aprovado')}}background:#4caf50;
                  {{else if (eq this.status 'contratado')}}background:#4caf50;
                  {{else if (eq this.status 'rejeitado')}}background:#f03e3e;
                  {{else if (eq this.status 'expirado')}}background:#555;
                  {{else}}background:#2a2a2a;{{/if}}"></div>

                <!-- Passo 3: Resultado final -->
                <div style="display:flex;flex-direction:column;align-items:center;min-width:80px;">
                  <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;
                    {{#if (eq this.status 'aprovado')}}background:#1a3a1a;border:2px solid #4caf50;
                    {{else if (eq this.status 'contratado')}}background:#1a3a1a;border:2px solid #4caf50;
                    {{else if (eq this.status 'rejeitado')}}background:#3a1a1a;border:2px solid #f03e3e;
                    {{else if (eq this.status 'expirado')}}background:#2a2a2a;border:2px solid #555;
                    {{else}}background:#141414;border:2px solid #444;{{/if}}">
                    <i class="bi {{#if (eq this.status 'aprovado')}}bi-check-circle{{else if (eq this.status 'contratado')}}bi-award-fill{{else if (eq this.status 'rejeitado')}}bi-x-lg{{else if (eq this.status 'expirado')}}bi-dash-circle{{else}}bi-circle{{/if}}"
                      style="font-size:0.75rem;
                      {{#if (eq this.status 'aprovado')}}color:#4caf50;
                      {{else if (eq this.status 'contratado')}}color:#4caf50;
                      {{else if (eq this.status 'rejeitado')}}color:#f03e3e;
                      {{else if (eq this.status 'expirado')}}color:#555;
                      {{else}}color:#444;{{/if}}"></i>
                  </div>
                  <p style="font-size:0.65rem;margin:4px 0 0;text-align:center;line-height:1.2;
                    {{#if (eq this.status 'aprovado')}}color:#4caf50;
                    {{else if (eq this.status 'contratado')}}color:#4caf50;
                    {{else if (eq this.status 'rejeitado')}}color:#f03e3e;
                    {{else if (eq this.status 'expirado')}}color:#555;
                    {{else}}color:#444;{{/if}}">
                    {{#if (eq this.status 'aprovado')}}Aprovado!
                    {{else if (eq this.status 'contratado')}}Contratado!
                    {{else if (eq this.status 'rejeitado')}}Não selecionado
                    {{else if (eq this.status 'expirado')}}Encerrada
                    {{else}}Aguardando{{/if}}
                  </p>
                </div>
              </div>

              <!-- Rodapé: data + link -->
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span style="color:#555;font-size:0.78rem;">
                  <i class="bi bi-calendar3 me-1"></i>Candidatura em {{formatDate this.createdAt}}
                </span>
                <a href="/jobs/view/{{this.job.id}}"
                  style="background:transparent;border:1px solid #333;color:#aaa;border-radius:6px;padding:4px 12px;text-decoration:none;font-size:0.78rem;transition:border-color 0.2s;"
                  onmouseover="this.style.borderColor='#f03e3e';this.style.color='#f03e3e'"
                  onmouseout="this.style.borderColor='#333';this.style.color='#aaa'">
                  Ver Vaga <i class="bi bi-arrow-right ms-1"></i>
                </a>
              </div>
            </div>
          </div>
          {{/if}}
          {{/each}}
        </div>

      {{else}}
        <div style="text-align:center;padding:50px 0;">
          <i class="bi bi-clock-history" style="font-size:3rem;color:#f03e3e;"></i>
          <h5 class="mt-3">Nenhuma candidatura ainda</h5>
          <p class="text-muted">Candidate-se a vagas para acompanhar sua jornada aqui.</p>
          <a href="/" style="background:#f03e3e;border:none;color:white;border-radius:8px;padding:8px 20px;text-decoration:none;">
            <i class="bi bi-search me-1"></i> Buscar Vagas
          </a>
        </div>
      {{/if}}
    </div>

  </div>


<div style="background:#1e1e1e;border:1px solid #2a2a2a;border-radius:12px;padding:20px;margin-top:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
  <div style="display:flex;align-items:center;gap:14px;">
    <div style="width:42px;height:42px;border-radius:10px;background:rgba(240,62,62,0.1);border:1px solid rgba(240,62,62,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="bi bi-cpu" style="color:#f03e3e;font-size:1.1rem;"></i>
    </div>
    <div>
      <div style="font-weight:700;font-size:0.9rem;">Métricas de IA</div>
      <div style="color:#666;font-size:0.78rem;">Veja o uso das features de inteligência artificial</div>
    </div>
  </div>
  <a href="/ai-metrics"
    style="background:transparent;border:1px solid #f03e3e;color:#f03e3e;border-radius:8px;padding:7px 16px;text-decoration:none;font-size:0.85rem;font-weight:600;white-space:nowrap;transition:all 0.2s;"
    onmouseover="this.style.background='#f03e3e';this.style.color='white'"
    onmouseout="this.style.background='transparent';this.style.color='#f03e3e'">
    <i class="bi bi-graph-up-arrow me-1"></i> Ver Métricas
  </a>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const pieData = {
    pendentes: {{totalPendentes}},
    aceitos:   {{totalAceitos}},
    recusados: {{totalRecusados}}
  };

  const ctx = document.getElementById('statusChart');
  if (ctx && (pieData.pendentes + pieData.aceitos + pieData.recusados) > 0) {
    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['Pendentes', 'Aceitos', 'Recusados'],
        datasets: [{
          data: [pieData.pendentes, pieData.aceitos, pieData.recusados],
          backgroundColor: ['#ffc107', '#4caf50', '#f03e3e'],
          borderColor: '#1e1e1e',
          borderWidth: 3
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#aaa', padding: 16, font: { size: 12 } }
          }
        },
        cutout: '65%'
      }
    });
  }

  // Barras animadas de resultado
  const dashTotal = {{totalCandidaturas}} || 1;
  document.querySelectorAll('.dash-bar').forEach(bar => {
    const val  = parseInt(bar.dataset.val)   || 0;
    const tot  = parseInt(bar.dataset.total) || 1;
    const pct  = tot > 0 ? Math.min(Math.round(val / tot * 100), 100) : 0;
    setTimeout(() => { bar.style.width = pct + '%'; }, 200);
  });
  const taxaEl = document.getElementById('taxa-aprovacao');
  if (taxaEl && {{totalCandidaturas}} > 0) {
    taxaEl.textContent = Math.round({{totalAceitos}} / {{totalCandidaturas}} * 100) + '%';
